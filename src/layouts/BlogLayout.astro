---
import BaseHead from '@/components/base/Head.astro'
import '@unocss/reset/tailwind.css'
import '@/styles/main.css'
import '@/styles/prose.css'
import '@/styles/markdown.css'
import Navbar from '@/components/site/SiteNavbar.astro'
import Footer from '@/components/site/SiteFooter.astro'
import ToTopButton from '@/components/widgets/ToTopButton.astro'
import { BlogSearch } from '@/components/BlogSearch'
import SpeedInsights from '@vercel/speed-insights/astro'
import Analytics from '@vercel/analytics/astro'
import { FEATURES } from '@/config'

interface Props {
  title: string
  description?: string
  image?: string
  canonicalURL?: string
  pubDate?: Date
  author?: string
  tags?: string[]
}

const {
  title,
  description = 'A blog post',
  image = '/images/blog-default.jpg',
  pubDate,
  author,
  tags = [],
} = Astro.props

// Format date if provided
const formattedDate = pubDate?.toLocaleDateString('en-us', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const { cspNonce } = Astro.locals
const { nprogress, mediumZoom } = FEATURES
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <BaseHead {title} {description} ogImage={image} {cspNonce} />

    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#05030d" />

    <link rel="stylesheet" href="/css/background-fixes.css" />

    <script src="/js/polyfill-detector.js" is:inline></script>
    <script src="/js/module-loader.js" defer is:inline></script>
    <script src="/js/background-loader.js" defer is:inline></script>
    {
      (nprogress || mediumZoom) && (
        <script src="/js/nprogress-and-zoom.js" type="module" />
      )
    }

    <!-- Structured data for blog post -->
    {
      pubDate && author && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'BlogPosting',
            'headline': title,
            'image': [image],
            'datePublished': pubDate.toISOString(),
            'author': [
              {
                '@type': 'Person',
                'name': author,
              },
            ],
          })}
        />
      )
    }
  </head>

  <body
    class="min-h-screen flex flex-col overflow-x-hidden"
  >
    <Navbar />

    <main class="container-refined py-12">
      <article class="prose prose-lg dark:prose-invert mx-auto max-w-4xl">
        <!-- Blog post header -->
        <header class="mb-8">
          <h1 class="text-4xl font-bold mb-4">{title}</h1>
          {
            formattedDate && (
              <time
                datetime={pubDate?.toISOString()}
                class="text-muted-foreground"
              >
                {formattedDate}
              </time>
            )
          }
          {author && <p class="text-muted-foreground mt-2">By {author}</p>}
          {
            tags.length > 0 && (
              <div class="flex gap-2 mt-4">
                {tags.map((tag: unknown) => (
                  <a
                    href={`/blog/tags/${tag}`}
                    class="text-sm px-3 py-1 bg-muted rounded-full hover:bg-muted/80 transition-colors"
                    transition:animate="slide"
                    data-astro-prefetch
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )
          }
        </header>

        <!-- Blog post content -->
        <div class="blog-content">
          <BlogSearch client:load />
          <slot />
        </div>
      </article>
    </main>

    <Footer />
    <ToTopButton />
    <SpeedInsights />
    <Analytics />
    <script is:inline nonce={cspNonce}>
      function speedInsightsBeforeSend(data) {
        console.log('Speed Insights before send', data)
        return data
      }
    </script>
  </body>
</html>
