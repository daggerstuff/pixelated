---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Company Overview - Pixelated Empathy"
  description="Learn how Pixelated Empathy helps therapists, supervisors, and training programs practice difficult mental health conversations with AI simulation and structured feedback."
>
  <main class="flex-1 pt-14">
    <section class="brutalist-section py-20">
      <div class="site-shell site-shell--narrow text-center">
        <span class="eyebrow-text">Company</span>
        <h1 class="text-5xl md:text-6xl font-bold text-white mt-4 mb-6">
          Company Overview
        </h1>
        <p class="text-xl text-gray-300 leading-relaxed max-w-3xl mx-auto">
          Pixelated Empathy is a founder-led software company building AI
          roleplay and simulation tools for therapist training, supervision, and
          clinical rehearsal.
        </p>
      </div>
    </section>

    <section class="brutalist-section py-16 bg-gray-900/60">
      <div class="site-shell">
        <div class="grid gap-8 lg:grid-cols-2">
          <div class="glass-card p-8">
            <h2 class="text-2xl font-bold text-white mb-4">What we provide</h2>
            <p class="text-gray-300 leading-relaxed">
              The product helps teams rehearse crisis assessment, rupture
              repair, trauma disclosure, resistance, and other sessions that are
              hard to stage consistently in live training.
            </p>
          </div>
          <div class="glass-card p-8">
            <h2 class="text-2xl font-bold text-white mb-4">How teams use it</h2>
            <p class="text-gray-300 leading-relaxed">
              Programs can assign the same scenario to multiple trainees, run
              sessions repeatedly, compare decisions, and coach from transcripts
              and structured feedback rather than vague recollection alone.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="brutalist-section py-16">
      <div class="site-shell">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="glass-card p-6">
            <div class="text-sm text-gray-500 mb-2">Who it serves</div>
            <div class="text-lg font-semibold text-white">
              Therapists, supervisors, and training programs
            </div>
          </div>
          <div class="glass-card p-6">
            <div class="text-sm text-gray-500 mb-2">Company stage</div>
            <div class="text-lg font-semibold text-white">
              Founder-led product build
            </div>
          </div>
          <div class="glass-card p-6">
            <div class="text-sm text-gray-500 mb-2">Founded</div>
            <div class="text-lg font-semibold text-white">2025</div>
          </div>
        </div>
      </div>
    </section>

    <section class="brutalist-section py-16 bg-gray-900/60">
      <div class="site-shell site-shell--narrow">
        <div class="glass-card p-8 md:p-10">
          <h2 class="text-3xl font-bold text-white mb-4">Operating profile</h2>
          <div class="grid gap-5 md:grid-cols-2 text-gray-300">
            <div>
              <div class="text-sm text-gray-500 mb-1">Legal Entity</div>
              <div class="text-white font-medium">Pixelated Empathy</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Location</div>
              <div class="text-white font-medium">United States</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Current focus</div>
              <div class="text-white font-medium">
                AI simulation for clinical practice and supervision
              </div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Best fit</div>
              <div class="text-white font-medium">
                Teams that need repeatable, reviewable training
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
