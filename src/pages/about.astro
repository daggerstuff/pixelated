---
import PageHeader from '@/components/ui/PageHeader.astro'
import Surface from '@/components/ui/Surface.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'Pixelated Empathy',
  'url': 'https://pixelatedempathy.com',
  'logo': 'https://pixelatedempathy.com/favicon.svg',
  'description': 'AI-powered training platform for mental health professionals',
  'foundingDate': '2025',
  'address': {
    '@type': 'PostalAddress',
    'addressCountry': 'US',
  },
  'contactPoint': {
    '@type': 'ContactPoint',
    'email': 'info@pixelatedempathy.com',
    'contactType': 'Customer Service',
  },
}
---

<BaseLayout title="About Us - Pixelated Empathy">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
  />
  <section class="brutalist-section pt-20 md:pt-24 pb-16">
    <div class="site-shell site-shell--narrow">
      <PageHeader
        eyebrow="About"
        title="About Pixelated Empathy"
        lede="We build AI roleplay and simulation tools for therapists, supervisors, and training programs that need safer ways to practice difficult conversations."
      />

      <div class="divider my-12"></div>

      <div class="mt-16 grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <Surface class="p-6">
          <h2 class="text-2xl md:text-3xl font-semibold text-white">
            What the platform does
          </h2>
          <p class="mt-4 text-gray-300 leading-relaxed">
            Pixelated Empathy gives teams a place to rehearse crisis
            conversations, rupture repair, trauma disclosures, and other
            sessions that are difficult to stage consistently in the real world.
            After each simulation, the platform helps teams review pacing,
            empathy, bias cues, and decision points.
          </p>
        </Surface>
        <Surface class="p-6">
          <h2 class="text-2xl md:text-3xl font-semibold text-white">
            Why teams use it
          </h2>
          <p class="mt-4 text-gray-300 leading-relaxed">
            Clinical training often depends on a small number of live cases,
            roleplays that vary by facilitator, and supervision notes written
            after the moment has passed. We are building a repeatable training
            environment so programs can practice the same hard scenario, review
            what changed, and coach against something concrete.
          </p>
        </Surface>
      </div>

      <div class="divider my-12"></div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="brutalist-caption mb-2 text-teal-400">Founded</div>
          <p class="text-white font-medium">2025</p>
          <p class="text-gray-400 text-sm mt-1">Founder-led build</p>
        </div>
        <div>
          <div class="brutalist-caption mb-2 text-teal-400">Location</div>
          <p class="text-white font-medium">United States</p>
          <p class="text-gray-400 text-sm mt-1">Serving clients globally</p>
        </div>
        <div>
          <div class="brutalist-caption mb-2 text-teal-400">Who we serve</div>
          <p class="text-white font-medium">
            Training programs, supervisors, and clinicians
          </p>
          <p class="text-gray-400 text-sm mt-1">
            From solo practice to cohort review
          </p>
        </div>
      </div>

      <div class="divider my-12"></div>

      <div class="mt-16">
        <Surface class="p-6">
          <h2 class="text-2xl md:text-3xl font-semibold text-white mb-4">
            Company Information
          </h2>
          <div class="grid md:grid-cols-2 gap-6 mt-4">
            <div>
              <div class="text-sm text-gray-500 mb-1">Legal Entity</div>
              <div class="text-white font-medium">Pixelated Empathy</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Founded</div>
              <div class="text-white font-medium">2025</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Location</div>
              <div class="text-white font-medium">United States</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Status</div>
              <div class="text-white font-medium">
                Founder-led product build
              </div>
            </div>
          </div>
          <p class="mt-6 text-gray-400">
            Learn more about the current team structure on our
            <a href="/team" class="text-teal-400 hover:text-teal-300"
              >team page</a
            >.
          </p>
        </Surface>
      </div>

      <div class="mt-16 text-center">
        <a
          href="/contact"
          class="brutalist-button brutalist-button--primary px-8 py-4 font-semibold"
        >
          Partner with us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
