---
/**
 * Homepage - Pixelated Brutalism Design
 * Modern + Minimalist + Brutalist aesthetic
 */
import Layout from '@/layouts/Layout.astro'
import BrutalistHero from '@/components/BrutalistHero.astro'
import InfoStrip from '@/components/homepage/InfoStrip.astro'
import IntroSection from '@/components/homepage/IntroSection.astro'
import WorkflowSection from '@/components/homepage/WorkflowSection.astro'
import CoreFeatures from '@/components/mizu/CoreFeatures.astro'
import CTA from '@/components/mizu/CTA.astro'
import { homepageContent } from '@/lib/content'
import '@/styles/homepage.css'


const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'Pixelated Empathy',
  'url': 'https://pixelatedempathy.com',
  'logo': 'https://pixelatedempathy.com/favicon.svg',
  'description':
    'Clinical simulation and transcript-based review for therapist training and supervision teams.',
  'foundingDate': '2025',
  'address': {
    '@type': 'PostalAddress',
    'addressCountry': 'US',
  },
  'contactPoint': {
    '@type': 'ContactPoint',
    'email': 'info@pixelatedempathy.com',
    'contactType': 'Customer Service',
  },
  'sameAs': [
    'https://x.com/pixelatedempathy',
    'https://github.com/nochadisfaction/pixelated',
  ],
}
---

<Layout
  title="Pixelated Empathy | Clinical simulation for therapist training and supervision"
  description="Bring one difficult case into clinical rehearsal, keep the transcript, and coach the retry from a record a supervisor can actually use."
>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
  />

  <BrutalistHero
    kicker={homepageContent.hero.kicker}
    title={homepageContent.hero.title}
    subtitle={homepageContent.hero.subtitle}
    proofPoints={homepageContent.hero.proofPoints}
    primaryCTA={homepageContent.hero.primaryCTA}
    secondaryCTA={homepageContent.hero.secondaryCTA}
    artifact={homepageContent.hero.artifact}
  />

  <section class="trust-band-section border-y border-white/5 bg-black/10">
    <div class="container trust-band-shell">

      <InfoStrip
        className="trust-band"
        label="Trust markers"
        items={[
          {
            label: 'Who it is for',
            value: 'Therapist training and supervision teams',
          },
          {
            label: 'What stays attached',
            value: 'Transcript, notes, and retry logic',
          },
          {
            label: 'How to judge it',
            value: 'Start with one real case and review the record together',
          },
        ]}
        theme="dark"
      />
    </div>
  </section>

  <IntroSection content={homepageContent.intro} />
  <WorkflowSection content={homepageContent.how} />

  <CoreFeatures
    label={homepageContent.features.label}
    title={homepageContent.features.title}
    copy={homepageContent.features.copy}
    proofLabel={homepageContent.features.proofLabel}
    proofItems={homepageContent.features.proofItems}
    cards={homepageContent.features.cards}
    comparison={homepageContent.features.comparison}
  />

  <CTA
    label={homepageContent.cta.label}
    title={homepageContent.cta.title}
    intro={homepageContent.cta.intro}
    verdictCopy={homepageContent.cta.verdictCopy}
    proofItems={homepageContent.cta.proofItems}
    decisionTitle={homepageContent.cta.decisionTitle}
    rubric={homepageContent.cta.rubric}
    primaryCTA={homepageContent.cta.primaryCTA}
    secondaryCTA={homepageContent.cta.secondaryCTA}
    meta={homepageContent.cta.meta}
  />
</Layout>


<style>
  .trust-band-section {
    position: relative;
    padding: 1.5rem 0;
  }

  .trust-band-shell {
    position: relative;
    z-index: 1;
  }

  .trust-band {
    width: 100%;
  }

</style>
