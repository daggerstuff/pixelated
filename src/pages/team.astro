---
import MarketingCTA from '@/components/marketing/MarketingCTA.astro'
import MarketingPageHero from '@/components/marketing/MarketingPageHero.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'

const founder = {
  name: 'Chad',
  role: 'Founder',
  bio: 'Pixelated Empathy is currently founder-led. Product direction, implementation, and customer conversations are still tightly connected while the training workflow is being shaped in public.',
  expertise:
    'Product engineering, platform architecture, and AI workflow design',
}

const futureRoles = [
  {
    label: 'Clinical guidance',
    body: 'Advisors who can pressure-test scenarios, feedback language, and training use cases against real clinical workflows.',
  },
  {
    label: 'Design and UX',
    body: 'Product design support that makes difficult workflows readable, teachable, and trustworthy for care teams.',
  },
  {
    label: 'Platform engineering',
    body: 'Engineering depth around privacy, analytics, and scalable simulation workflows.',
  },
]
---

<BaseLayout
  title="Team - Pixelated Empathy"
  description="Learn who is currently building Pixelated Empathy and how the company is structured today."
>
  <MarketingPageHero
    eyebrow="Team"
    title="A founder-led build shaped close to the workflow."
    lede="This page is meant to be accurate about the company’s current shape. Pixelated Empathy is founder-led today, with future growth centered on clinical quality, trustworthy UX, and privacy-aware platform depth."
    note="Current team structure as of April 9, 2026"
    trustLine={['Founder-led', 'United States', 'Clinical workflow focus']}
    primaryCTA={{ text: 'Talk to the founder', href: '/contact' }}
    secondaryCTA={{ text: 'See the product demo', href: '/demo-hub' }}
    stats={[
      { label: 'Current structure', value: 'Founder-led', detail: 'Product, engineering, and customer conversations stay close together' },
      { label: 'Founded', value: '2025', detail: 'Company stage is still early and deliberate' },
      { label: 'Hiring direction', value: 'Quality first', detail: 'Future roles should strengthen training quality and trust' },
    ]}
  />

  <section class="marketing-section">
    <div class="marketing-shell">
      <div class="marketing-grid marketing-grid--2">
        <article class="marketing-card marketing-card--accent">
          <span class="marketing-card__label">{founder.role}</span>
          <h2 class="marketing-title marketing-title--medium">{founder.name}</h2>
          <p>{founder.bio}</p>
          <p><strong>Focus:</strong> {founder.expertise}</p>
        </article>

        <article class="marketing-card">
          <span class="marketing-card__label">Why stay close to the work</span>
          <p>
            The product is still being shaped around how supervisors, educators, and training teams actually evaluate a difficult case. Keeping product, implementation, and conversations close together reduces drift.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="marketing-section marketing-section--soft">
    <div class="marketing-shell">
      <div class="marketing-section-header">
        <span class="marketing-eyebrow">How the team should grow</span>
        <h2 class="marketing-title marketing-title--medium">The next additions should sharpen quality, not add noise.</h2>
      </div>

      <div class="marketing-grid marketing-grid--3">
        {futureRoles.map((role) => (
          <article class="marketing-card">
            <span class="marketing-card__label">{role.label}</span>
            <p>{role.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <MarketingCTA
    eyebrow="Talk to the person building it"
    title="If you are evaluating the workflow, bring the actual supervision problem."
    body="The fastest way to understand whether Pixelated Empathy fits your team is to discuss the case type, coaching challenge, or trust requirement you are trying to solve first."
    checklist={[
      'The training scenario or supervision problem you want to improve',
      'What a successful pilot would need to prove for your team',
      'Any trust, privacy, or rollout constraints that matter early',
    ]}
    primaryCTA={{ text: 'Talk to the founder', href: '/contact' }}
    secondaryCTA={{ text: 'See the product demo', href: '/demo-hub' }}
    note="Clarity around the problem matters more than a perfect org chart."
  />
</BaseLayout>
