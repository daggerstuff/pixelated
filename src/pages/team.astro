---
import BaseLayout from '../layouts/BaseLayout.astro'

const founder = {
  name: 'Chad',
  role: 'Founder',
  bio: 'Pixelated Empathy is currently founder-led. Product direction, implementation, and customer conversations are still tightly connected while the training workflow is being shaped in public.',
  expertise:
    'Product engineering, platform architecture, and AI workflow design',
}
---

<BaseLayout
  title="Team - Pixelated Empathy"
  description="Learn who is currently building Pixelated Empathy and how the company is structured today."
>
  <main class="flex-1 pt-14">
    <section class="brutalist-section py-20">
      <div class="site-shell site-shell--narrow text-center">
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">Team</h1>
        <p class="text-xl text-gray-300 leading-relaxed">
          This page is meant to be accurate about the company’s current shape.
          Pixelated Empathy is founder-led today, with future growth likely
          centered on clinical advisors, design collaborators, and engineering.
        </p>
      </div>
    </section>

    <section class="brutalist-section py-20 bg-gray-900">
      <div class="site-shell">
        <div class="max-w-3xl mx-auto glass-card p-8 text-center">
          <div
            class="w-32 h-32 mx-auto mb-6 rounded-full bg-gradient-to-br from-teal-500 to-blue-600 flex items-center justify-center"
          >
            <span class="text-2xl font-bold text-white">C</span>
          </div>
          <h2 class="text-3xl font-bold text-white mb-2">{founder.name}</h2>
          <p class="text-teal-400 font-medium mb-5">{founder.role}</p>
          <p class="text-gray-300 leading-relaxed mb-5">{founder.bio}</p>
          <p class="text-sm text-gray-400">
            <strong>Focus:</strong>
            {founder.expertise}
          </p>
        </div>
      </div>
    </section>

    <section class="brutalist-section py-20 bg-black">
      <div class="site-shell">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-white mb-4">
            How the team will grow
          </h2>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            The next additions should strengthen training quality, privacy, and
            supervisor workflows rather than add generic headcount.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="glass-card p-6 text-center">
            <h3 class="text-lg font-bold text-white mb-2">Clinical Guidance</h3>
            <p class="text-gray-300 text-sm leading-relaxed">
              Advisors who can pressure-test scenarios, feedback language, and
              training use cases against real clinical workflows.
            </p>
          </div>
          <div class="glass-card p-6 text-center">
            <h3 class="text-lg font-bold text-white mb-2">Design and UX</h3>
            <p class="text-gray-300 text-sm leading-relaxed">
              Product design support that makes difficult workflows readable,
              teachable, and trustworthy for care teams.
            </p>
          </div>
          <div class="glass-card p-6 text-center">
            <h3 class="text-lg font-bold text-white mb-2">
              Platform Engineering
            </h3>
            <p class="text-gray-300 text-sm leading-relaxed">
              Engineering depth around privacy, analytics, and scalable
              simulation workflows.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="brutalist-section py-20 bg-gray-900">
      <div class="site-shell">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-white mb-4">Operating Snapshot</h2>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            A short, accurate view of how the company is structured today.
          </p>
        </div>

        <div class="grid md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="text-4xl font-bold text-teal-400 mb-2">1</div>
            <p class="text-gray-300">Founder leading build and product</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-teal-400 mb-2">2025</div>
            <p class="text-gray-300">Company founded</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-teal-400 mb-2">US</div>
            <p class="text-gray-300">Operating location</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-teal-400 mb-2">AI</div>
            <p class="text-gray-300">Roleplay and simulation focus</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
