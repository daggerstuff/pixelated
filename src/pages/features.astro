---
import MarketingCTA from '@/components/marketing/MarketingCTA.astro'
import MarketingPageHero from '@/components/marketing/MarketingPageHero.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'

const coreCapabilities = [
  {
    label: 'Track 01',
    title: 'Believable case rehearsal',
    items: [
      'Run crisis assessment, trauma disclosure, rupture repair, resistance, and other difficult conversations in a more realistic flow.',
      'Keep the clinician inside the room instead of walking them through a branching script.',
    ],
  },
  {
    label: 'Track 02',
    title: 'Review-ready transcript',
    items: [
      'Keep the transcript, notes, and coaching lane tied to the same session.',
      'Make it easier for supervisors to point at the exact moment that should change next.',
    ],
  },
  {
    label: 'Track 03',
    title: 'Shared case comparison',
    items: [
      'Put multiple trainees through the same difficult case and compare their judgment.',
      'Turn supervision into side-by-side coaching instead of unrelated anecdotal feedback.',
    ],
  },
  {
    label: 'Track 04',
    title: 'Trust-aware rollout',
    items: [
      'Bring privacy, retention, and deployment questions into the evaluation early.',
      'Use the product in a way that fits sensitive training workflows rather than ignoring them.',
    ],
  },
]

const firstWeekSignals = [
  'Teams stop reconstructing the session from memory.',
  'Supervisors can name the line, question, or miss that mattered.',
  'Trainees can compare their judgment against the same difficult moment.',
]

const comparison = [
  {
    label: 'Before',
    quote: '“I think they got rushed somewhere in the middle.”',
  },
  {
    label: 'After',
    quote: '“At the disclosure, they reassured before checking immediacy.”',
  },
  {
    label: 'Before',
    quote: 'Each trainee sees a different roleplay, so the coaching never lines up.',
  },
  {
    label: 'After',
    quote: 'The team can compare how multiple clinicians handled the same rupture.',
  },
]

const foundations = [
  {
    label: 'Practice quality',
    body: 'The product is built to keep the case believable enough that coaching later still feels relevant to the real room.',
  },
  {
    label: 'Specificity',
    body: 'The main job is not novelty. It is giving a supervisor something concrete enough to teach from next week.',
  },
  {
    label: 'Operational fit',
    body: 'Privacy, access control, retention, and deployment questions belong in the evaluation process from the start.',
  },
]
---

<BaseLayout
  title="Features - Pixelated Empathy"
  description="Explore the simulation, supervision, and review capabilities inside Pixelated Empathy."
>
  <MarketingPageHero
    eyebrow="Features"
    title="Features that make hard cases easier to coach."
    lede="Pixelated Empathy is organized around a simple goal: keep the conversation believable, preserve the record, and make the next supervision meeting more specific."
    note="Start with the demo, not a long feature tour"
    trustLine={['Simulation + review', 'Cohort comparison', 'Trust-aware rollout']}
    primaryCTA={{ text: 'See the product demo', href: '/demo-hub' }}
    secondaryCTA={{ text: 'Plan a pilot review', href: '/contact' }}
    stats={[
      { label: 'What teams keep', value: 'Transcript + coaching notes', detail: 'The session record stays attached to the run' },
      { label: 'What teams compare', value: 'One shared case', detail: 'Useful for cohorts, supervisors, and training leads' },
      { label: 'What improves', value: 'Specific feedback', detail: 'The next attempt starts from a visible moment' },
    ]}
  />

  <section class="marketing-section">
    <div class="marketing-shell">
      <div class="marketing-proof-band">
        <div>
          <span class="marketing-eyebrow">Signals in the first week</span>
          <h2 class="marketing-title marketing-title--medium">This should feel clearer quickly.</h2>
          <p class="marketing-section-copy">
            The best early sign is simple: people stop speaking in fuzzy summaries and start pointing at specific turns in the transcript.
          </p>
        </div>

        <div class="marketing-proof-band__items">
          {firstWeekSignals.map((item, index) => (
            <div class="marketing-proof-item">
              <span>Signal {String(index + 1).padStart(2, '0')}</span>
              <strong>{item}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="marketing-section marketing-section--soft">
    <div class="marketing-shell">
      <div class="marketing-section-header">
        <span class="marketing-eyebrow">What the shift looks like</span>
        <h2 class="marketing-title marketing-title--medium">Better features create better supervision language.</h2>
      </div>

      <div class="marketing-quote-grid">
        {comparison.map((item) => (
          <article class:list={['marketing-quote-card', item.label === 'After' && 'marketing-card--accent']}>
            <span class="marketing-quote-label">{item.label}</span>
            <blockquote>{item.quote}</blockquote>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="marketing-section">
    <div class="marketing-shell">
      <div class="marketing-section-header">
        <span class="marketing-eyebrow">Capability map</span>
        <h2 class="marketing-title marketing-title--medium">The platform is built around four practical jobs.</h2>
      </div>

      <div class="marketing-grid marketing-grid--2">
        {coreCapabilities.map((capability) => (
          <article class="marketing-card">
            <span class="marketing-card__label">{capability.label}</span>
            <h3>{capability.title}</h3>
            <ul class="marketing-list">
              {capability.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="marketing-section marketing-section--soft">
    <div class="marketing-shell">
      <div class="marketing-grid marketing-grid--3">
        {foundations.map((item) => (
          <article class="marketing-card">
            <span class="marketing-card__label">{item.label}</span>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <MarketingCTA
    eyebrow="Use one case to evaluate the features"
    title="The right feature set is the one that makes your team coach more clearly."
    body="You do not need to memorize every capability. Start with the product demo, then judge the workflow against one difficult case your team already knows matters."
    checklist={[
      'A case type that usually produces fuzzy or inconsistent coaching',
      'The supervision meeting where you want more specificity',
      'Any privacy, access, or deployment constraints that affect adoption',
    ]}
    primaryCTA={{ text: 'Plan a pilot review', href: '/contact' }}
    secondaryCTA={{ text: 'See the product demo', href: '/demo-hub' }}
    note="A tighter coaching loop matters more than a longer feature checklist."
  />
</BaseLayout>
