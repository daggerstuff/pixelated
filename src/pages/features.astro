---
// Brutalist Features Page - Platform Capabilities
import BaseLayout from '@/layouts/BaseLayout.astro'

const coreFeatures = [
  {
    category: 'CRISIS PRACTICE',
    icon: '⚠',
    features: [
      {
        name: 'Suicidal Ideation Scenarios',
        description:
          'Practice assessment, de-escalation, and intervention with AI patients presenting different levels of suicidal risk.',
        metric: 'High-stakes rehearsal',
        status: 'ACTIVE',
      },
      {
        name: 'Psychotic Episode Management',
        description:
          'Rehearse how to respond to delusions, hallucinations, and disorganized thinking without relying on a generic script.',
        metric: 'Stabilization practice',
        status: 'ACTIVE',
      },
      {
        name: 'Acute Trauma Response',
        description:
          'Handle fresh trauma presentations with grounding, pacing, and stabilization techniques that can be repeated safely.',
        metric: 'Rupture-aware coaching',
        status: 'ACTIVE',
      },
    ],
  },
  {
    category: 'FEEDBACK & BIAS CUES',
    icon: '⚡',
    features: [
      {
        name: 'Real-Time Cultural Analysis',
        description:
          'Surface cultural assumptions and blind spots while the conversation is still fresh enough to learn from.',
        metric: 'Immediate review',
        status: 'ACTIVE',
      },
      {
        name: 'Microaggression Identification',
        description:
          'Catch subtle phrasing and response patterns that could damage therapeutic trust.',
        metric: 'Relationship protection',
        status: 'ACTIVE',
      },
      {
        name: 'Inclusive Language Coaching',
        description:
          'Train more inclusive language choices across diverse client populations and presentations.',
        metric: 'Clearer communication',
        status: 'ACTIVE',
      },
    ],
  },
  {
    category: 'ASSESSMENT & DECISION-MAKING',
    icon: '🎯',
    features: [
      {
        name: 'Differential Diagnosis Practice',
        description:
          'Work through cases that require careful formulation, uncertainty management, and ruling out alternatives.',
        metric: 'Structured reasoning',
        status: 'ACTIVE',
      },
      {
        name: 'Comorbidity Recognition',
        description:
          'Identify multiple co-occurring conditions in realistic client presentations instead of simplified textbook cases.',
        metric: 'Complex case review',
        status: 'ACTIVE',
      },
      {
        name: 'Assessment Tool Mastery',
        description:
          'Practice how structured assessments fit into live sessions and when they meaningfully change the conversation.',
        metric: 'Workflow alignment',
        status: 'ACTIVE',
      },
    ],
  },
  {
    category: 'SECURITY & PRIVACY',
    icon: '🔒',
    features: [
      {
        name: 'Zero-Knowledge Encryption',
        description:
          'Training sessions are protected with privacy-first handling designed for sensitive mental health workflows.',
        metric: 'Privacy-first design',
        status: 'ACTIVE',
      },
      {
        name: 'Homomorphic Computing',
        description:
          'Explore advanced privacy approaches that reduce exposure while still supporting useful analysis and review.',
        metric: 'Protected analysis',
        status: 'ACTIVE',
      },
      {
        name: 'Operational Controls',
        description:
          'Support healthcare-oriented training environments with privacy, retention, and review controls that teams can evaluate directly.',
        metric: 'Operational readiness',
        status: 'ACTIVE',
      },
    ],
  },
]

const platformStats = [
  {
    value: 'Roleplay',
    label: 'Scenario practice',
    description: 'Rehearse difficult sessions safely',
  },
  {
    value: 'Review',
    label: 'Session feedback',
    description: 'See what helped or escalated',
  },
  {
    value: 'Bias',
    label: 'Cultural cues',
    description: 'Spot relational risk earlier',
  },
  {
    value: 'Team',
    label: 'Supervisor workflows',
    description: 'Compare, coach, and repeat',
  },
  {
    value: 'Privacy',
    label: 'Protected training',
    description: 'Built for sensitive practice',
  },
  {
    value: 'Deploy',
    label: 'Individual to enterprise',
    description: 'Use solo or across a program',
  },
]
---

<BaseLayout
  title="Features - AI Therapy Training Platform"
  description="Explore the simulation, feedback, supervision, and privacy features inside the Pixelated Empathy training platform."
>
  <!-- Hero Section -->
  <section class="brutalist-section">
    <div class="brutalist-container">
      <div class="text-center mb-16">
        <div class="status-indicator status-indicator--online inline-flex mb-6">
          <div class="pulse-dot pulse-dot--green"></div>
          <span class="font-bold">PLATFORM OVERVIEW</span>
        </div>

        <h1 class="brutalist-heading text-5xl md:text-7xl mb-6">
          WHAT PIXELATED EMPATHY
          <br />
          <span class="confidence-boost">ACTUALLY INCLUDES</span>
        </h1>

        <p class="text-xl text-gray-300 mb-8 max-w-4xl mx-auto">
          Pixelated Empathy gives therapy teams an AI roleplay environment for
          crisis practice, structured feedback, supervision workflows, and
          privacy-aware training operations.
        </p>

        <div class="flex flex-wrap justify-center gap-4 mb-12">
          <div class="brutalist-badge brutalist-badge--success">
            ✓ AI ROLEPLAY
          </div>
          <div class="brutalist-badge brutalist-badge--info">
            ✓ FEEDBACK LOOPS
          </div>
          <div class="brutalist-badge brutalist-badge--warning">
            ✓ TEAM TRAINING
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Stats -->
  <section class="brutalist-section bg-gray-900/50">
    <div class="brutalist-container">
      <div class="text-center mb-12">
        <h2 class="brutalist-heading text-3xl md:text-5xl mb-6">
          HOW TEAMS
          <span class="text-blue-400">USE IT</span>
        </h2>
        <p class="text-lg text-gray-300">
          The platform is designed around repeatable training workflows, not a
          one-off demo experience.
        </p>
      </div>

      <div class="brutalist-grid brutalist-grid--3">
        {
          platformStats.map((stat) => (
            <div class="metric-card hover-lift">
              <div class="metric-value">{stat.value}</div>
              <div class="metric-label">{stat.label}</div>
              <div class="text-xs text-gray-500 mt-2">{stat.description}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Core Features -->
  <section class="brutalist-section">
    <div class="brutalist-container">
      <div class="text-center mb-16">
        <h2 class="brutalist-heading text-3xl md:text-5xl mb-6">
          CORE
          <span class="confidence-boost">CAPABILITIES</span>
        </h2>
        <p class="text-lg text-gray-300 max-w-3xl mx-auto">
          The product is organized around the four things therapy teams need
          most: realistic practice, meaningful review, safer decision-making,
          and privacy-aware deployment.
        </p>
      </div>

      <div class="space-y-16">
        {
          coreFeatures.map((category) => (
            <div class="space-y-8">
              {/* Category Header */}
              <div class="text-center">
                <div class="text-5xl mb-4">{category.icon}</div>
                <h3 class="brutalist-heading text-2xl md:text-4xl mb-4">
                  {category.category}
                </h3>
              </div>

              {/* Features Grid */}
              <div class="brutalist-grid brutalist-grid--3">
                {category.features.map((feature) => (
                  <div class="brutalist-card hover-lift">
                    <div class="flex items-center justify-between mb-4">
                      <h4 class="brutalist-subheading text-lg">
                        {feature.name}
                      </h4>
                      <div
                        class={`brutalist-badge ${
                          feature.status === 'ACTIVE'
                            ? 'brutalist-badge--success'
                            : 'brutalist-badge--warning'
                        } text-xs`}
                      >
                        {feature.status}
                      </div>
                    </div>

                    <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                      {feature.description}
                    </p>

                    <div class="border-t border-gray-700 pt-4">
                      <div class="flex items-center justify-between">
                        <span class="text-xs text-gray-500 uppercase tracking-wide">
                          Impact
                        </span>
                        <span class="text-sm font-bold text-green-400">
                          {feature.metric}
                        </span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Technical Specifications -->
  <section class="brutalist-section bg-gray-900/50">
    <div class="brutalist-container">
      <div class="text-center mb-12">
        <h2 class="brutalist-heading text-3xl md:text-5xl mb-6">
          PLATFORM
          <span class="text-blue-400">FOUNDATIONS</span>
        </h2>
        <p class="text-lg text-gray-300">
          The supporting stack is built to make training credible, reviewable,
          and deployable inside real organizations.
        </p>
      </div>

      <div class="brutalist-grid brutalist-grid--2 max-w-4xl mx-auto">
        {/* AI & ML */}
        <div class="brutalist-card">
          <h3 class="brutalist-subheading text-xl mb-4 flex items-center gap-3">
            <span class="text-2xl">🤖</span>
            AI & MACHINE LEARNING
          </h3>
          <ul class="space-y-3 text-sm text-gray-400">
            <li class="flex items-center gap-2">
              <span class="text-green-400">✓</span>
              <span>Large Language Models (GPT-4, Claude)</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-400">✓</span>
              <span>Custom Psychology Training Data</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-400">✓</span>
              <span>Real-time Bias Detection Algorithms</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-400">✓</span>
              <span>Adaptive Learning Pathways</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-400">✓</span>
              <span>Continuous Model Improvement</span>
            </li>
          </ul>
        </div>

        {/* Security & Infrastructure */}
        <div class="brutalist-card">
          <h3 class="brutalist-subheading text-xl mb-4 flex items-center gap-3">
            <span class="text-2xl">🛡️</span>
            SECURITY & INFRASTRUCTURE
          </h3>
          <ul class="space-y-3 text-sm text-gray-400">
            <li class="flex items-center gap-2">
              <span class="text-blue-400">✓</span>
              <span>AES-256 End-to-End Encryption</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-blue-400">✓</span>
              <span>Fully Homomorphic Encryption (FHE)</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-blue-400">✓</span>
              <span>Zero-Knowledge Architecture</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-blue-400">✓</span>
              <span>SOC 2 Type II Compliance</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-blue-400">✓</span>
              <span>99.9% Uptime SLA</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Integration & Support -->
  <section class="brutalist-section">
    <div class="brutalist-container">
      <div class="text-center mb-12">
        <h2 class="brutalist-heading text-3xl md:text-5xl mb-6">
          HOW IT FITS
          <span class="confidence-boost">INTO TRAINING PROGRAMS</span>
        </h2>
        <p class="text-lg text-gray-300 max-w-3xl mx-auto">
          Use it alongside coursework, supervision, faculty review, or internal
          training without rebuilding your entire program around the tool.
        </p>
      </div>

      <div class="brutalist-grid brutalist-grid--2 max-w-4xl mx-auto">
        {/* Integration Options */}
        <div class="mental-health-safe">
          <h3 class="brutalist-subheading text-xl mb-6 text-center">
            INTEGRATION OPTIONS
          </h3>
          <div class="space-y-4">
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">LMS Integration</span>
              <span class="brutalist-badge brutalist-badge--success"
                >AVAILABLE</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Single Sign-On (SSO)</span>
              <span class="brutalist-badge brutalist-badge--success"
                >AVAILABLE</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Grade Passback</span>
              <span class="brutalist-badge brutalist-badge--success"
                >AVAILABLE</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Custom Branding</span>
              <span class="brutalist-badge brutalist-badge--success"
                >AVAILABLE</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">API Access</span>
              <span class="brutalist-badge brutalist-badge--info"
                >ENTERPRISE</span
              >
            </div>
          </div>
        </div>

        {/* Support & Training */}
        <div class="mental-health-safe">
          <h3 class="brutalist-subheading text-xl mb-6 text-center">
            SUPPORT & TRAINING
          </h3>
          <div class="space-y-4">
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Implementation Support</span>
              <span class="brutalist-badge brutalist-badge--success"
                >INCLUDED</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Faculty Training Program</span>
              <span class="brutalist-badge brutalist-badge--success"
                >INCLUDED</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Implementation Consulting</span>
              <span class="brutalist-badge brutalist-badge--success"
                >INCLUDED</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Custom Scenario Development</span>
              <span class="brutalist-badge brutalist-badge--info"
                >AVAILABLE</span
              >
            </div>
            <div
              class="flex items-center justify-between p-4 bg-gray-800 border border-gray-700"
            >
              <span class="font-medium">Research Collaboration</span>
              <span class="brutalist-badge brutalist-badge--warning"
                >SELECTIVE</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Section -->
  <section class="brutalist-section bg-gray-900/50">
    <div class="brutalist-container">
      <div class="text-center mb-12">
        <h2 class="brutalist-heading text-3xl md:text-5xl mb-6">
          WHY TEAMS MOVE
          <span class="confidence-boost">BEYOND AD HOC ROLEPLAY</span>
        </h2>
        <p class="text-lg text-gray-300">
          Structured simulation creates repeatability, clearer feedback, and
          less guesswork than one-off classroom exercises.
        </p>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="bg-gray-800 border-2 border-gray-700 overflow-hidden">
          {/* Table Header */}
          <div class="grid grid-cols-4 bg-gray-900 border-b-2 border-gray-700">
            <div class="p-4 font-bold text-white">FEATURE</div>
            <div class="p-4 font-bold text-center text-white">TRADITIONAL</div>
            <div class="p-4 font-bold text-center text-white">COMPETITORS</div>
            <div class="p-4 font-bold text-center text-green-400">
              PIXELATED EMPATHY
            </div>
          </div>

          {/* Table Rows */}
          <div class="grid grid-cols-4 border-b border-gray-700">
            <div class="p-4 text-gray-300">Crisis Training</div>
            <div class="p-4 text-center text-red-400">❌ Limited</div>
            <div class="p-4 text-center text-yellow-400">⚠️ Basic</div>
            <div class="p-4 text-center text-green-400">✅ Complete</div>
          </div>

          <div class="grid grid-cols-4 border-b border-gray-700">
            <div class="p-4 text-gray-300">Bias Detection</div>
            <div class="p-4 text-center text-red-400">❌ None</div>
            <div class="p-4 text-center text-red-400">❌ None</div>
            <div class="p-4 text-center text-green-400">✅ Real-time</div>
          </div>

          <div class="grid grid-cols-4 border-b border-gray-700">
            <div class="p-4 text-gray-300">Client Diversity</div>
            <div class="p-4 text-center text-yellow-400">⚠️ Limited</div>
            <div class="p-4 text-center text-yellow-400">⚠️ Moderate</div>
            <div class="p-4 text-center text-green-400">✅ 50,000+</div>
          </div>

          <div class="grid grid-cols-4 border-b border-gray-700">
            <div class="p-4 text-gray-300">Privacy Protection</div>
            <div class="p-4 text-center text-yellow-400">⚠️ Basic</div>
            <div class="p-4 text-center text-yellow-400">⚠️ HIPAA</div>
            <div class="p-4 text-center text-green-400">✅ Zero-Knowledge</div>
          </div>

          <div class="grid grid-cols-4">
            <div class="p-4 text-gray-300">Measurable Outcomes</div>
            <div class="p-4 text-center text-red-400">❌ Subjective</div>
            <div class="p-4 text-center text-yellow-400">⚠️ Limited</div>
            <div class="p-4 text-center text-green-400">✅ Comprehensive</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="brutalist-section">
    <div class="brutalist-container">
      <div class="mental-health-safe max-w-4xl mx-auto text-center">
        <div class="text-5xl mb-6 text-green-400">🚀</div>

        <h2 class="brutalist-heading text-3xl md:text-5xl mb-6">
          READY TO SEE
          <br />
          <span class="confidence-boost">THE WORKFLOW?</span>
        </h2>

        <p class="text-xl text-gray-300 mb-8">
          Explore the demos, review the platform structure, and decide whether
          Pixelated Empathy fits your supervision or training program.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <a
            href="/demo-hub"
            class="brutalist-button brutalist-button--primary text-lg px-8 py-4"
          >
            TRY ALL DEMOS →
          </a>
          <a
            href="/contact"
            class="brutalist-button brutalist-button--secondary text-lg px-8 py-4"
          >
            SCHEDULE CONSULTATION
          </a>
        </div>

        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <span class="brutalist-badge brutalist-badge--success"
            >✓ DEMO ACCESS</span
          >
          <span class="brutalist-badge brutalist-badge--info"
            >✓ CONTACT SALES</span
          >
          <span class="brutalist-badge brutalist-badge--warning"
            >✓ TEAM DEPLOYMENT OPTIONS</span
          >
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
