---
import MizuLayout from '@/layouts/MizuLayout.astro'
---

<MizuLayout
  title="Press & Media | Pixelated Empathy"
  description="Press information and company background for Pixelated Empathy."
>
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
    <div class="site-shell site-shell--narrow relative z-10">
      <div class="text-center mb-16">
        <h1
          class="text-4xl md:text-6xl font-bold tracking-tight mb-6 text-white"
        >
          Press & Media
        </h1>
        <p
          class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed"
        >
          Pixelated Empathy builds AI roleplay and simulation tools for
          therapist training. If you are covering mental health technology,
          supervision workflows, or practice-based training, contact us for
          accurate background information.
        </p>
      </div>

      <div
        class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 md:p-12 mb-12"
      >
        <h2 class="text-3xl font-bold text-white mb-6">Media contact</h2>
        <div class="space-y-4 text-slate-300">
          <div>
            <div class="text-sm text-slate-500 mb-1">Email</div>
            <a
              href="mailto:info@pixelatedempathy.com"
              class="text-primary-400 hover:text-primary-300 text-lg font-medium"
            >
              info@pixelatedempathy.com
            </a>
          </div>
          <div>
            <div class="text-sm text-slate-500 mb-1">Response window</div>
            <p>We aim to respond within two business days.</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <div
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8"
        >
          <h2 class="text-2xl font-bold text-white mb-4">
            Short company description
          </h2>
          <p class="text-slate-400 leading-relaxed">
            Pixelated Empathy is a founder-led company building AI simulation
            tools that help therapists, supervisors, and training programs
            practice difficult mental health conversations before they happen in
            the real world.
          </p>
        </div>
        <div
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8"
        >
          <h2 class="text-2xl font-bold text-white mb-4">Useful topics</h2>
          <ul class="space-y-3 text-slate-400">
            <li>Simulation-based therapist training</li>
            <li>AI roleplay and transcript review</li>
            <li>Supervisor workflows and cohort practice</li>
            <li>Privacy and deployment expectations for training tools</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</MizuLayout>
