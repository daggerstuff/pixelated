---
import { AuthButtons } from '@/components/auth/AuthButtons'

const currentPath = Astro.url.pathname

const links = [
  { text: 'Features', href: '/features', isAnchor: false },
  { text: 'Trust', href: '/trust', isAnchor: false },
  { text: 'Company', href: '/company', isAnchor: false },
  { text: 'Contact', href: '/contact', isAnchor: false },
]
---

<header
  class="marketing-nav fixed top-4 left-4 right-4 z-50"
>
  <div class="marketing-nav__shell">
    <div class="marketing-nav__row">

      <a href="/" class="marketing-nav__brand" aria-label="Pixelated Empathy home">
        <div class="marketing-nav__logo">
          <img
            src="/favicon.svg"
            alt="Pixelated Empathy"
            class="h-full w-full object-contain"
          />
        </div>

        <div class="marketing-nav__title">
          <span class="marketing-nav__name">Pixelated Empathy</span>
          <span class="marketing-nav__tag">
            Clearer coaching for hard therapy sessions
          </span>
        </div>
      </a>

      <nav class="marketing-nav__links" aria-label="Main navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                'marketing-nav__link',
                currentPath === link.href
                  ? 'marketing-nav__link--active'
                  : '',
              ]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.text}
            </a>
          ))

        }
      </nav>

      <div class="marketing-nav__actions">
        <a href="/contact" class="marketing-nav__pilot">Plan a pilot</a>
        <AuthButtons client:only="react" />
      </div>

      <button
        id="mobile-menu-button"
        class="marketing-nav__toggle"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="marketing-mobile-menu hidden"
    >
      <nav class="marketing-mobile-menu__content" aria-label="Mobile navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="marketing-mobile-menu__link"
            >
              {link.text}
            </a>
          ))
        }
        <div class="marketing-mobile-menu__actions">
          <a
            href="/contact"
            class="marketing-button marketing-button--secondary"
          >
            Plan a pilot
          </a>
          <a
            href="/demo-hub"
            class="marketing-button marketing-button--primary"
          >
            See demo
          </a>
          <a
            href="/login"
            class="marketing-mobile-menu__link marketing-mobile-menu__link--muted"
          >
            Log in
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .marketing-nav__shell {
    margin: 0 auto;
    width: min(78rem, calc(100vw - 2rem));
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    background: rgba(32, 29, 29, 0.78);
    backdrop-filter: blur(16px);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.28);
  }

  .marketing-nav__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.8rem;
    padding: 0.8rem 1rem;
  }

  .marketing-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
    text-decoration: none;
  }

  .marketing-nav__logo {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .marketing-nav__title {
    display: grid;
    min-width: 0;
  }

  .marketing-nav__name {
    color: var(--text-primary);
    font-size: 0.96rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .marketing-nav__tag {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .marketing-nav__links {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .marketing-nav__link {
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .marketing-nav__link:hover,
  .marketing-nav__link--active {
    color: var(--text-primary);
  }

  .marketing-nav__actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .marketing-nav__pilot {
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .marketing-nav__pilot:hover {
    color: var(--accent-primary);
  }

  .marketing-nav__toggle {
    display: none;
    color: var(--text-primary);
    background: transparent;
    border: 0;
    padding: 0.45rem;
    cursor: pointer;
  }

  .marketing-mobile-menu {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .marketing-mobile-menu__content {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
  }

  .marketing-mobile-menu__link {
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 0;
  }

  .marketing-mobile-menu__link--muted {
    color: var(--text-secondary);
  }

  .marketing-mobile-menu__actions {
    display: grid;
    gap: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 1024px) {
    .marketing-nav__tag,
    .marketing-nav__pilot {
      display: none;
    }
  }

  @media (max-width: 860px) {
    .marketing-nav {
      left: 0.75rem;
      right: 0.75rem;
      top: 0.75rem;
    }

    .marketing-nav__links,
    .marketing-nav__actions {
      display: none;
    }

    .marketing-nav__toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button')
  const mobileMenu = document.getElementById('mobile-menu')

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      const isExpanded =
        mobileMenuButton.getAttribute('aria-expanded') === 'true'
      mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded))
      mobileMenu.classList.toggle('hidden')
    })
  }
</script>
