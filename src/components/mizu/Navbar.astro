---
import { AuthButtons } from "@/components/auth/AuthButtons";

const links = [
  { text: "Home", href: "/", isAnchor: false },
  { text: "Features", href: "/features", isAnchor: false },
  { text: "About", href: "/about", isAnchor: false },
  { text: "Team", href: "/team", isAnchor: false },
  { text: "Contact", href: "/contact", isAnchor: false },
];
---

<header
  class="fixed top-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-white/10"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <a
        href="/"
        class="flex-shrink-0 flex items-center gap-2 hover:opacity-80 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-lg p-1"
        aria-label="Pixelated Empathy Home"
      >
        <!-- Logo Icon -->
        <div
          class="w-8 h-8 rounded-lg overflow-hidden shadow-lg shadow-primary-500/20"
        >
          <img
            src="/android-chrome-192x192.png"
            alt=""
            class="w-full h-full object-cover"
            aria-hidden="true"
          />
        </div>
        <span class="font-bold text-base tracking-tight text-white"
          >Pixelated Empathy</span
        >
      </a>

      <nav class="hidden md:flex space-x-8" aria-label="Main navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-slate-300 hover:text-white transition-colors text-sm font-medium"
            >
              {link.text}
            </a>
          ))
        }
      </nav>

      <div class="hidden md:flex items-center gap-4">
        <AuthButtons client:only="react" />
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        class="md:hidden text-slate-300 hover:text-white transition-colors p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-lg"
        aria-label="Open main menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          class="w-6 h-6 block menu-icon-open"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          class="w-6 h-6 hidden menu-icon-close"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="md:hidden hidden border-t border-white/10 bg-slate-950/95 backdrop-blur-md"
      role="dialog"
      aria-modal="true"
      aria-label="Mobile navigation menu"
    >
      <nav class="px-4 py-6 space-y-4" aria-label="Mobile navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="block text-slate-300 hover:text-white transition-colors text-sm font-medium py-2"
            >
              {link.text}
            </a>
          ))
        }
        <div class="pt-4 border-t border-white/10 space-y-3">
          <a
            href="/login"
            class="block text-slate-300 hover:text-white transition-colors text-sm font-medium py-2"
          >
            Log in
          </a>
          <a
            href="/auth/signup"
            class="block bg-white text-slate-950 px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-slate-200 transition-colors text-center"
          >
            Get Started
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuOpenIcon = mobileMenuButton?.querySelector(".menu-icon-open");
    const menuCloseIcon = mobileMenuButton?.querySelector(".menu-icon-close");

    if (!mobileMenuButton || !mobileMenu) return;

    const toggleMenu = () => {
      const isExpanded =
        mobileMenuButton.getAttribute("aria-expanded") === "true";
      const newExpanded = !isExpanded;

      mobileMenuButton.setAttribute("aria-expanded", String(newExpanded));
      mobileMenuButton.setAttribute(
        "aria-label",
        newExpanded ? "Close main menu" : "Open main menu",
      );

      mobileMenu.classList.toggle("hidden");
      menuOpenIcon?.classList.toggle("hidden");
      menuCloseIcon?.classList.toggle("hidden");

      if (newExpanded) {
        // Focus first focusable element in menu when opened
        const firstFocusable = mobileMenu.querySelector(
          'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
        ) as HTMLElement;
        firstFocusable?.focus();
        document.body.style.overflow = "hidden"; // Prevent scrolling
      } else {
        document.body.style.overflow = "";
      }
    };

    // Click handler for the menu button
    mobileMenuButton.addEventListener("click", toggleMenu);

    // Focus trap handling
    const handleKeydown = (e: KeyboardEvent) => {
      const isExpanded =
        mobileMenuButton.getAttribute("aria-expanded") === "true";

      // Escape key: close the menu
      if (e.key === "Escape" && isExpanded) {
        toggleMenu();
        mobileMenuButton.focus();
        return;
      }

      // Tab key: keep focus within the menu
      if (e.key === "Tab" && isExpanded) {
        const focusable = mobileMenu.querySelectorAll(
          'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
        ) as HTMLElement[];
        if (focusable.length === 0) return;

        const currentlyFocused = document.activeElement as HTMLElement;
        const currentIndex = Array.from(focusable).indexOf(currentlyFocused);
        const nextIndex = e.shiftKey ? currentIndex - 1 : currentIndex + 1;
        const nextIndexMod = (nextIndex + focusable.length) % focusable.length;
        focusable[nextIndexMod].focus();
        e.preventDefault();
        return;
      }
    };

    // Outside click handling
    const handleClickOutside = (e: MouseEvent) => {
      const isExpanded =
        mobileMenuButton.getAttribute("aria-expanded") === "true";
      if (
        isExpanded &&
        !mobileMenu.contains(e.target as Node) &&
        !mobileMenuButton.contains(e.target as Node)
      ) {
        toggleMenu();
      }
    };

    // Add global listeners
    document.addEventListener("keydown", handleKeydown);
    document.addEventListener("click", handleClickOutside);

    // Astro cleanup
    document.addEventListener(
      "astro:before-preparation",
      () => {
        document.removeEventListener("keydown", handleKeydown);
        document.removeEventListener("click", handleClickOutside);
        document.body.style.overflow = "";
      },
      { once: true },
    );
  }

  // Initialize on initial load and after each view transition navigation
  document.addEventListener("astro:page-load", initMobileMenu);
</script>