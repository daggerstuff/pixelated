---
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  copy?: string
  proofLabel?: string
  proofItems?: readonly string[]
  cards?: readonly {
    title: string
    description: string
    icon: string
    image?: string
  }[]
}

const {
  label,
  title,
  copy,
  proofLabel,
  proofItems = [],
  cards = [],
} = Astro.props
---

<section class="pe-home-section core-features-section">
  <SectionAtmosphere variant="section-soft" />
  <div class="pe-home-shell">
    <div class="core-features-intro">
      <span class="pe-meta-label">{label}</span>
      <h2 class="pe-heading-l">{title}</h2>
      <p class="pe-home-copy">{copy}</p>
    </div>

    <div class="core-feature-layout">
      <div class="core-feature-proof">
        <span class="pe-page-panel-label">{proofLabel}</span>
        <ul class="core-feature-proof__list">
          {proofItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="core-feature-grid">
        {
          cards.map((feature, index) => (
            <article
              class:list={[
                'core-feature-card',
                index === 0 && 'core-feature-card--lead',
              ]}
            >
              <span class="core-feature-card__caption">
                Capability {String(index + 1).padStart(2, '0')}
              </span>
              <h3 class="pe-heading-s">{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .core-features-section {
    background: rgba(253, 252, 252, 0.03);
    color: var(--text-primary);
  }

  .core-features-intro {
    display: grid;
    gap: 1rem;
    max-width: 38rem;
    margin: 0 auto;
    margin-bottom: 2.4rem;
  }

  .core-feature-layout {
    display: grid;
    gap: 1.4rem;
  }

  .core-feature-proof {
    display: grid;
    gap: 0.9rem;
  }

  .core-feature-proof__list {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .core-feature-proof__list li {
    position: relative;
    padding-left: 0;
    text-align: center;
  }

  .core-feature-proof__list li::before {
    content: '';
    position: static;
    display: block;
    width: 0.38rem;
    height: 0.38rem;
  margin: 0 0 0.65rem;
    border-radius: 999px;
    background: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(var(--accent-primary-rgb), 0.12);
  }

  .core-feature-proof__list li,
  .core-feature-card p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.76;
    color: rgba(253, 252, 252, 0.8);
  }

  .core-feature-proof__list li {
    padding: 0.9rem 0 0;
  }

  .core-feature-grid {
    display: grid;
    gap: 0.95rem;
  }

  .core-feature-card {
    display: grid;
    gap: 0.9rem;
    padding: 1rem 0 0;
  }

  .core-feature-card__caption {
    font-family: var(--font-label);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .core-feature-card--lead {
    background:
      radial-gradient(
        circle at top left,
        rgba(var(--accent-primary-rgb), 0.07),
        transparent 42%
      ),
      rgba(253, 252, 252, 0.02);
    padding: 1.2rem 1.1rem 1.25rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 8px;
  }

  @media (min-width: 980px) {
    .core-features-intro {
      max-width: none;
      margin: 0 0 2.4rem;
      grid-template-columns: minmax(18rem, 0.55fr) minmax(0, 1fr);
      align-items: end;
      text-align: left;
      justify-items: start;
      column-gap: clamp(2rem, 4vw, 4rem);
    }

    .core-features-intro .pe-meta-label {
      grid-column: 1 / -1;
    }

    .core-features-intro .pe-heading-l {
      max-width: 13ch;
    }

    .core-features-intro .pe-home-copy {
      align-self: end;
      max-width: 34rem;
      margin: 0 auto;
      text-align: left;
    }

    .core-feature-layout {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.25rem;
      text-align: left;
      justify-items: stretch;
    }

    .core-feature-proof {
      grid-template-columns: minmax(14rem, 0.36fr) minmax(0, 0.64fr);
      gap: 1.25rem;
      align-items: start;
    }

    .core-feature-proof__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem 1.25rem;
    }

    .core-feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
      gap: 1rem;
    }

.core-feature-proof,
.core-feature-card {
  text-align: left;
  justify-items: start;
}

.core-feature-proof,
.core-feature-card {
  padding: 1.15rem;
  border: 1px solid rgba(253, 252, 252, 0.1);
  border-radius: 8px;
  background: rgba(253, 252, 252, 0.04);
}

    .core-feature-card p {
      max-width: 20rem;
      margin-inline: auto;
    }



  }

  @media (max-width: 720px) {
    .core-features-intro,
    .core-feature-layout,
    .core-feature-proof,
    .core-feature-card
{
      text-align: center;
      justify-items: center;
    }

    .core-feature-proof__list {
      justify-items: center;
      text-align: center;
    }



.core-feature-proof,
.core-feature-card {
  padding: 1rem;
  border: 1px solid rgba(253, 252, 252, 0.14);
  border-radius: 8px;
  background: rgba(253, 252, 252, 0.04);
}
}
</style>
