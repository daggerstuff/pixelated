---
/**
 * CoreFeatures Component - Brutalist Style
 */
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'
import FeatureIcon from '@/components/mizu/FeatureIcon.astro'

export interface Props {
  label?: string
  title?: string
  copy?: string
  proofLabel?: string
  proofItems?: readonly string[]
  cards?: readonly { title: string; description: string; icon: string }[]
  comparison?: {
    label: string
    title: string
    body: string
    items: readonly { label: string; value: string; accent?: boolean }[]
  }
}

const {
  label,
  title,
  copy,
  proofLabel,
  proofItems = [],
  cards = [],
  comparison,
} = Astro.props

const getCardClasses = (index: number) => ({
  'core-feature-card': true,
  'core-feature-card--lead': index === 0,
})
---

<section class="pe-page-section core-features-section">
  <SectionAtmosphere variant="section" />
  <div class="pe-page-shell core-features-shell">
    <div class="core-features-intro">
      <div>
        <span class="pe-page-label">{label}</span>
        <h2 class="pe-page-heading">{title}</h2>
      </div>
      <p class="core-features-copy">
        {copy}
      </p>
    </div>

    <div class="core-features-grid">
      <aside class="core-features-proof">
        <span class="pe-page-panel-label">{proofLabel}</span>
        <ul class="core-features-proof-list">
          {proofItems.map((item) => <li>{item}</li>)}
        </ul>
      </aside>

      <div class="core-features-list">
        {
          cards.map((feature, index) => (
            <div class:list={getCardClasses(index)} data-index={index}>
              <div class="core-feature-card__row">
                <FeatureIcon icon={feature.icon} />
                <div class="core-feature-card__copy">
                  <span class="core-feature-card__eyebrow">
                    Capability {String(index + 1).padStart(2, '0')}
                  </span>
                  <h3 class="core-feature-card__title">{feature.title}</h3>
                  <p class="core-feature-card__description">
                    {feature.description}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {
      comparison && (
        <div class="core-features-comparison">
          <div class="core-features-comparison__lead">
            <span class="pe-page-panel-label">{comparison.label}</span>
            <h3>{comparison.title}</h3>
            <p>{comparison.body}</p>
          </div>

          <div class="core-features-comparison__grid">
            {comparison.items.map((item) => (
              <div
                class:list={[
                  'core-features-comparison__item',
                  item.accent && 'core-features-comparison__item--accent',
                ]}
              >
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .core-features-shell {
    position: relative;
    z-index: 1;
    max-width: 80rem;
  }

  .core-features-section {
    position: relative;
    background:
      radial-gradient(
        circle at top left,
        rgba(143, 184, 162, 0.1),
        transparent 28%
      ),
      linear-gradient(180deg, #101514 0%, #121817 100%);
    color: var(--text-primary);
  }

  .core-features-section :is(h2, h3, p, strong) {
    color: inherit;
  }

  .core-features-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 26rem);
    gap: clamp(2rem, 3vw, 3.5rem);
    align-items: end;
    margin-bottom: clamp(2.2rem, 3vw, 3.4rem);
    position: relative;
  }

  .core-features-intro::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: -2rem;
    width: min(18rem, 32vw);
    height: 1px;
    background: linear-gradient(90deg, rgba(125, 211, 168, 0.55), transparent);
  }

  .core-features-copy {
    font-size: clamp(1rem, 0.96rem + 0.12vw, 1.06rem);
    line-height: 1.78;
    color: #cbd5e1;
    max-width: 24rem;
    text-wrap: pretty;
  }

  .core-features-grid {
    display: grid;
    grid-template-columns: minmax(17rem, 0.62fr) minmax(0, 1.38fr);
    gap: clamp(1.75rem, 2.8vw, 3rem);
    margin-bottom: clamp(2.6rem, 3.8vw, 3.8rem);
  }

  .core-features-proof {
    display: grid;
    align-content: start;
    gap: var(--space-4);
    padding: clamp(1.4rem, 2vw, 1.9rem);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 1rem;
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.05),
        rgba(143, 184, 162, 0)
      ),
      rgba(10, 14, 15, 0.92);
    box-shadow: 0 20px 48px rgba(2, 8, 9, 0.22);
    position: relative;
  }

  .core-features-proof::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(
      180deg,
      rgba(143, 184, 162, 1),
      rgba(143, 184, 162, 0.18)
    );
  }

  .core-features-proof-list {
    display: grid;
    gap: 1rem;
    padding-left: 1rem;
    color: #cbd5e1;
    line-height: 1.7;
  }

  .core-feature-card__row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .core-feature-card__copy {
    min-width: 0;
  }

  .core-feature-card__title {
    margin-bottom: var(--space-2);
  }

  .core-feature-card__eyebrow {
    display: inline-flex;
    margin-bottom: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: none;
    color: rgba(255, 255, 255, 0.48);
  }

  .core-feature-card__description {
    color: #cbd5e1;
    line-height: 1.72;
    text-wrap: pretty;
  }

  .core-features-comparison {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 3vw, 3.5rem);
    align-items: start;
    padding-top: clamp(2rem, 3vw, 2.8rem);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .core-features-comparison__lead {
    display: grid;
    gap: var(--space-4);
  }

  .core-features-comparison__lead h3 {
    font-size: clamp(1.6rem, 1.28rem + 0.75vw, 2.2rem);
    line-height: 1.04;
  }

  .core-features-comparison__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.9rem;
  }

  .core-features-comparison__item {
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    gap: 0.5rem;
    min-width: 0;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.95rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .core-features-comparison__item--accent {
    background: rgba(143, 184, 162, 0.1);
  }

  @media (max-width: 640px) {
    .core-features-comparison__item {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      padding: 0.75rem 0.85rem;
    }

    .core-features-comparison__item span {
      font-size: 0.72rem;
    }
  }

  .core-features-comparison__item span {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.56);
  }

  .core-features-comparison__item strong {
    font-size: clamp(1rem, 0.96rem + 0.14vw, 1.08rem);
    line-height: 1.45;
    color: #f4f6f5;
  }

  .core-features-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .core-feature-card {
    grid-column: span 1;
    min-width: 0;
    padding: clamp(1.3rem, 1.8vw, 1.75rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    position: relative;
    overflow: hidden;
    box-shadow: 0 22px 54px rgba(2, 8, 9, 0.2);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .core-feature-card:hover {
    border-color: rgba(143, 184, 162, 0.25);
    background: rgba(255, 255, 255, 0.06);
  }

  .core-feature-card::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), transparent 78%);
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .core-feature-card:hover::after {
    opacity: 0.8;
  }

  .core-feature-card--lead::after {
    opacity: 0.6;
    height: 4px;
  }

  .core-feature-card--lead {
    grid-column: 1 / -1;
    padding: clamp(1.6rem, 2.2vw, 2rem);
    border-color: rgba(143, 184, 162, 0.16);
    background:
      linear-gradient(
        135deg,
        rgba(143, 184, 162, 0.18),
        rgba(143, 184, 162, 0.05) 36%,
        rgba(255, 255, 255, 0.04) 100%
      ),
      rgba(255, 255, 255, 0.06);
    box-shadow: var(--shadow-floating);
  }

  .core-feature-card:not(.core-feature-card--lead) {
    border-color: rgba(255, 255, 255, 0.06);
  }

  .core-feature-card:not(.core-feature-card--lead):hover {
    border-color: rgba(143, 184, 162, 0.2);
  }

  .core-feature-card:nth-child(2) {
    grid-column: span 1;
  }

  .core-feature-card:nth-child(3) {
    grid-column: span 1;
    margin-top: 0;
  }

  .core-feature-card--lead h3 {
    font-size: clamp(1.55rem, 1.25rem + 0.85vw, 2.05rem);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.85rem;
    color: var(--accent-primary);
    flex-shrink: 0;
    background: rgba(10, 17, 17, 0.38);
  }

  .core-feature-card:hover .feature-icon {
    border-color: var(--accent-primary);
  }

  .core-feature-card h3 {
    font-size: clamp(1.25rem, 1.12rem + 0.34vw, 1.55rem);
    line-height: 1.12;
  }

  @media (max-width: 1024px) {
    .core-features-intro,
    .core-features-grid,
    .core-features-comparison {
      grid-template-columns: 1fr;
    }

    .core-features-proof {
      position: static;
      top: auto;
    }
  }

  @media (max-width: 768px) {
    .core-features-list,
    .core-features-comparison__grid {
      grid-template-columns: 1fr;
    }

    .core-feature-card,
    .core-feature-card--lead,
    .core-feature-card:nth-child(2),
    .core-feature-card:nth-child(3) {
      grid-column: auto;
      margin-top: 0;
    }
  }

  @media (max-width: 640px) {
    .core-features-copy {
      font-size: var(--text-base);
    }

    .core-features-proof-list li:last-child,
    .core-features-comparison__item:last-child {
      display: none;
    }
  }
</style>
