---
/**
 * CoreFeatures Component - Brutalist Style
 */
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  copy?: string
  proofLabel?: string
  proofItems?: readonly string[]
  cards?: readonly { title: string; description: string; icon: string }[]
  comparison?: {
    label: string
    title: string
    body: string
    items: readonly { label: string; value: string; accent?: boolean }[]
  }
}

const {
  label,
  title,
  copy,
  proofLabel,
  proofItems = [],
  cards = [],
  comparison,
} = Astro.props
---

<section class="pe-page-section core-features-section">
  <SectionAtmosphere variant="section" />
  <div class="pe-page-shell core-features-shell">
    <div class="core-features-intro">
      <div>
        <span class="pe-page-label">{label}</span>
        <h2 class="pe-page-heading">{title}</h2>
      </div>
      <p class="core-features-copy">
        {copy}
      </p>
    </div>

    <div class="core-features-grid">
      <aside class="core-features-proof">
        <span class="pe-page-panel-label">{proofLabel}</span>
        <ul class="core-features-proof-list">
          {proofItems.map((item) => <li>{item}</li>)}
        </ul>
      </aside>

      <div class="core-features-list">
      {
        cards.map((feature, index) => (
          <div
            class:list={[
              'core-feature-card',
              index === 0 && 'core-feature-card--lead',
            ]}
            data-index={index}
          >
            <div class="core-feature-card__row">
              <div class="feature-icon">
                {feature.icon === 'chat' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    width="24"
                    height="24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.18.063-2.33.155-3.456.279-.266.029-.395.03-.515.137-.12.108-.178.291-.218.665l-.33 3.018a1.5 1.5 0 0 1-1.49 1.341 2.378 2.378 0 0 1-1.782-.872c-.22-.303-.388-.637-.5-1.006A2.146 2.146 0 0 1 3 11.25V6.75A2.25 2.25 0 0 1 5.25 4.5h14.25A2.25 2.25 0 0 1 21.75 6.75v.068a2.127 2.127 0 0 1-.601 1.637l-.899.856Z"
                    />
                  </svg>
                )}
                {feature.icon === 'chart' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    width="24"
                    height="24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"
                    />
                  </svg>
                )}
                {feature.icon === 'shield' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    width="24"
                    height="24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"
                    />
                  </svg>
                )}
              </div>
              <div class="core-feature-card__copy">
                <h3 class="core-feature-card__title">{feature.title}</h3>
                <p class="core-feature-card__description">{feature.description}</p>
              </div>
            </div>
          </div>
        ))
      }
      </div>
    </div>

    <div class="core-features-comparison">
      <div class="core-features-comparison__lead">
        <span class="pe-page-panel-label">{comparison?.label}</span>
        <h3>{comparison?.title}</h3>
        <p>{comparison?.body}</p>
      </div>

      <div class="core-features-comparison__grid">
        {comparison?.items.map((item) => (
          <div
            class:list={[
              'core-features-comparison__item',
              item.accent && 'core-features-comparison__item--accent',
            ]}
          >
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .core-features-shell {
    position: relative;
    z-index: 1;
    max-width: 72rem;
  }

  .core-features-section {
    position: relative;
    background:
      radial-gradient(circle at top left, rgba(136, 201, 165, 0.1), transparent 28%),
      linear-gradient(180deg, #101514 0%, #121817 100%);
    color: var(--text-primary);
  }

  .core-features-section :is(h2, h3, p, strong) {
    color: inherit;
  }

  .core-features-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 28rem);
    gap: var(--space-8);
    align-items: end;
    margin-bottom: var(--space-12);
    position: relative;
  }

  .core-features-intro::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: -2rem;
    width: min(18rem, 32vw);
    height: 1px;
    background: linear-gradient(90deg, rgba(125, 211, 168, 0.55), transparent);
  }

  .core-features-copy {
    font-size: clamp(1rem, 0.96rem + 0.2vw, 1.1rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.72);
    max-width: 24rem;
  }

  .core-features-grid {
    display: grid;
    grid-template-columns: minmax(18rem, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(1.2rem, 2.2vw, 2rem);
    margin-bottom: var(--space-12);
  }

  .core-features-proof {
    display: grid;
    align-content: start;
    gap: var(--space-5);
    padding: clamp(1.55rem, 2.15vw, 2.1rem);
    border: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(236, 233, 223, 0.95));
    box-shadow: 0 18px 40px rgba(17, 23, 22, 0.06);
    position: relative;
  }

  .core-features-proof::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: rgba(17, 23, 22, 0.78);
  }

  .core-features-proof-list {
    display: grid;
    gap: var(--space-4);
    padding-left: 1rem;
    color: var(--ink-secondary);
    line-height: 1.65;
  }

  .core-feature-card__row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .core-feature-card__copy {
    min-width: 0;
  }

  .core-feature-card__title {
    margin-bottom: var(--space-2);
  }

  .core-feature-card__description {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
  }

  .core-features-comparison {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    padding-top: var(--space-10);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .core-features-comparison__lead {
    display: grid;
    gap: var(--space-4);
  }

  .core-features-comparison__lead h3 {
    font-size: clamp(1.6rem, 1.28rem + 0.75vw, 2.2rem);
    line-height: 1.04;
  }

  .core-features-comparison__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .core-features-comparison__item {
    display: grid;
    grid-template-columns: minmax(8rem, 0.38fr) minmax(0, 1fr);
    align-items: start;
    gap: 1rem;
    min-width: 0;
    padding: 1rem 1.15rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.05);
  }

  .core-features-comparison__item:last-child {
    border-bottom: 0;
  }

  .core-features-comparison__item--accent {
    background: rgba(125, 211, 168, 0.1);
  }

  .core-features-comparison__item span {
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.46);
  }

  .core-features-comparison__item strong {
    font-size: clamp(1rem, 0.96rem + 0.14vw, 1.08rem);
    line-height: 1.45;
    color: #f4f6f5;
  }

  .core-features-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .core-feature-card {
    min-width: 0;
    padding: clamp(1.2rem, 1.7vw, 1.55rem);
    border: 0;
    background: rgba(255, 255, 255, 0.045);
    position: relative;
    overflow: hidden;
  }

  .core-feature-card::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), transparent 78%);
    opacity: 0.55;
  }

  .core-feature-card--lead {
    grid-column: 1 / -1;
    padding: clamp(1.5rem, 2vw, 2.1rem);
    background:
      linear-gradient(135deg, rgba(125, 211, 168, 0.18), rgba(125, 211, 168, 0.05) 36%, rgba(255, 255, 255, 0.04) 100%),
      rgba(255, 255, 255, 0.06);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.1);
  }

  .core-feature-card--lead h3 {
    font-size: clamp(1.55rem, 1.25rem + 0.85vw, 2.05rem);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    color: var(--accent-primary);
    flex-shrink: 0;
    background: rgba(0, 0, 0, 0.14);
  }

  .core-feature-card:hover .feature-icon {
    border-color: var(--accent-primary);
  }

  .core-feature-card h3 {
    font-size: clamp(1.35rem, 1.15rem + 0.4vw, 1.72rem);
    line-height: 1.06;
  }

  @media (max-width: 1024px) {
    .core-features-intro,
    .core-features-grid,
    .core-features-comparison {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .core-features-list,
    .core-features-comparison__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .core-features-copy {
      font-size: var(--text-base);
    }
  }
</style>
