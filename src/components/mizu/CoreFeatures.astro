---
/**
 * CoreFeatures Component - Brutalist Style
 */
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'
import FeatureIcon from '@/components/mizu/FeatureIcon.astro'

export interface Props {
  label?: string
  title?: string
  copy?: string
  proofLabel?: string
  proofItems?: readonly string[]
  cards?: readonly { title: string; description: string; icon: string }[]
  comparison?: {
    label: string
    title: string
    body: string
    items: readonly { label: string; value: string; accent?: boolean }[]
  }
}

const {
  label,
  title,
  copy,
  proofLabel,
  proofItems = [],
  cards = [],
  comparison,
} = Astro.props

const getCardClasses = (index: number) => ({
  'core-feature-card': true,
  'core-feature-card--lead': index === 0,
})
---

<section class="pe-page-section core-features-section">
  <SectionAtmosphere variant="section" />
  <div class="pe-page-shell core-features-shell">
    <div class="core-features-intro">
      <div>
        <span class="pe-page-label">{label}</span>
        <h2 class="pe-page-heading">{title}</h2>
      </div>
      <p class="core-features-copy">
        {copy}
      </p>
    </div>

    <div class="core-features-grid">
      <aside class="core-features-proof">
        <span class="pe-page-panel-label">{proofLabel}</span>
        <ul class="core-features-proof-list">
          {proofItems.map((item) => <li>{item}</li>)}
        </ul>
      </aside>

      <div class="core-features-list">
        {
          cards.map((feature, index) => (
            <div class:list={getCardClasses(index)} data-index={index}>
              <div class="core-feature-card__row">
                <div class="core-feature-card__image-wrap">
                  {feature.image && (
                    <img src={feature.image} alt={feature.title} class="core-feature-card__image" />
                  )}
                  {!feature.image && <FeatureIcon icon={feature.icon} />}
                </div>
                <div class="core-feature-card__copy">
                  <span class="core-feature-card__eyebrow">
                    Capability {String(index + 1).padStart(2, '0')}
                  </span>
                  <h3 class="core-feature-card__title">{feature.title}</h3>
                  <p class="core-feature-card__description">
                    {feature.description}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

    </div>

    {
      comparison && (
        <div class="core-features-comparison">
          <div class="core-features-comparison__lead">
            <span class="pe-page-panel-label">{comparison.label}</span>
            <h3>{comparison.title}</h3>
            <p>{comparison.body}</p>
          </div>

          <div class="core-features-comparison__grid">
            {comparison.items.map((item) => (
              <div
                class:list={[
                  'core-features-comparison__item',
                  item.accent && 'core-features-comparison__item--accent',
                ]}
              >
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .core-features-shell {
    position: relative;
    z-index: 1;
    max-width: 55rem;
  }

  .core-features-section {
    position: relative;
    background: #121817;
    color: var(--text-primary);
  }

  .core-features-intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    position: relative;
    text-align: center;
  }

  .core-features-copy {
    font-size: 1.06rem;
    line-height: 1.68;
    color: var(--text-secondary);
    max-width: 48ch;
    text-wrap: pretty;
    margin: 0 auto;
  }

  .core-features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .core-features-proof {
    display: grid;
    align-content: start;
    gap: 1.2rem;
    padding: 2rem;
    border: 1px dotted var(--border-subtle);
    border-radius: var(--radius-sm);
    background: rgba(48, 44, 44, 0.4);
    backdrop-filter: blur(8px);
    text-align: center;
  }

  .core-features-proof-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    padding: 0;
    list-style: none;
    margin: 0;
  }

  .core-features-proof-list li {
    padding: 0.75rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.03);
    font-size: 0.88rem;
    font-family: var(--font-mono);
  }

  .core-feature-card__row {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .core-feature-card__copy {
    width: 100%;
  }

  .core-feature-card__title {
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
  }

  .core-feature-card__eyebrow {
    display: block;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .core-feature-card__description {
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 42ch;
    margin: 0 auto;
    text-wrap: pretty;
  }

  .core-features-comparison {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
    padding-top: 4rem;
    border-top: 1px dotted rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .core-features-comparison__lead {
    display: grid;
    gap: 1rem;
    justify-items: center;
  }

  .core-features-comparison__lead h3 {
    font-size: 2rem;
  }

  .core-features-comparison__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    max-width: 55rem;
    margin: 0 auto;
  }

  .core-features-comparison__item {
    display: grid;
    gap: 0.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 4px;
  }

  .core-features-comparison__item strong {
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .core-feature-card__image-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 2rem;
    background: #000;
  }

  .core-feature-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: transform 0.6s ease, opacity 0.6s ease;
  }

  .core-feature-card:hover .core-feature-card__image {
    transform: scale(1.05);
    opacity: 1;
  }

  .core-features-list {

    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .core-feature-card {
    grid-column: span 1;
    padding: 2.5rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(48, 44, 44, 0.3);
    backdrop-filter: blur(12px);
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .core-feature-card--lead {
    grid-column: span 2;
    padding: 4rem 3rem;
    background: linear-gradient(135deg, rgba(255, 107, 0, 0.05), rgba(0, 0, 0, 0));
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border: 1px solid var(--accent-primary);
    border-radius: 50%;
    color: var(--accent-primary);
    background: rgba(255, 107, 0, 0.1);
  }


  .core-feature-card:hover .feature-icon {
    border-color: var(--accent-primary);
  }

  .core-feature-card h3 {
    font-size: clamp(1.1rem, 1.02rem + 0.26vw, 1.35rem);
    line-height: 1.12;
  }

  @media (max-width: 1024px) {
    .core-features-intro,
    .core-features-grid,
    .core-features-comparison {
      grid-template-columns: 1fr;
    }

    .core-features-proof {
      position: static;
      top: auto;
    }

    .core-features-proof-list,
    .core-features-comparison__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .core-features-list {
      grid-template-columns: 1fr;
    }

    .core-feature-card,
    .core-feature-card--lead,
    .core-feature-card:nth-child(2),
    .core-feature-card:nth-child(3) {
      grid-column: auto;
      margin-top: 0;
    }
  }

  @media (max-width: 640px) {
    .core-features-copy {
      font-size: var(--text-base);
    }

    .core-features-proof-list li:last-child,
    .core-features-comparison__item:last-child {
      display: none;
    }
  }
</style>
