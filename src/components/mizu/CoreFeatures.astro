---
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  copy?: string
  proofLabel?: string
  proofItems?: readonly string[]
  cards?: readonly { title: string; description: string; icon: string; image?: string }[]
  comparison?: {
    label: string
    title: string
    body: string
    items: readonly { label: string; value: string; accent?: boolean }[]
  }
}

const {
  label,
  title,
  copy,
  proofLabel,
  proofItems = [],
  cards = [],
  comparison,
} = Astro.props
---

<section class="pe-home-section core-features-section">
  <SectionAtmosphere variant="section-soft" />
  <div class="pe-home-shell">
    <div class="core-features-intro">
      <span class="pe-meta-label">{label}</span>
      <h2 class="pe-heading-l">{title}</h2>
      <p class="pe-home-copy">{copy}</p>
    </div>

    <div class="core-feature-layout">
      <div class="core-feature-proof">
        <span class="pe-page-panel-label">{proofLabel}</span>
        <ul class="core-feature-proof__list pe-home-stack">
          {proofItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="core-feature-grid">
        {
          cards.map((feature, index) => (
            <article class:list={['core-feature-card', index === 0 && 'core-feature-card--lead']}>
              <span class="core-feature-card__caption">Capability {String(index + 1).padStart(2, '0')}</span>
              <h3 class="pe-heading-s">{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))
        }
      </div>
    </div>

    {
      comparison && (
        <div class="core-feature-comparison">
          <div class="core-feature-comparison__header">
            <span class="pe-page-panel-label">{comparison.label}</span>
            <h3 class="pe-heading-s">{comparison.title}</h3>
            <p class="pe-home-copy">{comparison.body}</p>
          </div>

          <div class="core-feature-comparison__grid">
            {comparison.items.map((item) => (
              <article class:list={['core-feature-quote', item.accent && 'core-feature-quote--accent']}>
                <span class="core-feature-quote__label">{item.label}</span>
                <p>{item.value}</p>
              </article>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .core-features-section {
    background: transparent;
    color: var(--text-primary);
  }

  .core-features-intro {
    display: grid;
    gap: 1.05rem;
    max-width: 48rem;
    margin-inline: auto;
    justify-items: center;
    text-align: center;
  }

  .core-feature-layout {
    display: grid;
    gap: 1.4rem;
    margin-top: 2.4rem;
  }

  .core-feature-proof {
    display: grid;
    gap: 0.9rem;
    padding: 1.15rem 1.25rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.58), rgba(39, 35, 35, 0.38));
    backdrop-filter: blur(12px);
    justify-items: center;
    text-align: center;
  }

  .core-feature-proof__list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .core-feature-proof__list li,
  .core-feature-card p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.78;
    color: rgba(253, 252, 252, 0.8);
  }

  .core-feature-proof__list li {
    padding: 0.92rem 0;
  }

  .core-feature-grid {
    display: grid;
    gap: 1rem;
  }

  .core-feature-card {
    display: grid;
    gap: 0.9rem;
    padding: clamp(1.2rem, 2vw, 1.6rem);
    border: 1px dotted rgba(253, 252, 252, 0.12);
    border-radius: 4px;
    background: rgba(253, 252, 252, 0.02);
  }

  .core-feature-card__caption {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .core-feature-card--lead {
    background:
      radial-gradient(circle at top left, rgba(var(--accent-primary-rgb), 0.07), transparent 42%),
      linear-gradient(180deg, rgba(48, 44, 44, 0.68), rgba(39, 35, 35, 0.5));
    border-style: solid;
    border-color: rgba(253, 252, 252, 0.08);
    backdrop-filter: blur(12px);
  }

  .core-feature-comparison {
    display: grid;
    gap: 1.35rem;
    margin-top: 2.6rem;
  }

  .core-feature-comparison__header {
    display: grid;
    gap: 0.95rem;
    max-width: 48rem;
    margin-inline: auto;
    justify-items: center;
    text-align: center;
  }

  .core-feature-comparison__grid {
    display: grid;
    gap: 1rem;
  }

  .core-feature-quote {
    display: grid;
    gap: 0.7rem;
    padding: 1.35rem 1.4rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.54), rgba(39, 35, 35, 0.36));
  }

  .core-feature-quote--accent {
    border-color: rgba(var(--accent-primary-rgb), 0.32);
    background:
      radial-gradient(circle at top left, rgba(var(--accent-primary-rgb), 0.08), transparent 40%),
      linear-gradient(180deg, rgba(48, 44, 44, 0.64), rgba(39, 35, 35, 0.44));
  }

  .core-feature-quote__label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .core-feature-quote p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.76;
    color: rgba(253, 252, 252, 0.84);
  }

  @media (min-width: 980px) {
    .core-feature-layout {
      grid-template-columns: minmax(19rem, 0.84fr) minmax(0, 1.16fr);
      align-items: start;
    }

    .core-feature-proof__list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      border-top: 0;
    }

    .core-feature-proof__list li {
      padding: 1rem;
      border: 1px solid rgba(253, 252, 252, 0.08);
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.02);
    }

    .core-feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .core-feature-comparison__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
