---
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  copy?: string
  proofLabel?: string
  proofItems?: readonly string[]
  cards?: readonly {
    title: string
    description: string
    icon: string
    image?: string
  }[]
  comparison?: {
    label: string
    title: string
    body: string
    items: readonly { label: string; value: string; accent?: boolean }[]
  }
}

const {
  label,
  title,
  copy,
  proofLabel,
  proofItems = [],
  cards = [],
  comparison,
} = Astro.props
---

<section class="pe-home-section core-features-section">
  <SectionAtmosphere variant="section-soft" />
  <div class="pe-home-shell">
    <div class="core-features-intro">
      <span class="pe-meta-label">{label}</span>
      <h2 class="pe-heading-l">{title}</h2>
      <p class="pe-home-copy">{copy}</p>
    </div>

    <div class="core-feature-layout">
      <div class="core-feature-proof">
        <span class="pe-page-panel-label">{proofLabel}</span>
        <ul class="core-feature-proof__list">
          {proofItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="core-feature-grid">
        {
          cards.map((feature, index) => (
            <article
              class:list={[
                'core-feature-card',
                index === 0 && 'core-feature-card--lead',
              ]}
            >
              <span class="core-feature-card__caption">
                Capability {String(index + 1).padStart(2, '0')}
              </span>
              <h3 class="pe-heading-s">{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))
        }
      </div>
    </div>

    {
      comparison && (
        <div class="core-feature-comparison">
          <div class="core-feature-comparison__header">
            <span class="pe-page-panel-label">{comparison.label}</span>
            <h3 class="pe-heading-s">{comparison.title}</h3>
            <p class="pe-home-copy">{comparison.body}</p>
          </div>

          <div class="core-feature-comparison__grid">
            {comparison.items.map((item) => (
              <article
                class:list={[
                  'core-feature-quote',
                  item.accent && 'core-feature-quote--accent',
                ]}
              >
                <span class="core-feature-quote__label">{item.label}</span>
                <p>{item.value}</p>
              </article>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .core-features-section {
    background: transparent;
    color: var(--text-primary);
  }

  .core-features-intro {
    display: grid;
    gap: 1rem;
    max-width: 38rem;
    margin: 0 auto;
    margin-bottom: 2.4rem;
  }

  .core-feature-layout {
    display: grid;
    gap: 1.4rem;
  }

  .core-feature-proof {
    display: grid;
    gap: 0.9rem;
  }

  .core-feature-proof__list {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .core-feature-proof__list li,
  .core-feature-card p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.76;
    color: rgba(253, 252, 252, 0.8);
  }

  .core-feature-proof__list li {
    padding: 0.9rem 0 0;
    border-top: 1px dotted rgba(253, 252, 252, 0.14);
  }

  .core-feature-grid {
    display: grid;
    gap: 0.95rem;
  }

  .core-feature-card {
    display: grid;
    gap: 0.9rem;
    padding: 1rem 0 0;
    border-top: 1px dotted rgba(253, 252, 252, 0.1);
  }

  .core-feature-card__caption {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .core-feature-card--lead {
    background:
      radial-gradient(
        circle at top left,
        rgba(var(--accent-primary-rgb), 0.07),
        transparent 42%
      ),
      rgba(253, 252, 252, 0.02);
    padding: 1.2rem 1.1rem 1.25rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
  }

  .core-feature-comparison {
    display: grid;
    gap: 1.2rem;
    margin-top: 2.75rem;
  }

  .core-feature-comparison__header {
    display: grid;
    gap: 0.9rem;
    max-width: 36rem;
    margin-inline: auto;
  }

  .core-feature-comparison__grid {
    display: grid;
    gap: 0.95rem;
  }

  .core-feature-quote {
    display: grid;
    gap: 0.65rem;
    padding: 0.95rem 0 0;
    border-top: 1px dotted rgba(253, 252, 252, 0.1);
  }

  .core-feature-quote--accent {
    padding: 1rem 1rem 1.1rem;
    border: 1px solid rgba(var(--accent-primary-rgb), 0.28);
    border-radius: 4px;
    background: radial-gradient(
      circle at top left,
      rgba(var(--accent-primary-rgb), 0.08),
      transparent 40%
    );
  }

  .core-feature-quote__label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .core-feature-quote p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.98rem;
    line-height: 1.74;
    color: rgba(253, 252, 252, 0.84);
  }

  @media (min-width: 980px) {
    .core-features-intro {
      max-width: none;
      margin: 0 0 2.4rem;
      grid-template-columns: minmax(18rem, 0.55fr) minmax(0, 1fr);
      align-items: end;
      text-align: left;
      justify-items: start;
      column-gap: clamp(2rem, 4vw, 4rem);
    }

    .core-features-intro .pe-meta-label {
      grid-column: 1 / -1;
    }

    .core-features-intro .pe-heading-l {
      max-width: 13ch;
    }

    .core-features-intro .pe-home-copy {
      align-self: end;
      margin: 0;
      text-align: left;
    }

    .core-feature-layout {
      grid-template-columns: minmax(18rem, 0.48fr) minmax(0, 1.52fr);
      align-items: start;
      gap: clamp(2rem, 4vw, 4rem);
      text-align: left;
      justify-items: stretch;
    }

    .core-feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
      gap: 1rem;
    }

    .core-feature-proof,
    .core-feature-card,
    .core-feature-comparison,
    .core-feature-comparison__header,
    .core-feature-quote {
      text-align: left;
      justify-items: start;
    }

    .core-feature-proof,
    .core-feature-card,
    .core-feature-quote {
      padding: 1.15rem;
      border: 1px solid rgba(253, 252, 252, 0.1);
      border-radius: 4px;
      background: rgba(253, 252, 252, 0.016);
    }

    .core-feature-comparison {
      margin-top: 3rem;
      grid-template-columns: minmax(20rem, 0.72fr) minmax(0, 1.28fr);
      gap: clamp(2rem, 4vw, 4rem);
      align-items: start;
    }

    .core-feature-comparison__header {
      margin: 0;
      max-width: 28rem;
    }

    .core-feature-comparison__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }
  }

  @media (max-width: 720px) {
    .core-features-intro,
    .core-feature-layout,
    .core-feature-proof,
    .core-feature-card,
    .core-feature-comparison,
    .core-feature-comparison__header,
    .core-feature-quote {
      text-align: center;
      justify-items: center;
    }

    .core-feature-proof,
    .core-feature-card,
    .core-feature-quote {
      padding: 1rem;
      border: 1px solid rgba(253, 252, 252, 0.14);
      border-radius: 4px;
      background: rgba(253, 252, 252, 0.018);
    }
  }
</style>
