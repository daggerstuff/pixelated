---
const currentYear = new Date().getFullYear()
---

<footer class="marketing-footer">
  <div class="marketing-shell">
    <div class="marketing-footer__cta">
      <div>
        <span class="marketing-eyebrow">See the workflow first</span>
        <h2 class="marketing-title marketing-title--medium">
          Bring one hard case. Leave with something specific to coach.
        </h2>
        <p class="marketing-lede">
          Pixelated Empathy is for training teams that want clearer supervision,
          not another abstract AI promise. Start with the demo, then use one
          difficult case to decide whether the review actually gets sharper.
        </p>
      </div>
      <div class="marketing-footer__cta-actions">
        <a class="marketing-button marketing-button--primary" href="/demo-hub">Watch the demo</a>
        <a class="marketing-button marketing-button--secondary" href="/contact">Book a pilot</a>
        <p class="marketing-note">Founder-led • United States • Sensitive-workflow review on request</p>
      </div>
    </div>

    <div class="marketing-footer__grid">
      <div class="marketing-footer__brand">
        <div class="marketing-footer__brand-row">
          <div class="marketing-footer__logo">
            <img src="/favicon.svg" alt="Pixelated Empathy" class="h-full w-full object-contain" />
          </div>
          <div>
            <strong>Pixelated Empathy</strong>
            <p>Clinical simulation and transcript-backed coaching for therapist training teams.</p>
          </div>
        </div>

        <div class="marketing-inline-links">
          <a href="https://twitter.com/pixelatedempathy" target="_blank" rel="noopener noreferrer" class="marketing-inline-link">Twitter</a>
          <a href="https://github.com/nochadisfaction/pixelated" target="_blank" rel="noopener noreferrer" class="marketing-inline-link">GitHub</a>
          <a href="mailto:info@pixelatedempathy.com" class="marketing-inline-link">info@pixelatedempathy.com</a>
        </div>
      </div>

      <div>
        <span class="marketing-list-label">Product</span>
        <ul class="marketing-footer__list">
          <li><a href="/features">Features</a></li>
          <li><a href="/demo-hub">Demo hub</a></li>
          <li><a href="/trust">Trust center</a></li>
          <li><a href="/training">Training</a></li>
        </ul>
      </div>

      <div>
        <span class="marketing-list-label">Company</span>
        <ul class="marketing-footer__list">
          <li><a href="/about">About</a></li>
          <li><a href="/company">Company</a></li>
          <li><a href="/team">Founder</a></li>
          <li><a href="/press">Press</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div>
        <span class="marketing-list-label">Policies</span>
        <ul class="marketing-footer__list">
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/cookie-policy">Cookies</a></li>
          <li><a href="/accessibility">Accessibility</a></li>
        </ul>
      </div>
    </div>

    <div class="marketing-footer__bottom">
      <p>&copy; {currentYear} Pixelated Empathy. All rights reserved.</p>
      <p>Clearer supervision for difficult sessions.</p>
    </div>
  </div>
</footer>

<style>
  .marketing-footer {
    width: 100%;
    padding: 5.75rem 0 2.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), rgba(255, 255, 255, 0)),
      rgba(0, 0, 0, 0.14);
  }

  .marketing-footer__cta {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: 1.5rem;
    padding-bottom: 2.3rem;
    margin-bottom: 2.3rem;
    border-bottom: 1px dotted var(--divider-dotted);
  }

  .marketing-footer__cta-actions {
    display: grid;
    gap: 0.95rem;
    align-content: start;
    padding: 1.35rem;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.6), rgba(39, 35, 35, 0.4));
  }

  .marketing-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) repeat(3, minmax(0, 1fr));
    gap: 1.75rem;
  }

  .marketing-footer__brand {
    display: grid;
    gap: 1.25rem;
    max-width: 26rem;
  }

  .marketing-footer__brand-row {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .marketing-footer__logo {
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    padding: 0.3rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .marketing-footer__brand strong {
    display: block;
    margin-bottom: 0.4rem;
    color: var(--text-primary);
  }

  .marketing-footer__brand p {
    margin: 0;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .marketing-footer__list {
    display: grid;
    gap: 0.7rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .marketing-footer__list a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .marketing-footer__list a:hover {
    color: var(--text-primary);
  }

  .marketing-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  @media (max-width: 960px) {
    .marketing-footer__cta,
    .marketing-footer__grid {
      grid-template-columns: 1fr;
    }

    .marketing-footer__cta {
      text-align: center;
    }

    .marketing-footer__cta > div,
    .marketing-footer__cta-actions {
      justify-items: center;
    }
  }
</style>
