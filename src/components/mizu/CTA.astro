---
/**
 * CTA Component - Brutalist Style
 */
import DataPoint from '@/components/homepage/DataPoint.astro'
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: readonly { label: string; value: string }[]
  decisionTitle?: string
  rubric?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label,
  title,
  intro,
  verdictCopy,
  proofItems = [],
  decisionTitle,
  rubric = [],
  primaryCTA = { text: 'Start Practice', href: '/signup' },
  secondaryCTA = { text: 'Talk to Us', href: '/contact' },
  meta,
} = Astro.props
---

<section class="pe-page-section cta-section">
  <SectionAtmosphere variant="cta" />
  <div class="pe-page-shell cta-shell">
    <div class="cta-panel">
      <div class="cta-copy">
        <span class="pe-page-label cta-label">{label}</span>
        <h2 class="cta-title">
          {title}
        </h2>
        <p class="cta-intro">
          {intro}
        </p>
        <p class="cta-verdict-copy">
          {verdictCopy}
        </p>
        <div class="cta-proof-list">
          {
            proofItems.map((item) => (
              <div class="cta-proof-item">
                <DataPoint label={item.label} value={item.value} />
              </div>
            ))
          }
        </div>
      </div>

      <div class="cta-actions">
        <div class="cta-decision">
          <span class="cta-verdict__label">Verdict</span>
          <h3>{decisionTitle}</h3>
        </div>

        <div class="cta-verdict">
          <span class="cta-verdict__label">Decision rubric</span>
          <ul class="cta-verdict__list">
            {rubric.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="cta-action-cluster">
          <a
            href={primaryCTA.href}
            class="cta-button cta-button--primary"
            role="button"
          >
            {primaryCTA.text}
          </a>
          <a
            href={secondaryCTA.href}
            class="cta-button cta-button--secondary"
            role="button">{secondaryCTA.text}</a
          >
        </div>

        <p class="cta-meta">
          {meta}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    background:
      radial-gradient(
        circle at top right,
        rgba(143, 184, 162, 0.08),
        transparent 28%
      ),
      linear-gradient(180deg, #0f1414 0%, #151b1a 100%);
  }

  .cta-shell {
    position: relative;
    z-index: 1;
    max-width: 80rem;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(18rem, 0.92fr);
    gap: clamp(2rem, 3vw, 3.2rem);
    align-items: start;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.15rem;
    background:
      linear-gradient(
        135deg,
        rgba(143, 184, 162, 0.14),
        rgba(143, 184, 162, 0.03) 34%,
        rgba(255, 255, 255, 0.018) 100%
      ),
      rgba(255, 255, 255, 0.028);
    padding: clamp(1.7rem, 2.4vw, 2.3rem);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-floating);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .cta-panel::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: linear-gradient(
      180deg,
      var(--accent-primary),
      rgba(143, 184, 162, 0.15) 60%,
      transparent
    );
  }

  .cta-copy {
    max-width: 40rem;
  }

  .cta-title {
    max-width: 13ch;
    font-size: clamp(2.25rem, 1.95rem + 1vw, 3.1rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .cta-label {
    margin-bottom: var(--space-4);
  }

  .cta-proof-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1.1rem;
  }

  .cta-title,
  .cta-intro,
  .cta-verdict-copy {
    margin-bottom: var(--space-3);
  }

  .cta-intro,
  .cta-verdict-copy {
    max-width: 38rem;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.96rem + 0.12vw, 1.06rem);
    line-height: 1.75;
    color: var(--text-secondary);
    text-wrap: pretty;
  }

  .cta-proof-item {
    padding: 0.85rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.02);
  }

  .cta-actions {
    display: grid;
    gap: 1.2rem;
    padding: 1.35rem 1.35rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.045),
      rgba(255, 255, 255, 0.018) 100%
    );
    color: var(--text-primary);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      var(--shadow-panel);
  }

  .cta-decision {
    display: grid;
    gap: 0.55rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-decision h3 {
    font-size: clamp(1.08rem, 1rem + 0.25vw, 1.28rem);
    line-height: 1.22;
    color: var(--text-primary);
  }

  .cta-actions :is(h3, strong) {
    color: var(--text-primary);
  }

  .cta-verdict {
    display: grid;
    gap: 0.65rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-verdict__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: none;
    color: var(--accent-primary);
  }

  .cta-verdict__list {
    display: grid;
    gap: 0.6rem;
    margin: 0;
    padding-left: 1rem;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.66;
  }

  .cta-action-cluster {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: var(--space-3);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.9rem 1.05rem;
    border-radius: 0.85rem;
    border: 1px solid transparent;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
  }

  .cta-button--primary {
    color: #09100e;
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    min-width: 12.5rem;
    box-shadow: 0 12px 26px rgba(143, 184, 162, 0.22);
  }

  .cta-button--primary:hover {
    color: #09100e;
    background: color-mix(in srgb, var(--accent-primary) 85%, white);
    box-shadow: 0 14px 30px rgba(143, 184, 162, 0.3);
    transform: translateY(-2px);
  }

  .cta-button--primary:active {
    transform: translateY(1px) scale(0.99);
  }

  .cta-button--secondary {
    color: rgba(255, 255, 255, 0.88);
    border-color: transparent;
    background: transparent;
    padding-inline: 0;
    min-width: 0;
    justify-content: flex-start;
  }

  .cta-button--secondary:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
  }

  .cta-meta {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.58);
    line-height: 1.62;
    padding-top: 0.65rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 1024px) {
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .cta-proof-list {
      grid-template-columns: 1fr;
    }

    .cta-action-cluster {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .cta-actions {
      width: 100%;
    }

    .cta-action-cluster {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-action-cluster .cta-button--primary {
      width: 100%;
    }

    .cta-action-cluster .cta-button--secondary {
      width: auto;
      justify-content: flex-start;
    }
  }
</style>
