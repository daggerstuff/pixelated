---
/**
 * CTA Component - Brutalist Style
 */
import DataPoint from '@/components/homepage/DataPoint.astro'
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: readonly { label: string; value: string }[]
  decisionTitle?: string
  rubric?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label,
  title,
  intro,
  verdictCopy,
  proofItems = [],
  decisionTitle,
  rubric = [],
  primaryCTA = { text: 'Start Practice', href: '/signup' },
  secondaryCTA = { text: 'Talk to Us', href: '/contact' },
  meta,
} = Astro.props
---

<section class="pe-page-section cta-section">
  <SectionAtmosphere variant="cta" />
  <div class="pe-page-shell cta-shell">
    <div class="cta-panel">
      <div class="cta-copy">
        <span class="pe-page-label cta-label">{label}</span>
        <h2 class="cta-title">
          {title}
        </h2>
        <p class="cta-intro">
          {intro}
        </p>
        <p class="cta-verdict-copy">
          {verdictCopy}
        </p>
        <div class="cta-proof-list">
          {
            proofItems.map((item) => (
              <div class="cta-proof-item">
                <DataPoint label={item.label} value={item.value} />
              </div>
            ))
          }
        </div>
      </div>

      <div class="cta-actions">
        <div class="cta-decision">
          <span class="cta-verdict__label">Verdict</span>
          <h3>{decisionTitle}</h3>
        </div>

        <div class="cta-verdict">
          <span class="cta-verdict__label">Decision rubric</span>
          <ul class="cta-verdict__list">
            {rubric.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="cta-action-cluster">
          <a href={primaryCTA.href} class="cta-button cta-button--primary" role="button">
            {primaryCTA.text}
          </a>
          <a href={secondaryCTA.href} class="cta-button cta-button--secondary" role="button"
            >{secondaryCTA.text}</a
          >
        </div>

        <p class="cta-meta">
          {meta}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    background:
      radial-gradient(
        circle at top right,
        rgba(125, 211, 168, 0.08),
        transparent 28%
      ),
      linear-gradient(180deg, #0f1414 0%, #151b1a 100%);
  }

  .cta-shell {
    position: relative;
    z-index: 1;
    max-width: 72rem;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.96fr);
    gap: clamp(1.1rem, 2vw, 1.8rem);
    align-items: start;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(
        135deg,
        rgba(125, 211, 168, 0.14),
        rgba(125, 211, 168, 0.03) 34%,
        rgba(255, 255, 255, 0.018) 100%
      ),
      rgba(255, 255, 255, 0.028);
    padding: clamp(1.2rem, 2vw, 1.65rem);
    position: relative;
    overflow: hidden;
  }

  .cta-panel::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: linear-gradient(
      180deg,
      var(--accent-primary),
      rgba(136, 201, 165, 0.15) 60%,
      transparent
    );
  }

  .cta-copy {
    max-width: 42rem;
  }

  .cta-label {
    margin-bottom: var(--space-4);
  }

  .cta-proof-list {
    display: grid;
    gap: 0.75rem;
  }

  .cta-title,
  .cta-intro,
  .cta-verdict-copy {
    margin-bottom: var(--space-3);
  }

  .cta-intro,
  .cta-verdict-copy {
    max-width: 38rem;
    font-family: var(--font-sans);
    font-size: clamp(0.98rem, 0.94rem + 0.18vw, 1.06rem);
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .cta-proof-item {
    padding-top: 0.7rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-actions {
    display: grid;
    gap: 0.9rem;
    padding: 0.95rem 1rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.05),
      rgba(255, 255, 255, 0.02) 100%
    );
    color: var(--text-primary);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .cta-decision {
    display: grid;
    gap: 0.55rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-decision h3 {
    font-size: clamp(1.12rem, 1rem + 0.36vw, 1.4rem);
    line-height: 1.16;
    color: var(--text-primary);
  }

  .cta-actions :is(h3, strong) {
    color: var(--text-primary);
  }

  .cta-verdict {
    display: grid;
    gap: 0.65rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-verdict__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .cta-verdict__list {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1rem;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.55;
  }

  .cta-action-cluster {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: var(--space-3);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    padding: 0.78rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
  }

  .cta-button--primary {
    color: #09100e;
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    min-width: 12.5rem;
    box-shadow: 0 12px 26px rgba(125, 211, 168, 0.22);
  }

  .cta-button--primary:hover {
    color: #09100e;
    background: color-mix(in srgb, var(--accent-primary) 85%, white);
    box-shadow: 0 14px 30px rgba(125, 211, 168, 0.3);
  }

  .cta-button--secondary {
    color: rgba(255, 255, 255, 0.88);
    border-color: transparent;
    background: transparent;
    padding-inline: 0;
    min-width: 0;
  }

  .cta-button--secondary:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
  }

  .cta-meta {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.58);
    line-height: 1.55;
    padding-top: 0.65rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 1024px) {
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .cta-action-cluster {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .cta-actions {
      width: 100%;
    }

    .cta-action-cluster {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-action-cluster .cta-button--primary {
      width: 100%;
    }

    .cta-action-cluster .cta-button--secondary {
      width: auto;
      justify-content: flex-start;
    }
  }
</style>
