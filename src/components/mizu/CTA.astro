---
export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: readonly { label: string; value: string }[]
  decisionTitle?: string
  rubric?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label,
  title,
  intro,
  verdictCopy,
  proofItems = [],
  decisionTitle,
  rubric = [],
  primaryCTA = { text: 'Book a pilot review', href: '/contact' },
  secondaryCTA = { text: 'See the product demo', href: '/demo-hub' },
  meta,
} = Astro.props
---

<section class="pe-home-section cta-section">
  <div class="pe-home-shell">
    <div class="pe-home-grid cta-shell">
      <div class="pe-home-rail">
        <span class="pe-meta-label">{label}</span>
        <div class="pe-home-rail__line"></div>
        <p class="pe-home-kicker-note">
          The close should make the decision cleaner, not louder.
        </p>
      </div>

      <div class="cta-panel">
        <div class="cta-copy">
          <h2 class="pe-heading-l">{title}</h2>
          <p class="pe-home-copy">{intro}</p>
          <p class="cta-verdict-copy">{verdictCopy}</p>

          <div class="cta-proof-list pe-home-stack">
            {
              proofItems.map((item) => (
                <div class="cta-proof-item">
                  <span class="cta-proof-item__label">{item.label}</span>
                  <p>{item.value}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="cta-decision">
          <span class="cta-decision__label">Decision rubric</span>
          <h3 class="pe-heading-s">{decisionTitle}</h3>
          <p class="cta-decision__context">
            Keep the product only if one hard case gives your team a clearer coaching move next week.
          </p>

          <ul class="cta-rubric pe-home-stack">
            {rubric.map((item) => <li>{item}</li>)}
          </ul>

          <div class="cta-action-cluster">
            <a href={primaryCTA.href} class="cta-button cta-button--primary" role="button">{primaryCTA.text}</a>
            <a href={secondaryCTA.href} class="cta-button cta-button--secondary" role="button">{secondaryCTA.text}</a>
          </div>

          <p class="cta-meta">{meta}</p>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: transparent;
    color: var(--text-primary);
  }

  .cta-panel {
    display: grid;
    gap: 1.6rem;
  }

  .cta-copy,
  .cta-decision {
    display: grid;
    gap: 1.05rem;
  }

  .cta-copy {
    justify-items: center;
    text-align: center;
  }

  .cta-verdict-copy {
    margin: 0;
    max-width: 36rem;
    font-family: var(--font-mono);
    font-size: 0.98rem;
    line-height: 1.8;
    color: rgba(253, 252, 252, 0.88);
  }

  .cta-proof-item p,
  .cta-rubric li,
  .cta-meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    line-height: 1.76;
    color: rgba(253, 252, 252, 0.8);
  }

  .cta-proof-list,
  .cta-rubric {
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .cta-proof-item,
  .cta-rubric li {
    padding: 0.92rem 0;
  }

  .cta-proof-item__label,
  .cta-decision__label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .cta-decision {
    padding: clamp(1.3rem, 2vw, 1.6rem);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.26);
    border-radius: 4px;
    background:
      radial-gradient(circle at top right, rgba(var(--accent-primary-rgb), 0.12), transparent 34%),
      linear-gradient(180deg, rgba(48, 44, 44, 0.74), rgba(39, 35, 35, 0.54));
    backdrop-filter: blur(12px);
  }

  .cta-decision__context {
    margin: 0;
    color: rgba(253, 252, 252, 0.82);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.76;
  }

  .cta-rubric {
    margin: 0;
    padding-left: 0;
    list-style: none;
  }

  .cta-action-cluster {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.55rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0 1.05rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-button--primary {
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
  }

  .cta-button--secondary {
    background: rgba(255, 255, 255, 0.02);
    color: rgba(253, 252, 252, 0.78);
    border: 1px dotted rgba(253, 252, 252, 0.14);
  }

  .cta-button:hover {
    transform: translateY(-1px);
  }

  .cta-meta {
    color: rgba(253, 252, 252, 0.6);
  }

  @media (min-width: 980px) {
    .cta-panel {
      grid-template-columns: minmax(0, 1.06fr) minmax(0, 0.94fr);
      align-items: start;
    }

    .cta-proof-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      border-top: 0;
    }

    .cta-proof-item {
      padding: 1rem;
      border: 1px solid rgba(253, 252, 252, 0.08);
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.02);
    }
  }
</style>
