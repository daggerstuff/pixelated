---
export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: readonly { label: string; value: string }[]
  decisionTitle?: string
  rubric?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label,
  title,
  intro,
  verdictCopy,
  proofItems = [],
  decisionTitle,
  rubric = [],
  primaryCTA = { text: 'Book a pilot review', href: '/contact' },
  secondaryCTA = { text: 'See the product demo', href: '/demo-hub' },
  meta,
} = Astro.props
---

<section class="pe-home-section cta-section">
  <div class="pe-home-shell">
    <div class="pe-home-grid cta-shell">
      <div class="pe-home-rail">
        <span class="pe-meta-label">{label}</span>
        <div class="pe-home-rail__line"></div>
        <p class="pe-home-kicker-note">
          The last section should not pitch harder. It should make the decision cleaner.
        </p>
      </div>

      <div class="cta-panel">
        <div class="cta-copy">
          <h2 class="pe-heading-l">{title}</h2>
          <p class="pe-home-copy">{intro}</p>
          <p class="cta-verdict-copy">{verdictCopy}</p>

          <div class="cta-proof-list pe-home-stack">
            {
              proofItems.map((item) => (
                <div class="cta-proof-item">
                  <span class="cta-proof-item__label">{item.label}</span>
                  <p>{item.value}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="cta-decision pe-home-panel">
          <span class="cta-decision__label">Decision rubric</span>
          <h3 class="pe-heading-s">{decisionTitle}</h3>

          <ul class="cta-rubric pe-home-stack">
            {rubric.map((item) => <li>{item}</li>)}
          </ul>

          <div class="cta-action-cluster">
            <a href={primaryCTA.href} class="cta-button cta-button--primary" role="button">
              {primaryCTA.text}
            </a>
            <a href={secondaryCTA.href} class="cta-button cta-button--secondary" role="button">
              {secondaryCTA.text}
            </a>
          </div>

          <p class="cta-meta">{meta}</p>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: transparent;
    color: var(--text-primary);
  }

  .cta-panel {
    display: grid;
    gap: 1rem;
  }

  .cta-copy,
  .cta-decision {
    display: grid;
    gap: 1rem;
  }

  .cta-verdict-copy,
  .cta-proof-item p,
  .cta-rubric li,
  .cta-meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.7;
    color: rgba(253, 252, 252, 0.72);
  }

  .cta-proof-list,
  .cta-rubric {
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .cta-proof-item,
  .cta-rubric li {
    padding: 0.95rem 0;
  }

  .cta-proof-item__label,
  .cta-decision__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .cta-decision {
    padding: clamp(1.15rem, 2vw, 1.5rem);
  }

  .cta-rubric {
    margin: 0;
    padding-left: 0;
    list-style: none;
  }

  .cta-action-cluster {
    display: grid;
    gap: 0.85rem;
    margin-top: 0.3rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0 1rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-button--primary {
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
  }

  .cta-button--secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1px dotted rgba(253, 252, 252, 0.16);
  }

  .cta-button:hover {
    transform: translateY(-1px);
  }

  .cta-meta {
    color: rgba(253, 252, 252, 0.48);
  }

  @media (min-width: 980px) {
    .cta-panel {
      grid-template-columns: minmax(0, 1.06fr) minmax(0, 0.94fr);
      align-items: start;
    }
  }
</style>
