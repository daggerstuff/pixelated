---
/**
 * CTA Component - Brutalist Style
 */
import DataPoint from '@/components/homepage/DataPoint.astro'
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: readonly { label: string; value: string }[]
  decisionTitle?: string
  rubric?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label,
  title,
  intro,
  verdictCopy,
  proofItems = [],
  decisionTitle,
  rubric = [],
  primaryCTA = { text: 'Start Practice', href: '/signup' },
  secondaryCTA = { text: 'Talk to Us', href: '/contact' },
  meta,
} = Astro.props
---

<section class="pe-page-section cta-section">
  <SectionAtmosphere variant="cta" />
  <div class="pe-page-shell cta-shell">
    <div class="cta-panel">
      <div class="cta-copy">
        <span class="pe-page-label cta-label">{label}</span>
        <h2 class="cta-title">
          {title}
        </h2>
        <p class="cta-intro">
          {intro}
        </p>
        <p class="cta-verdict-copy">
          {verdictCopy}
        </p>
        <div class="cta-proof-list">
          {
            proofItems.map((item) => (
              <div class="cta-proof-item">
                <DataPoint label={item.label} value={item.value} />
              </div>
            ))
          }
        </div>
      </div>

      <div class="cta-actions">
        <div class="cta-decision">
          <span class="cta-verdict__label">Verdict</span>
          <h3>{decisionTitle}</h3>
        </div>

        <div class="cta-verdict">
          <span class="cta-verdict__label">Decision rubric</span>
          <ul class="cta-verdict__list">
            {rubric.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="cta-action-cluster">
          <a
            href={primaryCTA.href}
            class="cta-button cta-button--primary"
            role="button"
          >
            {primaryCTA.text}
          </a>
          <a
            href={secondaryCTA.href}
            class="cta-button cta-button--secondary"
            role="button">{secondaryCTA.text}</a
          >
        </div>

        <p class="cta-meta">
          {meta}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    background:
      radial-gradient(
        circle at top right,
        rgba(143, 184, 162, 0.08),
        transparent 28%
      ),
      linear-gradient(180deg, #0f1414 0%, #151b1a 100%);
  }

  .cta-shell {
    position: relative;
    z-index: 1;
    max-width: 55rem;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    border: 1px dotted rgba(253, 252, 252, 0.2);
    border-radius: 4px;
    background: rgba(48, 44, 44, 0.6);
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(12px);
    text-align: center;
  }

  .cta-panel::before {
    display: none;
  }

  .cta-copy {
    max-width: 48ch;
    margin: 0 auto;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(2.2rem, 8vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin-bottom: 2rem;
  }

  .cta-label {
    margin-bottom: 1.5rem;
  }

  .cta-proof-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin: 2rem auto 0;
  }

  .cta-intro,
  .cta-verdict-copy {
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    text-wrap: pretty;
  }

  .cta-actions {
    display: grid;
    gap: 2rem;
    width: 100%;
    max-width: 48ch;
    margin: 0 auto;
    padding: 2.5rem;
    border: 1px dotted rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.02);
  }

  .cta-decision {
    display: grid;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.1);
  }

  .cta-decision h3 {
    font-size: 1.25rem;
    line-height: 1.4;
  }

  .cta-verdict {
    display: grid;
    gap: 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.1);
    text-align: left; /* Keep rubric left for readability but centered box */
  }

  .cta-verdict__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .cta-verdict__list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding-left: 1.2rem;
    color: rgba(253, 252, 252, 0.8);
    line-height: 1.5;
  }

  .cta-action-cluster {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .cta-button {
    width: 100%;
    min-height: 3.5rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cta-button--primary {
    background: var(--accent-primary);
    color: #000;
  }

  .cta-button--secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
  }

  .cta-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 1rem;
  }


  @media (max-width: 1024px) {
    .cta-proof-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .cta-action-cluster {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .cta-actions {
      width: 100%;
    }

    .cta-proof-list {
      grid-template-columns: 1fr;
    }

    .cta-action-cluster {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-action-cluster .cta-button--primary {
      width: 100%;
    }

    .cta-action-cluster .cta-button--secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
