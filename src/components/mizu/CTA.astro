---
/**
 * CTA Component - Brutalist Style
 */
import SectionAtmosphere from '@/components/homepage/SectionAtmosphere.astro'

export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: Array<{ label: string; value: string }>
  decisionTitle?: string
  rubric?: string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label = 'Run the evaluation',
  title = 'Judge it like a supervision tool, not an AI demo.',
  intro = 'Take one difficult case, give it to a clinician or trainee, then ask whether the transcript and feedback changed the quality of your next supervisory conversation.',
  verdictCopy = 'If the platform does not give your team a clearer intervention, a sharper risk read, or a better repair on the second pass, it has not earned a place in training.',
  proofItems = [],
  decisionTitle = 'If you would not use the transcript in real supervision next week, walk away.',
  rubric = [],
  primaryCTA = { text: 'Start Practice', href: '/signup' },
  secondaryCTA = { text: 'Talk to Us', href: '/contact' },
  meta = 'No credit card required for trial. Use one real training case and decide from the review, not the pitch.',
} = Astro.props
---

<section class="pe-page-section cta-section">
  <SectionAtmosphere variant="cta" />
  <div class="pe-page-shell cta-shell">
    <div class="cta-panel">
      <div class="cta-copy">
        <span class="pe-page-label cta-label">{label}</span>
        <h2 class="cta-title">
          {title}
        </h2>
        <p class="cta-intro">
          {intro}
        </p>
        <p class="cta-verdict-copy">
          {verdictCopy}
        </p>
        <div class="cta-proof-list">
          {proofItems.map((item) => (
            <div class="cta-proof-item">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </div>

      <div class="cta-actions">
        <div class="cta-decision">
          <span class="cta-verdict__label">Verdict</span>
          <h3>{decisionTitle}</h3>
        </div>

        <div class="cta-verdict">
          <span class="cta-verdict__label">Decision rubric</span>
          <ul class="cta-verdict__list">
            {rubric.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="cta-action-cluster">
          <a href={primaryCTA.href} class="cta-button cta-button--primary">
            {primaryCTA.text}
          </a>
          <a href={secondaryCTA.href} class="cta-button cta-button--secondary">{secondaryCTA.text}</a>
        </div>

        <p class="cta-meta">
          {meta}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    background: linear-gradient(180deg, #111716 0%, #161c1b 100%);
  }

  .cta-shell {
    position: relative;
    z-index: 1;
    max-width: 72rem;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: var(--space-10);
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(135deg, rgba(125, 211, 168, 0.14), rgba(125, 211, 168, 0.03) 34%, rgba(255, 255, 255, 0.018) 100%),
      rgba(255, 255, 255, 0.028);
    padding: clamp(1.9rem, 3.2vw, 3.25rem);
    border-radius: var(--radius-md);
  }

  .cta-copy {
    max-width: 42rem;
  }

  .cta-label {
    margin-bottom: var(--space-4);
  }

  .cta-title,
  .cta-intro,
  .cta-verdict-copy {
    margin-bottom: var(--space-6);
  }

  .cta-subcopy {
    color: var(--text-tertiary);
  }

  .cta-proof-list {
    display: grid;
    gap: var(--space-4);
  }

  .cta-verdict-copy {
    max-width: 38rem;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.02rem + 0.4vw, 1.42rem);
    line-height: 1.24;
    color: var(--text-primary);
  }

  .cta-proof-item {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-proof-item span {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .cta-proof-item strong {
    font-size: var(--text-base);
    line-height: 1.45;
    color: var(--text-primary);
  }

  .cta-actions {
    display: grid;
    gap: var(--space-4);
    padding: clamp(1.45rem, 2vw, 1.95rem);
    border: 1px solid rgba(17, 23, 22, 0.08);
    background:
      linear-gradient(180deg, rgba(248, 247, 241, 0.98), rgba(236, 235, 227, 0.96) 100%);
    color: #111716;
  }

  .cta-decision {
    display: grid;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(17, 23, 22, 0.08);
  }

  .cta-decision h3 {
    font-size: clamp(1.45rem, 1.18rem + 0.7vw, 1.95rem);
    line-height: 1.05;
    color: #111716;
  }

  .cta-actions :is(h3, strong) {
    color: #111716;
  }

  .cta-verdict {
    display: grid;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(17, 23, 22, 0.08);
  }

  .cta-verdict__label {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #2f6b4d;
  }

  .cta-verdict__list {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding-left: 1rem;
    color: rgba(17, 23, 22, 0.76);
    line-height: 1.55;
  }

  .cta-action-cluster {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-button--primary {
    color: #09100e;
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .cta-button--primary:hover {
    color: var(--accent-primary);
    background: transparent;
  }

  .cta-button--secondary {
    color: #111716;
    border-color: rgba(17, 23, 22, 0.18);
    background: transparent;
  }

  .cta-button--secondary:hover {
    border-color: #111716;
  }

  .cta-meta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    letter-spacing: 0.01em;
    color: rgba(17, 23, 22, 0.6);
  }

  @media (max-width: 1024px) {
    .cta-panel {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .cta-actions {
      width: 100%;
    }

    .cta-action-cluster .cta-button {
      width: 100%;
    }
  }
</style>
