---
export interface Props {
  label?: string
  title?: string
  intro?: string
  verdictCopy?: string
  proofItems?: readonly { label: string; value: string }[]
  decisionTitle?: string
  rubric?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  meta?: string
}

const {
  label,
  title,
  intro,
  verdictCopy,
  proofItems = [],
  decisionTitle,
  rubric = [],
  primaryCTA = { text: 'Book a pilot review', href: '/contact' },
  secondaryCTA = { text: 'See the product demo', href: '/demo-hub' },
  meta,
} = Astro.props
---

<section class="pe-home-section cta-section">
  <div class="pe-home-shell">
    <div class="cta-shell">
      <div class="cta-copy">
        <span class="pe-meta-label">{label}</span>
        <h2 class="pe-heading-l">{title}</h2>
        <p class="pe-home-copy">{intro}</p>
        <p class="cta-verdict-copy">{verdictCopy}</p>

        <div class="cta-proof-list">
          {
            proofItems.map((item) => (
              <div class="cta-proof-item">
                <span class="cta-proof-item__label">{item.label}</span>
                <p>{item.value}</p>
              </div>
            ))
          }
        </div>
      </div>

      <aside class="cta-decision">
        <span class="cta-decision__label">Decision rubric</span>
        <h3 class="pe-heading-s">{decisionTitle}</h3>
        <p class="cta-decision__context">
          Keep the product only if it makes practice easier to assign, review,
          and repeat inside your existing supervision workflow.
        </p>

        <ul class="cta-rubric">
          {rubric.map((item) => <li>{item}</li>)}
        </ul>

        <div class="cta-action-cluster">
          <a
            href={primaryCTA.href}
            class="cta-button cta-button--primary"
            role="button">{primaryCTA.text}</a
          >
          <a
            href={secondaryCTA.href}
            class="cta-button cta-button--secondary"
            role="button">{secondaryCTA.text}</a
          >
        </div>

        <p class="cta-meta">{meta}</p>
      </aside>
    </div>
  </div>
</section>

<style>
.cta-section {
  background: rgba(var(--accent-primary-rgb), 0.04);
  color: var(--text-primary);
  border-top: 2px solid rgba(var(--accent-primary-rgb), 0.4);
}

  .cta-shell {
    display: grid;
    gap: clamp(1.8rem, 4vw, 3.4rem);
  }

  .cta-copy,
  .cta-decision {
    display: grid;
    gap: 1rem;
  }

  .cta-copy {
    max-width: 38rem;
    margin: 0 auto;
  }

  .cta-verdict-copy {
    margin: 0;
    max-width: 34rem;
    font-family: var(--font-sans);
    font-size: 0.98rem;
    line-height: 1.76;
    color: rgba(253, 252, 252, 0.88);
  }

  .cta-proof-list {
    display: grid;
    gap: 0.9rem;
    margin-top: 0.3rem;
  }

  .cta-proof-item {
    display: grid;
    gap: 0.45rem;
    padding: 0.95rem 0 0;
  }

  .cta-proof-item p,
  .cta-rubric li,
  .cta-meta {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    line-height: 1.74;
    color: rgba(253, 252, 252, 0.8);
  }

  .cta-proof-item__label,
  .cta-decision__label {
    font-family: var(--font-label);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .cta-decision {
    padding: clamp(1.25rem, 2vw, 1.5rem);
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 8px;
    background:
      radial-gradient(
        circle at top right,
        rgba(var(--accent-primary-rgb), 0.1),
        transparent 34%
      ),
      linear-gradient(180deg, rgba(48, 44, 44, 0.6), rgba(39, 35, 35, 0.52));
    backdrop-filter: blur(12px);
  }

  .cta-decision__context {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.74;
    color: rgba(253, 252, 252, 0.82);
  }

  .cta-rubric {
    display: grid;
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cta-rubric li {
    position: relative;
    padding: 0.9rem 0 0;
    text-align: left;
  }

  .cta-rubric li::before {
    content: '';
    position: static;
    display: block;
    width: 0.38rem;
    height: 0.38rem;
  margin: 0 0 0.65rem;
    border-radius: 999px;
    background: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(var(--accent-primary-rgb), 0.12);
  }

  .cta-action-cluster {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0 1.05rem;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .cta-button--primary {
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
  }

  .cta-button--secondary {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(253, 252, 252, 0.82);
    border: 1px solid rgba(253, 252, 252, 0.12);
  }

  .cta-button:hover {
    /* transform: translateY(-1px); removed by Gilfoyle */
  }

  .cta-meta {
    color: rgba(253, 252, 252, 0.58);
  }

  @media (min-width: 980px) {
    .cta-shell {
      grid-template-columns: minmax(0, 0.95fr) minmax(24rem, 0.72fr);
      align-items: start;
      gap: clamp(3rem, 5vw, 5rem);
      text-align: left;
      justify-items: stretch;
    }

    .cta-copy {
      max-width: 41rem;
      margin: 0;
      text-align: left;
      justify-items: start;
    }

    .cta-copy .pe-heading-l {
      max-width: 13ch;
    }

    .cta-copy .pe-home-copy {
      max-width: 34rem;
      margin: 0 auto;
      text-align: left;
    }

    .cta-proof-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      max-width: 100%;
    }

    .cta-proof-item,
    .cta-decision {
      text-align: left;
      justify-items: start;
    }

    .cta-proof-item {
      padding: 1rem;
      border: 1px solid rgba(253, 252, 252, 0.1);
      border-radius: 8px;
      background: rgba(253, 252, 252, 0.016);
    }

    .cta-proof-item p {
      max-width: 24rem;
      margin-inline: auto;
    }

    .cta-rubric {
      justify-items: start;
      text-align: left;
    }

    .cta-action-cluster {
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .cta-shell,
    .cta-copy,
    .cta-proof-item,
    .cta-decision,
    .cta-rubric {
      text-align: center;
      justify-items: center;
    }

    .cta-rubric {
      justify-items: center;
      text-align: center;
    }

    .cta-rubric li {
      max-width: 28rem;
      margin-inline: auto;
    }

    .cta-proof-item {
      padding: 1rem;
      border: 1px solid rgba(253, 252, 252, 0.14);
      border-radius: 8px;
      background: rgba(253, 252, 252, 0.018);
    }

.cta-action-cluster {
  grid-template-columns: 1fr;
}

.cta-button {
  width: 100%;
}
  }
</style>
