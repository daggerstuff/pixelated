---
/**
 * CTA Component - Brutalist Style
 */
---

<section class="section" style="background: var(--bg-void);">
  <div class="container text-center">
    <span class="label-mono block mb-4">// Ready?</span>
    <h2 class="mb-6">Ready to handle anything?</h2>
    <p class="mb-10" style="max-width: 500px; margin-left: auto; margin-right: auto;">
      Join thousands of therapists sharpening their skills with Pixelated Empathy.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/auth/signup" class="btn btn-primary btn-terminal">
        Start Practice
      </a>
      <a href="/contact" class="btn btn-outline">
        Contact Sales
      </a>
    </div>
    <p class="mt-8 text-dim" style="font-size: var(--text-xs);">
      No credit card required for trial • Cancel anytime
    </p>
  </div>
</section>
