---
import Plum from '@/components/backgrounds/Plum.astro'
import Rose from '@/components/backgrounds/Rose.astro'

interface Props {
  type: string
}

const { type } = Astro.props

let BackgroundComponent: any = null
if (type === 'dot') {
  const Dot = (await import('./Dot.astro')).default
  BackgroundComponent = Dot
}
if (type === 'particle') {
  const Particle = (await import('./Particle.astro')).default
  BackgroundComponent = Particle
}
if (type === 'plum') {
  BackgroundComponent = Plum
}
if (type === 'rose') {
  BackgroundComponent = Rose
}

// Unknown background types intentionally render no background.
---

{BackgroundComponent && <BackgroundComponent />}
