---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    steps: readonly { number: string; title: string; body: string }[]
    outputs: readonly { label: string; value: string }[]
  }
}

const { content } = Astro.props
---

<section class="home-section home-section--how">
  <div class="container">
    <div class="home-split">
      <div class="home-split__intro">
        <span class="pe-meta-label">{content.label}</span>
        <h2 class="pe-heading-l">{content.title}</h2>
      </div>

      <div class="home-steps">
        {
          content.steps.map((step) => (
            <div class="home-step glass-panel">
              <span class="home-step-number">{step.number}</span>
              <div>
                <h3 class="pe-heading-s">{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <InfoStrip
      className="home-outputs home-outputs--spaced"
      label="What comes out of one run"
      title="A session record, a review surface, and a cleaner next attempt."
      body="The workflow matters because the practice run does not disappear at the end of the conversation. It stays intact long enough for a supervisor to coach from it."
      items={content.outputs}
      theme="dark"
    />
  </div>
</section>

<style>
  .home-section--how {
    background: var(--bg-primary);
    color: var(--text-primary);
    padding: var(--section-padding-y) 0;
    position: relative;
  }

  .home-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-12);
    align-items: start;
  }

  .home-split__intro {
    text-align: center;
    max-width: 58rem;
    margin: 0 auto;
  }

  .home-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-6);
  }

  .home-step {
    padding: var(--spacing-6);
    transition: transform 0.2s ease;
  }

  .home-step:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--accent-primary-rgb), 0.2);
  }

  .home-step-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-primary);
    display: block;
    margin-bottom: var(--spacing-4);
    opacity: 0.8;
  }

  .home-step p {
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  .home-outputs {
    margin-top: clamp(4rem, 8vw, 6rem);
  }

  @media (max-width: 880px) {
    .home-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
