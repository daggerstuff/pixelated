---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    steps: readonly { number: string; title: string; body: string }[]
    outputs: readonly { label: string; value: string }[]
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--how">
  <div class="pe-page-shell home-shell">
    <div class="home-split">
      <div class="home-split__intro">
        <span class="pe-page-label">{content.label}</span>
        <h2 class="pe-page-heading">{content.title}</h2>
      </div>

      <div class="home-steps">
        {
          content.steps.map((step) => (
            <div class="home-step">
              <span class="home-step-number">{step.number}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <InfoStrip
      className="home-outputs home-outputs--spaced"
      label="What comes out of one run"
      title="A session record, a review surface, and a cleaner next attempt."
      body="The workflow matters because the practice run does not disappear at the end of the conversation. It stays intact long enough for a supervisor to coach from it."
      items={content.outputs}
      theme="dark"
    />
  </div>
</section>

<style>
  .home-section--how {
    background:
      radial-gradient(
        circle at top left,
        rgba(143, 184, 162, 0.09),
        transparent 28%
      ),
      linear-gradient(180deg, rgba(11, 16, 17, 0.98), rgba(8, 12, 13, 1));
    color: var(--text-primary);
  }

  .home-section--how :is(h2, h3, strong) {
    color: var(--text-primary);
  }

  .home-section--how p {
    color: #d2ddd8;
  }

  .home-split {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(2.8rem, 4vw, 5rem);
    align-items: start;
  }

  .home-split__intro {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 7rem;
  }

  .home-steps {
    display: grid;
    gap: 1.3rem;
    position: relative;
    padding-left: 1.35rem;
  }

  .home-steps::before {
    content: '';
    position: absolute;
    top: 0.4rem;
    bottom: 0.4rem;
    left: 0;
    width: 1px;
    background: linear-gradient(
      180deg,
      rgba(136, 201, 165, 0.62),
      rgba(136, 201, 165, 0.08)
    );
  }

  .home-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
    padding: 1.45rem 1.45rem 1.35rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.08),
        rgba(143, 184, 162, 0)
      ),
      rgba(255, 255, 255, 0.03);
    box-shadow: var(--shadow-panel);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .home-step:nth-child(even) {
    margin-left: clamp(1.4rem, 2.8vw, 2.8rem);
  }

  .home-step:hover {
    border-color: rgba(143, 184, 162, 0.22);
    transform: translateX(6px);
  }

  .home-step:first-child {
    position: relative;
    border-color: rgba(143, 184, 162, 0.22);
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.14),
        rgba(143, 184, 162, 0.02)
      ),
      rgba(255, 255, 255, 0.05);
    box-shadow: var(--shadow-floating);
  }

  .home-step:first-child::after {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(
      180deg,
      rgba(143, 184, 162, 1),
      rgba(143, 184, 162, 0.18)
    );
  }

  .home-step-number {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: none;
    position: relative;
    min-width: 3.4rem;
  }

  .home-step-number {
    color: rgba(255, 255, 255, 0.5);
  }

  .home-step h3 {
    font-size: clamp(1.08rem, 1rem + 0.28vw, 1.22rem);
    line-height: 1.22;
    margin-bottom: 0.55rem;
  }

  .home-step p {
    line-height: 1.66;
    text-wrap: pretty;
  }

  .home-step-number::before {
    content: '';
    position: absolute;
    left: -1.55rem;
    top: 0.45rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--accent-primary);
    box-shadow: 0 0 8px 2px rgba(143, 184, 162, 0.25);
  }

  .home-outputs {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.045);
    position: relative;
  }

  .home-outputs--spaced {
    margin-top: clamp(3rem, 5vw, 4.5rem);
    position: relative;
  }

  .home-outputs--spaced::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(143, 184, 162, 0.35),
      transparent 78%
    );
    z-index: 1;
  }

  .home-outputs--spaced::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      rgba(143, 184, 162, 0.2),
      transparent 60%
    );
  }

  @media (max-width: 1080px) {
    .home-split {
      grid-template-columns: 1fr;
    }

    .home-split__intro {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .home-step {
      padding: 1rem;
    }

    .home-step:nth-child(even) {
      margin-left: 0;
    }

    .home-outputs :global(.info-strip__item:last-child) {
      display: none;
    }
  }
</style>
