---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    steps: readonly { number: string; title: string; body: string }[]
    bandLabel: string
    bandTitle: string
    bandBody: string
    outputs: readonly { label: string; value: string }[]
  }
}

const { content } = Astro.props
---

<section class="home-section home-section--how">
  <div class="container">
    <div class="home-split">
      <div class="home-split__intro">
        <span class="pe-meta-label">{content.label}</span>
        <h2 class="pe-heading-l">{content.title}</h2>
      </div>

      <div class="home-steps">
        {
          content.steps.map((step) => (
            <div class="home-step glass-panel">
              <span class="home-step-number">{step.number}</span>
              <div>
                <h3 class="pe-heading-s">{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <InfoStrip
      className="home-outputs home-outputs--spaced"
      label={content.bandLabel}
      title={content.bandTitle}
      body={content.bandBody}
      items={content.outputs}
      theme="dark"
    />
  </div>
</section>

<style>
  .home-section--how {
    background: #121817;
    color: var(--text-primary);
    padding: 6rem 0;
    position: relative;
  }

  .home-split {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 4rem;
    max-width: 55rem;
    margin: 0 auto;
  }

  .home-split__intro {
    text-align: center;
    width: 100%;
  }

  .home-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    width: 100%;
  }

  .home-step {
    padding: 2rem;
    border: 1px dotted rgba(255, 255, 255, 0.1);
    background: rgba(48, 44, 44, 0.3);
    border-radius: 4px;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .home-step-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-primary);
    display: block;
    margin-bottom: 1rem;
    letter-spacing: 0.15em;
  }

  .home-step p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .home-outputs {
    margin-top: 5rem;
    width: 100%;
    max-width: 55rem;
    margin-inline: auto;
  }

</style>
