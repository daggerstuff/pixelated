---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    steps: readonly { number: string; title: string; body: string }[]
    bandLabel: string
    bandTitle: string
    bandBody: string
    outputs: readonly { label: string; value: string }[]
  }
}

const { content } = Astro.props
---

<section class="pe-home-section home-section--how">
  <div class="pe-home-shell">
    <div class="home-how__intro">
      <span class="pe-meta-label">{content.label}</span>
      <h2 class="pe-heading-l">{content.title}</h2>
      <p class="pe-home-copy">
        One case should move from live room to review lane without becoming opinion, shorthand, or memory repair.
      </p>
    </div>

    <div class="home-how__steps">
      {
        content.steps.map((step, index) => (
          <article class:list={['home-how__step', index === 0 && 'home-how__step--lead']}>
            <span class="home-how__number">{step.number}</span>
            <h3 class="pe-heading-s">{step.title}</h3>
            <p>{step.body}</p>
          </article>
        ))
      }
    </div>

    <InfoStrip
      className="home-how__outputs"
      label={content.bandLabel}
      title={content.bandTitle}
      body={content.bandBody}
      items={content.outputs}
      theme="dark"
    />
  </div>
</section>

<style>
  .home-section--how {
    background: transparent;
    color: var(--text-primary);
  }

  .home-how__intro {
    display: grid;
    gap: 1.1rem;
    max-width: 46rem;
    margin-inline: auto;
    justify-items: center;
    text-align: center;
  }

  .home-how__steps {
    display: grid;
    gap: 1rem;
    margin-top: 2.6rem;
  }

  .home-how__step {
    display: grid;
    gap: 0.9rem;
    padding: 1.3rem 1.35rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.02);
  }

  .home-how__step--lead {
    background:
      radial-gradient(circle at top left, rgba(var(--accent-primary-rgb), 0.08), transparent 40%),
      linear-gradient(180deg, rgba(48, 44, 44, 0.7), rgba(39, 35, 35, 0.52));
    backdrop-filter: blur(12px);
  }

  .home-how__number {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .home-how__step p {
    margin: 0;
    max-width: 36ch;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(253, 252, 252, 0.8);
  }

  .home-how__outputs {
    margin-top: 2.8rem;
  }

  .home-how__outputs :global(.info-strip) {
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.66), rgba(39, 35, 35, 0.5));
  }

  @media (min-width: 980px) {
    .home-how__steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.2rem;
    }
  }
</style>
