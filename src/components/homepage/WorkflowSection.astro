---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    steps: Array<{ number: string; title: string; body: string }>
    outputs: Array<{ label: string; value: string }>
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--how">
  <div class="pe-page-shell home-shell">
    <div class="home-split">
      <div>
        <span class="pe-page-label">{content.label}</span>
        <h2 class="pe-page-heading">{content.title}</h2>
      </div>

      <div class="home-steps">
        {content.steps.map((step) => (
          <div class="home-step">
            <span class="home-step-number">{step.number}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <InfoStrip
      className="home-outputs home-outputs--spaced"
      label="What comes out of one run"
      title="A session record, a review surface, and a cleaner next attempt."
      body="The workflow matters because the practice run does not disappear at the end of the conversation. It stays intact long enough for a supervisor to coach from it."
      items={content.outputs}
      theme="paper"
    />
  </div>
</section>

<style>
  .home-section--how {
    background: var(--surface-paper-gradient-soft);
    color: var(--ink-primary);
  }

  .home-section--how :is(h2, h3, strong) {
    color: var(--ink-primary);
  }

  .home-section--how p {
    color: var(--ink-secondary);
  }

  .home-split {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(1.8rem, 3vw, 3.2rem);
    align-items: start;
  }

  .home-steps {
    display: grid;
    gap: var(--space-5);
  }

  .home-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
    padding: 1.35rem 1.35rem 1.2rem;
    border: 1px solid var(--ink-border);
    background: var(--surface-paper-panel-muted);
  }

  .home-step-number {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .home-step-number {
    color: rgba(17, 23, 22, 0.52);
  }

  .home-outputs {
    border-color: var(--ink-border);
    background: var(--surface-paper-panel);
  }

  .home-outputs--spaced {
    margin-top: var(--space-12);
  }

  @media (max-width: 1080px) {
    .home-split {
      grid-template-columns: 1fr;
    }
  }
</style>
