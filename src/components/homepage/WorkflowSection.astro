---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    steps: readonly { number: string; title: string; body: string }[]
    outputs: readonly { label: string; value: string }[]
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--how">
  <div class="pe-page-shell home-shell">
    <div class="home-split">
      <div class="home-split__intro">
        <span class="pe-page-label">{content.label}</span>
        <h2 class="pe-page-heading">{content.title}</h2>
      </div>

      <div class="home-steps">
        {
          content.steps.map((step) => (
            <div class="home-step">
              <span class="home-step-number">{step.number}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <InfoStrip
      className="home-outputs home-outputs--spaced"
      label="What comes out of one run"
      title="A session record, a review surface, and a cleaner next attempt."
      body="The workflow matters because the practice run does not disappear at the end of the conversation. It stays intact long enough for a supervisor to coach from it."
      items={content.outputs}
      theme="dark"
    />
  </div>
</section>

<style>
  .home-section--how {
    background: rgba(11, 16, 17, 0.98);
    color: var(--text-primary);
  }

  .home-section--how :is(h2, h3, strong) {
    color: var(--text-primary);
  }

  .home-section--how p {
    color: #d2ddd8;
  }

  .home-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 3rem);
    align-items: start;
  }

  .home-split__intro {
    display: grid;
    gap: 1rem;
    position: static;
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }

  .home-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    position: relative;
    padding-left: 0;
  }

  .home-steps::before {
    display: none;
  }

  .home-step {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.96rem;
    background:
      linear-gradient(180deg, rgba(143, 184, 162, 0.1), rgba(143, 184, 162, 0)),
      rgba(255, 255, 255, 0.03);
    box-shadow: 0 18px 42px rgba(2, 8, 9, 0.18);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .home-step:nth-child(even) {
    margin-left: 0;
  }

  .home-step:hover {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.06);
  }

  .home-step:first-child {
    position: relative;
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
  }

  .home-step:first-child::after {
    display: none;
  }

  .home-step-number {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: none;
    position: relative;
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-width: 0;
    padding: 0.36rem 0.52rem;
    border: 1px solid rgba(143, 184, 162, 0.24);
    border-radius: 0.52rem;
    background: rgba(143, 184, 162, 0.08);
  }

  .home-step-number {
    color: rgba(255, 255, 255, 0.5);
  }

  .home-step h3 {
    font-size: clamp(1rem, 0.96rem + 0.18vw, 1.12rem);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .home-step p {
    line-height: 1.68;
    text-wrap: pretty;
  }

  .home-step-number::before {
    display: none;
  }

  .home-outputs {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.045);
    position: relative;
  }

  .home-outputs--spaced {
    margin-top: clamp(3.75rem, 5vw, 5.25rem);
    position: relative;
  }

  .home-outputs--spaced::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    z-index: 1;
  }

  .home-outputs--spaced::after {
    display: none;
  }

  @media (max-width: 1080px) {
    .home-split {
      grid-template-columns: 1fr;
    }

    .home-steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-step {
      padding: 0.95rem;
    }

    .home-step:nth-child(even) {
      margin-left: 0;
    }

    .home-steps {
      grid-template-columns: 1fr;
    }

    .home-outputs :global(.info-strip__item:last-child) {
      display: none;
    }
  }
</style>
