---
export interface Props {
  label: string
  value: string
  compact?: boolean
}

const { label, value, compact = false } = Astro.props
---

<div class:list={['data-point', compact && 'data-point--compact']}>
  <span class="data-point__label">{label}</span>
  <strong class="data-point__value">{value}</strong>
</div>

<style>
  .data-point {
    display: grid;
    gap: 0.3rem;
  }

  .data-point__label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    font-variant-caps: normal;
    text-transform: none;
    color: rgba(255, 255, 255, 0.46);
  }

  .data-point__value {
    font-size: 0.95rem;
    line-height: 1.42;
    color: rgba(255, 255, 255, 0.92);
  }

  .data-point--compact .data-point__value {
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    text-transform: none;
  }
</style>
