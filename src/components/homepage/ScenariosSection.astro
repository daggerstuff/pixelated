---
import InfoStrip from '@/components/homepage/InfoStrip.astro'

export interface Props {
  content: {
    label: string
    title: string
    cards: Array<{ kicker: string; title: string; body: string }>
    strip: {
      label: string
      title: string
      body: string
      items: Array<{ label: string; value: string }>
    }
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--scenarios">
  <div class="pe-page-shell home-shell">
    <span class="pe-page-label">{content.label}</span>
    <h2 class="pe-page-heading">{content.title}</h2>

    <div class="home-card-grid home-card-grid--spaced">
      {content.cards.map((card, index) => (
        <article class:list={['home-card', index === 0 && 'home-card--featured', index === 2 && 'home-card--muted']}>
          <span class="home-card-kicker">{card.kicker}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>

    <InfoStrip
      className="home-use-strip home-use-strip--spaced"
      label={content.strip.label}
      title={content.strip.title}
      body={content.strip.body}
      items={content.strip.items}
      theme="dark"
    />
  </div>
</section>

<style>
  .home-section--scenarios {
    background: linear-gradient(180deg, rgba(8, 12, 13, 0.98), rgba(8, 12, 13, 1));
  }

  .home-card-kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: var(--space-4);
  }

  .home-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .home-card-grid--spaced {
    margin-top: var(--space-12);
  }

  .home-card {
    min-width: 0;
    display: grid;
    gap: var(--space-4);
    padding: clamp(1.65rem, 2.2vw, 2.35rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02));
  }

  .home-card--featured {
    background:
      linear-gradient(180deg, rgba(125, 211, 168, 0.13), rgba(125, 211, 168, 0.03) 38%, rgba(255, 255, 255, 0.018));
  }

  .home-card--featured h3 {
    font-size: clamp(1.4rem, 1.2rem + 0.45vw, 1.85rem);
    max-width: 14ch;
  }

  .home-card--muted {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.028), rgba(255, 255, 255, 0.012));
  }

  .home-use-strip--spaced {
    margin-top: var(--space-10);
  }

  @media (max-width: 1080px) {
    .home-card-grid {
      grid-template-columns: 1fr;
    }

    .home-card--featured {
      grid-row: auto;
    }
  }
</style>
