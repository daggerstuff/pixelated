---
export interface Props {
  kicker?: string
  title?: string
  subtitle?: string
  helperText?: string
  proofPoints?: readonly { label: string; text: string }[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
}

const {
  kicker,
  title,
  subtitle,
  helperText,
  proofPoints = [],
  primaryCTA,
  secondaryCTA,
} = Astro.props
---

<div class="hero-copy-wrap">
  <div class="hero-copy">
    {kicker && (
      <div class="hero-prelude">
        <div class="hero-kicker-pill">
          <span class="hero-kicker-dot"></span>
          <span class="hero-kicker">{kicker}</span>
        </div>
      </div>
    )}

    <div class="hero-copy__header">
      <h1 class="hero-title" style="color: var(--text-primary, #f7f3eb); -webkit-text-fill-color: var(--text-primary, #f7f3eb);">{title}</h1>
      <p class="hero-subtitle" style="color: var(--text-secondary, rgba(247, 243, 235, 0.82)); -webkit-text-fill-color: var(--text-secondary, rgba(247, 243, 235, 0.82));">{subtitle}</p>
    </div>

    <div class="hero-actions">
      <div class="hero-actions__buttons">
        {primaryCTA && (
          <a href={primaryCTA.href} class="btn-premium" role="button">
            <span class="btn-premium__text">{primaryCTA.text}</span>
          </a>
        )}

        {secondaryCTA && (
          <a href={secondaryCTA.href} class="hero-secondary-link">
            <span class="hero-secondary-link__text">{secondaryCTA.text}</span>
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              class="hero-secondary-link__icon"
              aria-hidden="true"
            >
              <path
                d="M5 12H19M19 12L13 6M19 12L13 18"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="square"></path>
            </svg>
          </a>
        )}
      </div>
      <p class="hero-actions__context" style="-webkit-text-fill-color: rgba(253, 252, 252, 0.66);">Start with the product first. Bring a real case only if the review gets more specific.</p>
    </div>

    {helperText && <p class="hero-helper" style="-webkit-text-fill-color: rgba(253, 252, 252, 0.56);">{helperText}</p>}

    {proofPoints.length > 0 && (
      <div class="hero-proof-grid" aria-label="Why the workflow lands">
        {proofPoints.map((point) => (
          <article class="hero-proof-card">
            <span class="hero-proof-card__label" style="-webkit-text-fill-color: var(--accent-primary, #ff6b00);">{point.label}</span>
            <p style="-webkit-text-fill-color: rgba(253, 252, 252, 0.82);">{point.text}</p>
          </article>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .hero-copy-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-copy {
    max-width: 36rem;
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    justify-items: start;
    gap: 1.45rem;
    padding: 1.1rem;
    border: 1px solid rgba(253, 252, 252, 0.06);
    border-radius: 4px;
    background: linear-gradient(180deg, rgba(10, 14, 16, 0.42), rgba(10, 14, 16, 0.18));
    backdrop-filter: blur(8px);
    justify-items: center;
    text-align: center;
  }

  .hero-copy__header {
    display: grid;
    gap: 1rem;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.46rem 0.82rem;
    border-radius: 4px;
    border: 1px dotted rgba(253, 252, 252, 0.14);
    background: rgba(48, 44, 44, 0.28);
    backdrop-filter: blur(10px);
  }

  .hero-kicker-dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary, #ff6b00);
  }

  .hero-title {
    max-width: 11ch;
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(1.9rem, 3vw, 3rem);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: var(--text-primary, #f7f3eb) !important;
    background: none;
    -webkit-text-fill-color: var(--text-primary, #f7f3eb) !important;
    mix-blend-mode: normal;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.16);
    text-wrap: balance;
  }

  .hero-subtitle {
    max-width: 30rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.96rem;
    line-height: 1.68;
    color: var(--text-secondary, rgba(247, 243, 235, 0.82)) !important;
    -webkit-text-fill-color: var(--text-secondary, rgba(247, 243, 235, 0.82)) !important;
    text-wrap: pretty;
  }


  .hero-actions {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.15rem;
    justify-items: center;
  }

  .hero-actions__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }

  .hero-actions__context {
    margin: 0;
    max-width: 28rem;
    color: rgba(253, 252, 252, 0.66) !important;
    -webkit-text-fill-color: rgba(253, 252, 252, 0.66) !important;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.66;
  }

  .hero-helper {
    margin: 0;
    max-width: 28rem;
    color: rgba(253, 252, 252, 0.56) !important;
    -webkit-text-fill-color: rgba(253, 252, 252, 0.56) !important;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.62;
  }

  .btn-premium {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.3rem;
    padding: 0.95rem 1.55rem;
    background: var(--accent-primary, #ff6b00);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
    border-radius: 4px;
    color: var(--bg-primary);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .btn-premium:hover {
    transform: translateY(-1px);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 3.3rem;
    padding: 0.95rem 1.35rem;
    color: rgba(247, 243, 235, 0.9) !important;
    -webkit-text-fill-color: rgba(247, 243, 235, 0.9) !important;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(253, 252, 252, 0.16);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.035);
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover {
    color: var(--accent-primary, #ff6b00);
    border-color: rgba(var(--accent-primary-rgb), 0.44);
    background: rgba(var(--accent-primary-rgb), 0.08);
    transform: translateY(-1px);
  }

  .hero-secondary-link__icon {
    flex-shrink: 0;
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    width: 100%;
  }

  .hero-proof-card {
    display: grid;
    gap: 0.55rem;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(253, 252, 252, 0.1);
    border-radius: 4px;
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.7), rgba(39, 35, 35, 0.42));
  }

  .hero-proof-card__label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-proof-card p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.66;
    color: rgba(253, 252, 252, 0.82) !important;
    -webkit-text-fill-color: rgba(253, 252, 252, 0.82) !important;
  }

  @media (max-width: 720px) {
    .hero-copy {
      gap: 1rem;
    }

    .hero-title {
      max-width: 10ch;
      font-size: clamp(1.6rem, 7.5vw, 2.3rem);
    }

    .hero-subtitle {
      max-width: 20rem;
      font-size: 0.9rem;
    }

    .hero-actions__buttons {
      width: 100%;
      display: grid;
    }

    .btn-premium,
    .hero-secondary-link {
      width: 100%;
    }

    .hero-proof-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
