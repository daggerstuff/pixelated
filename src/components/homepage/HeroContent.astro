---
export interface Props {
  kicker?: string
  title?: string
  subtitle?: string
  helperText?: string
  proofPoints?: readonly { label: string; text: string }[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
}

const {
  kicker,
  title,
  subtitle,
  helperText,
  proofPoints = [],
  primaryCTA,
  secondaryCTA,
} = Astro.props
---

<div class="hero-copy-wrap">
  <div class="hero-copy">
    {kicker && (
      <div class="hero-prelude">
        <div class="hero-kicker-pill">
          <span class="hero-kicker-dot"></span>
          <span class="hero-kicker">{kicker}</span>
        </div>
      </div>
    )}

    <h1 class="hero-title">{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>

    <ul class="hero-proof-grid pe-home-stack" aria-label="Core proof" role="list">
      {
        proofPoints.map((item) => (
          <li class="hero-proof-card" tabindex="0">
            <span class="hero-proof-card__index">{item.label}</span>
            <p class="hero-proof-card__copy">{item.text}</p>
          </li>
        ))
      }
    </ul>

    <div class="hero-actions">
      {primaryCTA && (
        <a href={primaryCTA.href} class="btn-premium" role="button">
          <span class="btn-premium__text">{primaryCTA.text}</span>
          <div class="btn-premium__fill"></div>
        </a>
      )}

      {secondaryCTA && (
        <a href={secondaryCTA.href} class="hero-secondary-link">
          <span class="hero-secondary-link__text">{secondaryCTA.text}</span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            class="hero-secondary-link__icon"
            aria-hidden="true"
          >
            <path
              d="M5 12H19M19 12L13 6M19 12L13 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="square"></path>
          </svg>
        </a>
      )}
    </div>

    {helperText && <p class="hero-helper">{helperText}</p>}
  </div>
</div>

<style>
  .hero-copy-wrap {
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }

  .hero-copy {
    max-width: 35rem;
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    justify-items: start;
    gap: 1.15rem;
    padding: clamp(0.1rem, 1vw, 0.5rem) 0 0;
    text-align: left;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.44rem 0.8rem;
    border-radius: 4px;
    border: 1px dotted rgba(253, 252, 252, 0.16);
    background: rgba(48, 44, 44, 0.3);
    backdrop-filter: blur(12px);
  }

  .hero-kicker-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-title {
    max-width: 10ch;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 2.625rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-subtitle {
    max-width: 33rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.72;
    color: rgba(253, 252, 252, 0.8);
    text-wrap: pretty;
  }

  .hero-proof-grid {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    width: 100%;
    max-width: 34rem;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .hero-proof-card {
    display: grid;
    grid-template-columns: minmax(0, 8.5rem) minmax(0, 1fr);
    gap: 0.85rem;
    min-width: 0;
    padding: 0.95rem 0;
    border-bottom: 1px dotted rgba(253, 252, 252, 0.12);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .hero-proof-card:hover {
    background: rgba(var(--accent-primary-rgb), 0.03);
  }

  .hero-proof-card:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  .hero-proof-card__index {
    padding-top: 0.12rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-proof-card__copy {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    line-height: 1.7;
    color: rgba(253, 252, 252, 0.72);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.2rem;
    align-items: center;
    justify-content: flex-start;
    margin-top: 0.35rem;
  }

  .hero-helper {
    margin: 0;
    color: rgba(253, 252, 252, 0.46);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .btn-premium {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.9rem 1.4rem;
    background: var(--accent-primary);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
    border-radius: 4px;
    color: var(--bg-primary);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    overflow: hidden;
    transition:
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .btn-premium:hover {
    transform: translateY(-1px);
  }

  .btn-premium__text,
  .btn-premium__fill {
    position: relative;
    z-index: 1;
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 3rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover {
    color: var(--accent-primary);
  }

  .hero-secondary-link__icon {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover .hero-secondary-link__icon {
    transform: translateX(2px);
  }

  @media (max-width: 720px) {
    .hero-title {
      max-width: 11ch;
      font-size: clamp(2.25rem, 8vw, 3.3rem);
    }

    .hero-subtitle {
      font-size: 0.96rem;
    }
  }

  @media (max-width: 480px) {
    .hero-proof-card {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .hero-title {
      font-size: clamp(2.15rem, 11vw, 2.8rem);
    }

    .hero-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .btn-premium,
    .hero-secondary-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>
