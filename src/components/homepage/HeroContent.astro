---
export interface Props {
  kicker?: string
  title?: string
  subtitle?: string
  helperText?: string
  proofPoints?: readonly { label: string; text: string }[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
}

const {
  kicker,
  title,
  subtitle,
  helperText,
  proofPoints = [],
  primaryCTA,
  secondaryCTA,
} = Astro.props
---

<div class="hero-copy-wrap">
  <div class="hero-copy">
    {
      kicker && (
        <div class="hero-prelude">
          <div class="hero-kicker-pill">
            <span class="hero-kicker-dot" />
            <span class="hero-kicker">{kicker}</span>
          </div>
        </div>
      )
    }

    <div class="hero-copy__header">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
    </div>

    <div class="hero-actions">
      <div class="hero-actions__buttons">
        {
          primaryCTA && (
            <a href={primaryCTA.href} class="btn-premium" role="button">
              {primaryCTA.text}
            </a>
          )
        }

        {
          secondaryCTA && (
            <a href={secondaryCTA.href} class="hero-secondary-link">
              <span>{secondaryCTA.text}</span>
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                class="hero-secondary-link__icon"
                aria-hidden="true"
              >
                <path
                  d="M5 12H19M19 12L13 6M19 12L13 18"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"
                />
              </svg>
            </a>
          )
        }
      </div>

      {
        (helperText || true) && (
          <p class="hero-actions__context">
            {helperText ||
              'Bring a real case only if the review gets more specific.'}
          </p>
        )
      }
    </div>

    {
      proofPoints.length > 0 && (
        <div class="hero-proof-grid" aria-label="Why the workflow lands">
          {proofPoints.map((point) => (
            <article class="hero-proof-card">
              <span class="hero-proof-card__label">{point.label}</span>
              <p>{point.text}</p>
            </article>
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .hero-copy-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-copy {
    width: min(100%, 34rem);
    display: grid;
    gap: 1.35rem;
    align-content: start;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: 0.46rem 0.82rem;
    border: 1px dotted rgba(253, 252, 252, 0.22);
    border-radius: 8px;
    background: rgba(253, 252, 252, 0.05);
    backdrop-filter: blur(10px);
  }

  .hero-kicker-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--accent-primary);
    box-shadow: 0 0 0 4px rgba(var(--accent-primary-rgb), 0.12);
  }

  .hero-kicker {
    font-family: var(--font-label);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .hero-copy__header {
    display: grid;
    gap: 1.2rem;
  }

  .hero-title {
    margin: 0;
    max-width: 11ch;
    margin: 0 auto;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 3.2vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-subtitle {
    margin: 0;
    max-width: 100%;
    margin: 0 auto;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(247, 243, 235, 0.82);
    text-wrap: pretty;
  }

  .hero-actions {
    display: grid;
    gap: 0.9rem;
  }

  .hero-actions__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    justify-content: center;
  }

  .hero-actions__context {
    margin: 0;
    max-width: 100%;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    line-height: 1.68;
    color: rgba(253, 252, 252, 0.64);
    letter-spacing: 0.01em;
  }

  .btn-premium,
  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.92rem 1.35rem;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .btn-premium {
    background: var(--accent-primary);
    color: var(--bg-primary);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.5);
  }

  .hero-secondary-link {
    gap: 0.85rem;
    border: 1px solid rgba(253, 252, 252, 0.16);
    background: rgba(253, 252, 252, 0.06);
    color: rgba(253, 252, 252, 0.9);
  }

  .btn-premium:hover,
  .hero-secondary-link:hover {
    transform: translateY(-1px);
  }

  .hero-secondary-link:hover {
    color: var(--accent-primary);
    border-color: rgba(var(--accent-primary-rgb), 0.42);
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 0.15rem;
  }

  .hero-proof-card {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
    padding: 0.95rem 0 0;
  }

  .hero-proof-card__label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-proof-card p {
    margin: 0 auto;
    max-width: 30ch;
    font-family: var(--font-display);
    font-size: 0.9rem;
    line-height: 1.66;
    color: rgba(253, 252, 252, 0.82);
  }

  @media (max-width: 920px) {
    .hero-copy {
      width: 100%;
    }

    .hero-title {
      max-width: 10ch;
      font-size: clamp(2.05rem, 9vw, 3.2rem);
    }
  }

  @media (min-width: 921px) {
    .hero-copy-wrap {
      justify-content: center;
    }

    .hero-copy {
      width: 100%;
      max-width: 39rem;
      gap: 1.45rem;
      text-align: center;
      justify-items: center;
    }

    .hero-prelude,
    .hero-actions__buttons {
      justify-content: flex-start;
    }

    .hero-title {
      max-width: 17ch;
      margin: 0;
      font-size: clamp(2.85rem, 3.65vw, 4rem);
      line-height: 1.2;
      letter-spacing: -0.06em;
    }

    .hero-subtitle,
    .hero-actions__context {
      margin: 0;
      max-width: 38rem;
      text-align: center;
    }

    .hero-subtitle {
      font-size: clamp(1.02rem, 1.1vw, 1.18rem);
      line-height: 1.65;
    }

    .hero-proof-grid {
      width: 100%;
      gap: 1rem;
    }

    .hero-proof-card {
      padding: 1rem 1rem 1.05rem;
      border: 1px solid rgba(253, 252, 252, 0.1);
      border-radius: 8px;
      background: rgba(253, 252, 252, 0.05);
      text-align: center;
      justify-items: center;
    }
  }

  @media (max-width: 720px) {
    .hero-copy-wrap {
      justify-content: center;
    }

    .hero-copy {
      gap: 1.15rem;
      text-align: center;
      justify-items: center;
    }

    .hero-prelude,
    .hero-actions__buttons {
      justify-content: center;
    }

    .hero-title {
      font-size: clamp(2.1rem, 11vw, 3rem);
      line-height: 0.98;
    }

    .hero-subtitle {
      font-size: 0.94rem;
      line-height: 1.68;
    }

    .hero-actions__buttons {
      width: 100%;
      display: grid;
      gap: 0.85rem;
    }

    .btn-premium,
    .hero-secondary-link {
      width: 100%;
    }

    .hero-proof-grid {
      grid-template-columns: 1fr;
      width: 100%;
    }
  }
</style>
