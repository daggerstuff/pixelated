---
export interface Props {
  kicker?: string
  title?: string
  subtitle?: string
  helperText?: string
  proofPoints?: readonly { label: string; text: string }[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
}

const {
  kicker,
  title,
  subtitle,
  helperText,
  proofPoints = [],
  primaryCTA,
  secondaryCTA,
} = Astro.props
---

<div class="hero-copy-wrap">
  <div class="hero-copy">
    {kicker && (
      <div class="hero-prelude">
        <div class="hero-kicker-pill">
          <span class="hero-kicker-dot"></span>
          <span class="hero-kicker">{kicker}</span>
        </div>
      </div>
    )}

    <div class="hero-copy__header">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
    </div>

    <div class="hero-actions">
      <p class="hero-actions__context">Book a pilot review if this looks like your supervision workflow.</p>
      {primaryCTA && (
        <a href={primaryCTA.href} class="btn-premium" role="button">
          <span class="btn-premium__text">{primaryCTA.text}</span>
        </a>
      )}

      {secondaryCTA && (
        <a href={secondaryCTA.href} class="hero-secondary-link">
          <span class="hero-secondary-link__text">{secondaryCTA.text}</span>
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            class="hero-secondary-link__icon"
            aria-hidden="true"
          >
            <path
              d="M5 12H19M19 12L13 6M19 12L13 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="square"></path>
          </svg>
        </a>
      )}
    </div>

    {helperText && <p class="hero-helper">{helperText}</p>}
  </div>
</div>

<style>
  .hero-copy-wrap {
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }

  .hero-copy {
    max-width: 34rem;
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    justify-items: start;
    gap: 1.85rem;
    padding: 0.4rem 0 0;
    text-align: left;
  }

  .hero-copy__header {
    display: grid;
    gap: 1.15rem;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.46rem 0.82rem;
    border-radius: 4px;
    border: 1px dotted rgba(253, 252, 252, 0.14);
    background: rgba(48, 44, 44, 0.28);
    backdrop-filter: blur(10px);
  }

  .hero-kicker-dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-title {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(3.05rem, 4.6vw, 4.65rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-subtitle {
    max-width: 33rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.82;
    color: rgba(253, 252, 252, 0.82);
    text-wrap: pretty;
  }


  .hero-actions {
    display: grid;
    gap: 0.95rem 1rem;
    align-items: start;
    justify-items: start;
    margin-top: 0.45rem;
  }

  .hero-actions__context {
    margin: 0;
    max-width: 28rem;
    color: rgba(253, 252, 252, 0.64);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.7;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-helper {
    margin: 0;
    max-width: 32rem;
    color: rgba(253, 252, 252, 0.56);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.7;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .btn-premium {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.92rem 1.55rem;
    background: var(--accent-primary);
    border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
    border-radius: 4px;
    color: var(--bg-primary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .btn-premium:hover {
    transform: translateY(-1px);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 3rem;
    color: rgba(253, 252, 252, 0.74);
    font-family: var(--font-mono);
    font-size: 0.71rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px dotted rgba(253, 252, 252, 0.14);
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover {
    color: var(--accent-primary);
    border-color: rgba(var(--accent-primary-rgb), 0.44);
  }

  .hero-secondary-link__icon {
    flex-shrink: 0;
  }
  @media (max-width: 720px) {
    .hero-copy {
      gap: 1.15rem;
    }

    .hero-title {
      max-width: 12ch;
      font-size: clamp(2.8rem, 12vw, 3.8rem);
    }
  }
</style>
