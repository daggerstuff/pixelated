---
export interface Props {
  variant?: 'section' | 'section-soft' | 'cta'
}

const { variant = 'section' } = Astro.props
---

<div class:list={['section-atmosphere', `section-atmosphere--${variant}`]} aria-hidden="true">
  <div class="section-atmosphere__plane section-atmosphere__plane--left"></div>
  <div class="section-atmosphere__plane section-atmosphere__plane--right"></div>
  <div class="section-atmosphere__beam"></div>
  <div class="section-atmosphere__glow section-atmosphere__glow--left"></div>
  <div class="section-atmosphere__glow section-atmosphere__glow--right"></div>
  <div class="section-atmosphere__grid"></div>
</div>

<style>
  .section-atmosphere {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .section-atmosphere__plane,
  .section-atmosphere__beam,
  .section-atmosphere__glow,
  .section-atmosphere__grid {
    position: absolute;
  }

  .section-atmosphere__plane--left {
    top: -10%;
    left: -8%;
    width: min(48rem, 66vw);
    height: min(34rem, 52vw);
    clip-path: polygon(0 0, 84% 0, 62% 100%, 0 100%);
  }

  .section-atmosphere__plane--right {
    right: -8%;
    bottom: -16%;
    width: min(34rem, 44vw);
    height: min(34rem, 44vw);
    clip-path: polygon(22% 0, 100% 0, 100% 100%, 0 82%);
  }

  .section-atmosphere__beam {
    top: 18%;
    right: 14%;
    width: min(26rem, 34vw);
    height: 1px;
    transform: rotate(-22deg);
    transform-origin: right center;
  }

  .section-atmosphere__glow {
    border-radius: 9999px;
    filter: blur(100px);
    transform: translateZ(0);
  }

  .section-atmosphere__glow--left {
    top: 8%;
    left: -10%;
    width: min(40rem, 56vw);
    height: min(40rem, 56vw);
  }

  .section-atmosphere__glow--right {
    right: -8%;
    bottom: 4%;
    width: min(34rem, 48vw);
    height: min(34rem, 48vw);
  }

  .section-atmosphere__grid {
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
    background-position: center center;
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at center, rgba(0, 0, 0, 0.9), transparent 82%);
  }

  .section-atmosphere--section .section-atmosphere__plane--left,
  .section-atmosphere--section-soft .section-atmosphere__plane--left,
  .section-atmosphere--cta .section-atmosphere__plane--left {
    background: linear-gradient(140deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.012));
    opacity: 0.76;
  }

  .section-atmosphere--section .section-atmosphere__plane--right,
  .section-atmosphere--section-soft .section-atmosphere__plane--right,
  .section-atmosphere--cta .section-atmosphere__plane--right {
    background: linear-gradient(160deg, rgba(125, 211, 168, 0.08), rgba(255, 255, 255, 0.01));
    opacity: 0.74;
  }

  .section-atmosphere--section .section-atmosphere__beam,
  .section-atmosphere--section-soft .section-atmosphere__beam,
  .section-atmosphere--cta .section-atmosphere__beam {
    background: linear-gradient(90deg, transparent 0%, rgba(125, 211, 168, 0.28) 48%, rgba(255, 255, 255, 0.12) 100%);
    opacity: 0.55;
  }

  .section-atmosphere--section .section-atmosphere__glow--left,
  .section-atmosphere--cta .section-atmosphere__glow--left {
    background: radial-gradient(circle, rgba(125, 211, 168, 0.1) 0%, rgba(125, 211, 168, 0.02) 45%, transparent 72%);
    opacity: 0.24;
  }

  .section-atmosphere--section .section-atmosphere__glow--right,
  .section-atmosphere--cta .section-atmosphere__glow--right {
    background: radial-gradient(circle, rgba(125, 211, 168, 0.08) 0%, rgba(125, 211, 168, 0.018) 45%, transparent 74%);
    opacity: 0.22;
  }

  .section-atmosphere--section-soft .section-atmosphere__glow--left,
  .section-atmosphere--section-soft .section-atmosphere__glow--right {
    background: radial-gradient(circle, rgba(17, 23, 22, 0.08) 0%, rgba(17, 23, 22, 0.02) 45%, transparent 72%);
    opacity: 0.14;
  }

  .section-atmosphere--section .section-atmosphere__grid,
  .section-atmosphere--cta .section-atmosphere__grid {
    opacity: 0.05;
  }

  .section-atmosphere--section-soft .section-atmosphere__grid {
    opacity: 0.03;
    background-image:
      linear-gradient(rgba(17, 23, 22, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(17, 23, 22, 0.08) 1px, transparent 1px);
  }

  .section-atmosphere--cta .section-atmosphere__plane--left {
    background: linear-gradient(135deg, rgba(125, 211, 168, 0.14), rgba(125, 211, 168, 0.03));
  }

  .section-atmosphere--cta .section-atmosphere__plane--right {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.08), rgba(125, 211, 168, 0.015));
  }

  @media (max-width: 768px) {
    .section-atmosphere__grid {
      background-size: 52px 52px;
      opacity: 0.08;
    }
  }
</style>
