---
export interface Props {
  label: string
  title?: string
  body?: string
  items: readonly { label: string; value: string }[]
  theme?: 'paper' | 'dark'
  className?: string
}

const {
  label,
  title = '',
  body = '',
  items,
  theme = 'paper',
  className = '',
} = Astro.props
---

<div class:list={['info-strip', `info-strip--${theme}`, className]}>
  <div class="info-strip__lead">
    <span class="pe-meta-label">{label}</span>
    {title ? <h3 class="pe-heading-s info-strip__title">{title}</h3> : null}
    {body ? <p class="info-strip__body">{body}</p> : null}
  </div>

  <div class="info-strip__list pe-home-stack">
    {
      items.map((item) => (
        <div class="info-strip__row">
          <span class="info-strip__label">{item.label}</span>
          <p class="info-strip__value">{item.value}</p>
        </div>
      ))
    }
  </div>
</div>

<style>
  .info-strip {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.25rem);
    padding: clamp(1.25rem, 2vw, 1.75rem);
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .info-strip__lead {
    display: grid;
    gap: 0.85rem;
    align-content: start;
  }

  .info-strip__title {
    max-width: 18ch;
  }

  .info-strip__body {
    margin: 0;
    max-width: 34ch;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    line-height: 1.68;
    color: rgba(253, 252, 252, 0.7);
  }

  .info-strip__list {
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .info-strip__row {
    display: grid;
    gap: 0.55rem;
    padding: 1rem 0;
  }

  .info-strip__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(253, 252, 252, 0.52);
  }

  .info-strip__value {
    margin: 0;
    max-width: 40ch;
    font-family: var(--font-mono);
    font-size: 0.94rem;
    line-height: 1.65;
    color: var(--text-primary);
  }

  .info-strip--dark {
    border: 1px solid rgba(253, 252, 252, 0.08);
    background: rgba(48, 44, 44, 0.6);
    backdrop-filter: blur(12px);
    color: var(--text-primary);
  }

  .info-strip--paper {
    background: rgba(253, 252, 252, 0.96);
    color: #201d1d;
    border: 1px solid rgba(32, 29, 29, 0.12);
  }

  .info-strip--paper .info-strip__body,
  .info-strip--paper .info-strip__label {
    color: rgba(32, 29, 29, 0.62);
  }

  .info-strip--paper .info-strip__value {
    color: #201d1d;
  }

  @media (min-width: 960px) {
    .info-strip {
      grid-template-columns: minmax(0, 18rem) minmax(0, 1fr);
    }

    .info-strip__list {
      border-top: 0;
      border-left: 1px dotted rgba(253, 252, 252, 0.12);
      padding-left: 1.5rem;
    }

    .info-strip--paper .info-strip__list {
      border-left-color: rgba(32, 29, 29, 0.12);
    }
  }
</style>
