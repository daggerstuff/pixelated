---
export interface Props {
  label: string
  title?: string
  body?: string
  items: readonly { label: string; value: string }[]
  theme?: 'paper' | 'dark'
  className?: string
}

const {
  label,
  title = '',
  body = '',
  items,
  theme = 'paper',
  className = '',
} = Astro.props
---

<div class:list={['info-strip', `info-strip--${theme}`, className]}>
  <div class="info-strip__lead">
    <span class="pe-meta-label">{label}</span>
    {title ? <h3 class="pe-heading-s">{title}</h3> : null}
    {body ? <p>{body}</p> : null}
  </div>
  <div class="info-strip__grid">
    {
      items.map((item) => (
        <div class="info-strip__item">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))
    }
  </div>
</div>

<style>
  .info-strip {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--spacing-8);
    padding: var(--spacing-8);
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .info-strip__lead {
    display: grid;
    gap: var(--spacing-4);
    align-content: start;
  }

  .info-strip__lead p {
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.7;
    margin: 0;
  }

  .info-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-4);
  }

  .info-strip__item {
    padding: var(--spacing-4);
    border: 1px solid var(--divider-subtle);
    background: var(--bg-ghost);
    border-radius: 2px;
    display: grid;
    gap: var(--spacing-2);
  }

  .info-strip__item span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .info-strip__item strong {
    font-size: 1rem;
    font-weight: 500;
  }

  /* Dark / Terminal Theme */
  .info-strip--dark {
    border: 1px solid var(--border-glass);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    color: var(--text-primary);
  }

  .info-strip--dark .info-strip__item {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.05);
  }

  /* Paper / Light Theme */
  .info-strip--paper {
    background: var(--surface-paper);
    color: var(--ink-primary);
    border: 1px solid var(--ink-border);
  }

  .info-strip--paper .info-strip__item {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 880px) {
    .info-strip {
      grid-template-columns: 1fr;
    }
    
    .info-strip__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
