---
export interface Props {
  label: string
  title?: string
  body?: string
  items: readonly { label: string; value: string }[]
  theme?: 'paper' | 'dark'
  className?: string
}

const {
  label,
  title = '',
  body = '',
  items,
  theme = 'paper',
  className = '',
} = Astro.props
---

<div class:list={['info-strip', `info-strip--${theme}`, className]}>
  <div class="info-strip__lead">
    <span class="pe-page-panel-label">{label}</span>
    {title ? <h3>{title}</h3> : null}
    {body ? <p>{body}</p> : null}
  </div>
  <div class="info-strip__grid">
    {
      items.map((item) => (
        <div class="info-strip__item">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))
    }
  </div>
</div>

<style>
  .info-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.64fr) minmax(0, 1.36fr);
    gap: clamp(1rem, 2vw, 1.9rem);
    padding: clamp(1rem, 1.6vw, 1.35rem);
    position: relative;
    overflow: hidden;
  }

  .info-strip::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: linear-gradient(
      180deg,
      var(--accent-primary),
      rgba(136, 201, 165, 0.08)
    );
  }

  .info-strip__lead {
    display: grid;
    gap: var(--space-2);
    align-content: start;
  }

  .info-strip__lead :is(h3, p) {
    max-width: 28rem;
  }

  .info-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .info-strip__item {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    min-width: 0;
    min-height: 100%;
    padding: 0.85rem 0.9rem;
    border: 1px solid rgba(17, 23, 22, 0.08);
    background: rgba(255, 255, 255, 0.62);
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .info-strip__item,
  .info-strip__item strong {
    text-wrap: balance;
    hyphens: auto;
  }

  .info-strip__item span {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .info-strip__item strong {
    font-size: 0.94rem;
    line-height: 1.35;
  }

  .info-strip--paper {
    border: 1px solid var(--ink-border);
    background: var(--surface-paper-panel);
    color: var(--ink-primary);
    box-shadow: 0 14px 32px rgba(17, 23, 22, 0.05);
  }

  .info-strip--paper .info-strip__lead :is(h3, p) {
    color: inherit;
  }

  .info-strip--paper .info-strip__item span {
    color: var(--ink-muted);
  }

  .info-strip--paper .info-strip__item strong {
    color: var(--ink-primary);
  }

  .info-strip--dark {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(
        135deg,
        rgba(125, 211, 168, 0.12),
        rgba(125, 211, 168, 0.02) 34%,
        rgba(255, 255, 255, 0.03) 100%
      ),
      rgba(10, 14, 15, 0.98);
    color: var(--text-primary);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
  }

  .info-strip--dark .info-strip__lead :is(h3, p) {
    color: inherit;
  }

  .info-strip--dark .info-strip__item span {
    color: rgba(255, 255, 255, 0.46);
  }

  .info-strip--dark .info-strip__item strong {
    color: var(--text-primary);
  }

  .info-strip--dark .info-strip__item {
    border-color: rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.03);
  }

  @media (max-width: 1080px) {
    .info-strip {
      grid-template-columns: 1fr;
    }

    .info-strip__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .info-strip__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .info-strip,
    .info-strip__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
