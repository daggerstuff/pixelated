---
export interface Props {
  label: string
  title: string
  body: string
  items: readonly { label: string; value: string }[]
  theme?: 'paper' | 'dark'
  className?: string
}

const {
  label,
  title,
  body,
  items,
  theme = 'paper',
  className = '',
} = Astro.props
---

<div class:list={['info-strip', `info-strip--${theme}`, className]}>
  <div class="info-strip__lead">
    <span class="pe-page-panel-label">{label}</span>
    <h3>{title}</h3>
    <p>{body}</p>
  </div>
  <div class="info-strip__grid">
    {items.map((item) => (
      <div class="info-strip__item">
        <span>{item.label}</span>
        <strong>{item.value}</strong>
      </div>
    ))}
  </div>
</div>

<style>
  .info-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(1.2rem, 2.4vw, 2.2rem);
    padding: clamp(1.35rem, 1.8vw, 1.9rem);
    position: relative;
    overflow: hidden;
  }

  .info-strip::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(180deg, var(--accent-primary), rgba(136, 201, 165, 0.08));
  }

  .info-strip__lead {
    display: grid;
    gap: var(--space-3);
  }

  .info-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .info-strip__item {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(17, 23, 22, 0.1);
    background: rgba(255, 255, 255, 0.68);
  }

  .info-strip__item span {
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .info-strip__item strong {
    font-size: 1rem;
    line-height: 1.35;
  }

  .info-strip--paper {
    border: 1px solid var(--ink-border);
    background: var(--surface-paper-panel);
    color: var(--ink-primary);
    box-shadow: 0 14px 32px rgba(17, 23, 22, 0.05);
  }

  .info-strip--paper .info-strip__lead :is(h3, p) {
    color: inherit;
  }

  .info-strip--paper .info-strip__item span {
    color: var(--ink-muted);
  }

  .info-strip--paper .info-strip__item strong {
    color: var(--ink-primary);
  }

  .info-strip--dark {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      linear-gradient(180deg, rgba(238, 235, 225, 0.96), rgba(232, 229, 220, 0.92)),
      linear-gradient(135deg, rgba(136, 201, 165, 0.06), transparent 70%);
    color: var(--ink-primary);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.12);
  }

  .info-strip--dark .info-strip__lead :is(h3, p) {
    color: inherit;
  }

  .info-strip--dark .info-strip__item span {
    color: var(--ink-muted);
  }

  .info-strip--dark .info-strip__item strong {
    color: var(--ink-primary);
  }

  @media (max-width: 1080px) {
    .info-strip,
    .info-strip__grid {
      grid-template-columns: 1fr;
    }

    .info-strip__item {
      padding-left: 0;
      padding-top: var(--space-3);
    }
  }
</style>
