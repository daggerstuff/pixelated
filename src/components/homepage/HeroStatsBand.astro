---
export interface Props {
  stats: readonly { value: string; label: string }[]
}

const { stats } = Astro.props
---

<div class="hero-stats">
  <div class="hero-stats__lead">
    <span class="hero-stats__eyebrow">What the pilot changes</span>
    <span class="hero-stats__caption">Review surface, supervision signal, and retry quality in one record.</span>
  </div>

  <ul class="hero-stats-grid" aria-label="Proof points" role="list">
    {stats.map((stat) => (
      <li class="stat-item">
        <span class="stat-value">{stat.value}</span>
        <span class="stat-label">{stat.label}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .hero-stats {
    display: grid;
    grid-template-columns: minmax(0, 15rem) minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
    margin-top: -1rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(90deg, rgba(125, 211, 168, 0.1), rgba(125, 211, 168, 0) 38%),
      rgba(8, 12, 13, 0.74);
  }

  .hero-stats__lead {
    display: grid;
    align-content: start;
    gap: 0.45rem;
    padding-right: 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-stats__eyebrow,
  .stat-label {
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .hero-stats__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .hero-stats__caption {
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.66);
  }

  .hero-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    padding: 0;
    list-style: none;
  }

  .stat-item {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
    padding: 1rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .stat-label {
    display: block;
    font-size: var(--text-sm);
    line-height: 1.45;
    text-transform: none;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 1080px) {
    .hero-stats {
      grid-template-columns: 1fr;
      margin-top: 0;
    }

    .hero-stats__lead {
      padding-right: 0;
      padding-bottom: 0.9rem;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
  }

  @media (max-width: 768px) {
    .hero-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
