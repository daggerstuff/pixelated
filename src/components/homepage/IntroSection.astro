---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: readonly string[]
    panelLabel: string
    panelItems: readonly { label: string; body: string }[]
    evidenceCards: readonly { title: string; items: readonly string[] }[]
  }
}

const { content } = Astro.props
---

<section class="pe-home-section home-section--intro">
  <div class="pe-home-shell">
    <div class="pe-home-grid home-intro">
      <div class="pe-home-rail">
        <span class="pe-meta-label">{content.label}</span>
        <div class="pe-home-rail__line"></div>
        <p class="pe-home-kicker-note">
          Useful supervision usually disappears right after the room settles. This section makes that failure visible.
        </p>
      </div>

      <div class="home-intro__body">
        <div class="home-intro__header">
          <h2 class="pe-heading-l">{content.title}</h2>
          <div class="home-intro__prose">
            {
              content.paragraphs.map((paragraph) => (
                <p class="pe-home-copy">{paragraph}</p>
              ))
            }
          </div>
        </div>

        <div class="home-intro__diagnostic">
          <div class="home-intro__issues">
            <span class="pe-page-panel-label">{content.panelLabel}</span>
            <div class="home-intro__issue-stack pe-home-stack">
              {
                content.panelItems.map((item) => (
                  <div class="home-intro__issue">
                    <span class="home-intro__issue-label">{item.label}</span>
                    <p>{item.body}</p>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="home-intro__evidence-board">
            {
              content.evidenceCards.map((card) => (
                <section class="home-intro__evidence-column">
                  <h3 class="pe-heading-s">{card.title}</h3>
                  <ul class="home-intro__evidence-list pe-home-stack">
                    {card.items.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background: transparent;
    color: var(--text-primary);
  }

  .home-intro {
    align-items: start;
  }

  .home-intro__body {
    display: grid;
    gap: 2.6rem;
  }

  .home-intro__header {
    display: grid;
    gap: 1.15rem;
    justify-items: center;
    text-align: center;
  }

  .home-intro__prose {
    display: grid;
    gap: 1.25rem;
    max-width: 44rem;
    justify-items: center;
  }

  .home-intro__diagnostic {
    display: grid;
    gap: 1.2rem;
    align-items: start;
  }

  .home-intro__issues {
    display: grid;
    gap: 0.95rem;
    padding: 1.25rem 1.35rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.54), rgba(39, 35, 35, 0.36));
    backdrop-filter: blur(12px);
    justify-items: center;
    text-align: center;
  }

  .home-intro__issue-stack {
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .home-intro__issue {
    display: grid;
    gap: 0.55rem;
    padding: 1.05rem 0;
  }

  .home-intro__issue-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .home-intro__issue p,
  .home-intro__evidence-list li {
    margin: 0;
    max-width: 42ch;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    line-height: 1.76;
    color: rgba(253, 252, 252, 0.8);
  }

  .home-intro__evidence-board {
    display: grid;
    gap: 1rem;
  }

  .home-intro__evidence-column {
    display: grid;
    gap: 0.95rem;
    padding: 1.2rem 1.25rem;
    border: 1px dotted rgba(253, 252, 252, 0.12);
    border-radius: 4px;
    background: rgba(253, 252, 252, 0.015);
    text-align: center;
  }

  .home-intro__evidence-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .home-intro__evidence-list li {
    padding: 0.9rem 0;
  }

  @media (min-width: 980px) {
    .home-intro__diagnostic {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    }

    .home-intro__issue-stack {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
      border-top: 0;
    }

    .home-intro__issue {
      padding: 1rem 1rem 1.05rem;
      border: 1px solid rgba(253, 252, 252, 0.08);
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.02);
    }

    .home-intro__evidence-board {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
