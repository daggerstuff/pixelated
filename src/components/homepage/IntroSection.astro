---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: readonly string[]
    panelLabel: string
    panelItems: readonly { label: string; body: string }[]
    evidenceCards: readonly { title: string; items: readonly string[] }[]
  }
}

const { content } = Astro.props
---

<section class="pe-home-section home-section--intro">
  <div class="pe-home-shell">
    <div class="pe-home-grid home-intro">
      <div class="pe-home-rail">
        <span class="pe-meta-label">{content.label}</span>
        <div class="pe-home-rail__line"></div>
        <p class="pe-home-kicker-note">
          Useful supervision usually disappears right after the room settles. This section makes that failure visible.
        </p>
      </div>

      <div class="home-intro__body">
        <div class="home-intro__header">
          <h2 class="pe-heading-l">{content.title}</h2>
          <div class="home-intro__prose">
            {
              content.paragraphs.map((paragraph) => (
                <p class="pe-home-copy">{paragraph}</p>
              ))
            }
          </div>
        </div>

        <div class="home-intro__panel pe-home-panel">
          <span class="pe-page-panel-label">{content.panelLabel}</span>
          <div class="home-proof-stack pe-home-stack">
            {
              content.panelItems.map((item) => (
                <div class="home-proof-item">
                  <span class="home-proof-item__label">{item.label}</span>
                  <p>{item.body}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="home-evidence-grid">
      {
        content.evidenceCards.map((card, index) => (
          <article
            class:list={[
              'home-evidence-card',
              'pe-home-panel',
              index === 0 && 'home-evidence-card--lead',
            ]}
          >
            <span class="pe-page-panel-label">{card.title}</span>
            <ul class="home-evidence-list">
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background: transparent;
    color: var(--text-primary);
  }

  .home-intro {
    align-items: start;
  }

  .home-intro__body {
    display: grid;
    gap: 1.5rem;
  }

  .home-intro__header {
    display: grid;
    gap: 1.15rem;
  }

  .home-intro__prose {
    display: grid;
    gap: 1rem;
  }

  .home-intro__panel {
    padding: clamp(1.15rem, 2vw, 1.5rem);
  }

  .home-proof-stack {
    margin-top: 1rem;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .home-proof-item {
    display: grid;
    gap: 0.55rem;
    padding: 1rem 0;
  }

  .home-proof-item__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .home-proof-item p {
    margin: 0;
    max-width: 44ch;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.68;
    color: rgba(253, 252, 252, 0.72);
  }

  .home-evidence-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .home-evidence-card {
    padding: clamp(1.15rem, 2vw, 1.5rem);
  }

  .home-evidence-list {
    display: grid;
    gap: 0;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .home-evidence-list li {
    position: relative;
    padding: 0.9rem 0 0.9rem 1.35rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.68;
    color: rgba(253, 252, 252, 0.72);
    border-bottom: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .home-evidence-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.25rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  @media (min-width: 980px) {
    .home-evidence-grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    }
  }
</style>
