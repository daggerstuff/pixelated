---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: readonly string[]
    panelLabel: string
    panelItems: readonly { label: string; body: string }[]
    evidenceCards: readonly { title: string; items: readonly string[] }[]
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--intro">
  <div class="pe-page-shell home-shell">
    <div class="home-intro">
      <div class="home-intro__lead">
        <span class="pe-page-label">{content.label}</span>
        <h2 class="pe-page-heading">{content.title}</h2>
        {content.paragraphs.map((paragraph, index) => (
          <p class:list={['home-copy', index === 0 ? 'home-copy--first' : 'home-copy--subsequent']}>{paragraph}</p>
        ))}
      </div>

      <div class="home-intro__panel">
        <span class="pe-page-panel-label">{content.panelLabel}</span>
        <div class="home-proof-stack">
          {content.panelItems.map((item) => (
            <div class="home-proof-item">
          <span class="home-proof-item__label">{item.label}</span>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="home-evidence-grid home-evidence-grid--spaced">
      {content.evidenceCards.map((card, index) => (
        <article class:list={['home-evidence-card', index === 0 && 'home-evidence-card--light']}>
          <span class="pe-page-panel-label">{card.title}</span>
          <ul class="home-evidence-list">
            {card.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background:
      radial-gradient(circle at top right, rgba(125, 211, 168, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(10, 14, 15, 0.98), rgba(8, 11, 12, 1));
    color: var(--text-primary);
    overflow: hidden;
  }

  .home-copy {
    max-width: 42rem;
    font-size: clamp(1rem, 0.96rem + 0.2vw, 1.1rem);
    line-height: 1.7;
  }

  .home-copy--first {
    margin-top: var(--space-6);
  }

  .home-copy--subsequent {
    margin-top: var(--space-4);
  }

  .home-section--intro :is(h2, h3, p, li, span) {
    color: inherit;
  }

  .home-section--intro .home-copy,
  .home-section--intro .home-proof-item p,
  .home-section--intro .home-evidence-list {
    color: rgba(255, 255, 255, 0.72);
  }

  .home-section--intro .pe-page-label,
  .home-section--intro .pe-page-panel-label {
    color: var(--accent-primary);
  }

  .home-section--intro .pe-page-heading {
    max-width: 12ch;
    color: var(--text-primary);
  }

  .home-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.96fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    position: relative;
  }

  .home-intro::after {
    content: '';
    position: absolute;
    right: clamp(-4rem, -6vw, -2rem);
    bottom: -2.4rem;
    width: min(24rem, 42vw);
    height: min(24rem, 42vw);
    border: 1px solid rgba(17, 23, 22, 0.08);
    opacity: 0.2;
  }

  .home-intro__lead {
    position: relative;
    z-index: 1;
  }

  .home-intro__panel {
    position: relative;
    padding: clamp(1.35rem, 2vw, 1.9rem);
    border: 1px solid rgba(255, 255, 255, 0.09);
    background:
      linear-gradient(180deg, rgba(20, 28, 28, 0.98), rgba(14, 19, 20, 0.94)),
      rgba(12, 16, 17, 0.94);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.22);
  }

  .home-intro__panel::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(125, 211, 168, 0.9), rgba(125, 211, 168, 0.14));
  }

  .home-intro__panel .home-proof-item__label,
  .home-intro__panel .home-panel-label {
    color: var(--accent-primary);
  }

  .home-intro__panel .home-proof-item p {
    color: rgba(255, 255, 255, 0.72);
  }

  .home-proof-stack,
  .home-evidence-grid,
  .home-evidence-list {
    display: grid;
    gap: var(--space-4);
  }

  .home-proof-item {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .home-proof-item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .home-proof-item__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .home-evidence-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    align-items: stretch;
    gap: var(--space-6);
    position: relative;
  }

  .home-evidence-grid--spaced {
    margin-top: var(--space-8);
    padding-top: var(--space-5);
  }

  .home-evidence-grid--spaced::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, rgba(125, 211, 168, 0.22), transparent 78%);
  }

  .home-evidence-card {
    min-width: 0;
    padding: clamp(1.3rem, 2vw, 1.8rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
      rgba(11, 15, 16, 0.92);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.18);
  }

  .home-evidence-card--light {
    position: relative;
    background:
      linear-gradient(180deg, rgba(125, 211, 168, 0.08), rgba(125, 211, 168, 0)),
      rgba(13, 19, 20, 0.98);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
  }

  .home-evidence-card--light::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(180deg, rgba(125, 211, 168, 1), rgba(125, 211, 168, 0.18));
  }

  .home-evidence-card:last-child {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
      rgba(8, 12, 13, 0.88);
    color: var(--text-primary);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.16);
  }

  .home-evidence-card--light .home-evidence-list {
    display: grid;
    gap: var(--space-4);
    padding-left: 0;
  }

  .home-evidence-card--light .home-evidence-list li {
    list-style: none;
  }

  .home-evidence-list {
    padding-left: 1rem;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.65;
  }

  @media (max-width: 960px) {
    .home-intro,
    .home-evidence-grid {
      grid-template-columns: 1fr;
    }

    .home-intro::after {
      display: none;
    }

  }
</style>
