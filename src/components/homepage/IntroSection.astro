---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: readonly string[]
    panelLabel: string
    panelItems: readonly { label: string; body: string }[]
    evidenceCards: readonly { title: string; items: readonly string[] }[]
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--intro">
  <div class="pe-page-shell home-shell">
    <div class="home-intro">
      <div class="home-intro__lead">
        <span class="pe-page-label">{content.label}</span>
        <h2 class="pe-page-heading">{content.title}</h2>
        {
          content.paragraphs.map((paragraph, index) => (
            <p
              class:list={[
                'home-copy',
                index === 0 ? 'home-copy--first' : 'home-copy--subsequent',
              ]}
            >
              {paragraph}
            </p>
          ))
        }
      </div>

      <div class="home-intro__panel">
        <span class="pe-page-panel-label">{content.panelLabel}</span>
        <div class="home-proof-stack">
          {
            content.panelItems.map((item) => (
              <div class="home-proof-item">
                <span class="home-proof-item__label">{item.label}</span>
                <p>{item.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="home-evidence-grid home-evidence-grid--spaced">
      {
        content.evidenceCards.map((card, index) => (
          <article
            class:list={[
              'home-evidence-card',
              index === 0 && 'home-evidence-card--light',
            ]}
          >
            <span class="pe-page-panel-label">{card.title}</span>
            <ul class="home-evidence-list">
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(143, 184, 162, 0.06),
        transparent 42%
      ),
      rgba(10, 14, 15, 0.98);
    color: var(--text-primary);
    overflow: hidden;
  }

  .home-copy {
    max-width: 34rem;
    font-size: clamp(1rem, 0.96rem + 0.12vw, 1.06rem);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .home-copy--first {
    margin-top: var(--space-6);
  }

  .home-copy--subsequent {
    margin-top: var(--space-4);
  }

  .home-section--intro :is(h2, h3, p, li, span) {
    color: inherit;
  }

  .home-section--intro .home-copy,
  .home-section--intro .home-proof-item p,
  .home-section--intro .home-evidence-list {
    color: #cbd5e1;
  }

  .home-section--intro .pe-page-label,
  .home-section--intro .pe-page-panel-label {
    color: var(--accent-primary);
  }

  .home-section--intro .pe-page-heading {
    max-width: 15ch;
    font-size: clamp(2.15rem, 1.95rem + 0.9vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--text-primary);
  }

  .home-intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 3rem);
    align-items: start;
    position: relative;
  }

  .home-intro::after {
    display: none;
  }

  .home-intro__lead {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    margin: 0 auto;
    padding-top: 0;
    text-align: center;
  }

  .home-intro__panel {
    position: relative;
    max-width: 72rem;
    width: 100%;
    margin: 0 auto;
    padding: clamp(1.3rem, 2vw, 1.7rem);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.96rem;
    background:
      linear-gradient(180deg, rgba(20, 28, 28, 0.92), rgba(14, 19, 20, 0.88)),
      rgba(12, 16, 17, 0.9);
    box-shadow: 0 22px 54px rgba(2, 8, 9, 0.22);
  }

  .home-intro__panel::before {
    content: '';
    position: absolute;
    inset: 0.85rem 1rem auto 1rem;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(125, 211, 168, 0.55),
      rgba(125, 211, 168, 0.08)
    );
  }

  .home-intro__panel .home-proof-item__label,
  .home-intro__panel .home-panel-label {
    color: var(--accent-primary);
  }

  .home-intro__panel .home-proof-item p {
    color: #cbd5e1;
  }

  .home-proof-stack,
  .home-evidence-grid,
  .home-evidence-list {
    display: grid;
    gap: 1rem;
  }

  .home-proof-stack {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .home-proof-item {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .home-proof-item:first-child {
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .home-proof-item__label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--accent-primary);
  }

  .home-evidence-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
    gap: clamp(0.95rem, 1.8vw, 1.2rem);
    position: relative;
  }

  .home-evidence-grid--spaced {
    margin-top: clamp(3.5rem, 5vw, 5rem);
    padding-top: 1.85rem;
  }

  .home-evidence-grid--spaced::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(125, 211, 168, 0.22),
      transparent 78%
    );
  }

  .home-evidence-card {
    min-width: 0;
    padding: clamp(1.35rem, 1.9vw, 1.85rem);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.96rem;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.045),
        rgba(255, 255, 255, 0)
      ),
      rgba(11, 15, 16, 0.92);
    box-shadow: 0 18px 42px rgba(2, 8, 9, 0.18);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .home-evidence-card:hover {
    border-color: rgba(143, 184, 162, 0.24);
    transform: translateY(-3px);
  }

  .home-evidence-card--light {
    position: relative;
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.08),
        rgba(143, 184, 162, 0)
      ),
      rgba(13, 19, 20, 0.98);
    box-shadow: var(--shadow-floating);
  }

  .home-evidence-list {
    padding-left: 1rem;
    line-height: 1.65;
  }

  @media (max-width: 1080px) {
    .home-evidence-grid {
      grid-template-columns: 1fr;
    }

    .home-evidence-card:first-child,
    .home-evidence-card:last-child,
    .home-evidence-card {
      grid-column: auto;
      margin-top: 0;
    }
  }

  .home-evidence-card--light::before {
    content: '';
    position: absolute;
    inset: 0.95rem 1rem auto 1rem;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(125, 211, 168, 1),
      rgba(125, 211, 168, 0.18)
    );
  }

  .home-evidence-card:last-child {
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.01)
      ),
      rgba(16, 23, 22, 0.94);
    color: var(--text-primary);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.14);
  }

  .home-evidence-card--light .home-evidence-list {
    display: grid;
    gap: var(--space-4);
    padding-left: 0;
    list-style: none;
  }

  .home-evidence-card--light .home-evidence-list li {
    position: relative;
    padding-left: 1.25rem;
  }

  .home-evidence-card--light .home-evidence-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--accent-primary);
    opacity: 0.6;
  }

  .home-evidence-list {
    padding-left: 0;
    list-style: none;
    color: #e2e8f0;
    line-height: 1.65;
  }

  .home-evidence-list li {
    position: relative;
    padding-left: 1.25rem;
  }

  .home-evidence-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 0.16rem;
    background: rgba(125, 211, 168, 0.5);
  }

  @media (max-width: 1040px) {
    .home-intro,
    .home-evidence-grid {
      grid-template-columns: 1fr;
    }

    .home-intro::after {
      display: none;
    }

    .home-proof-stack {
      grid-template-columns: 1fr;
    }
  }
</style>
