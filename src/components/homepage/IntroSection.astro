---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: string[]
    panelLabel: string
    panelItems: Array<{ label: string; body: string }>
    evidenceCards: Array<{ title: string; items: string[] }>
  }
}

const { content } = Astro.props
---

<section class="pe-page-section home-section home-section--intro">
  <div class="pe-page-shell home-shell">
    <div class="home-intro">
      <div class="home-intro__lead">
        <span class="pe-page-label">{content.label}</span>
        <h2 class="pe-page-heading">{content.title}</h2>
        {content.paragraphs.map((paragraph, index) => (
          <p class:list={['home-copy', index === 0 ? 'mt-6' : 'mt-4']}>{paragraph}</p>
        ))}
      </div>

      <div class="home-intro__panel">
        <span class="pe-page-panel-label">{content.panelLabel}</span>
        <div class="home-proof-stack">
          {content.panelItems.map((item) => (
            <div class="home-proof-item">
          <span class="home-proof-item__label">{item.label}</span>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="home-evidence-grid mt-10">
      {content.evidenceCards.map((card, index) => (
        <article class:list={['home-evidence-card', index === 0 && 'home-evidence-card--light']}>
          <span class="pe-page-panel-label">{card.title}</span>
          <ul class="home-evidence-list">
            {card.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background: var(--surface-paper-gradient);
    color: var(--ink-primary);
  }

  .home-copy {
    max-width: 42rem;
    font-size: var(--text-lg);
  }

  .home-section--intro :is(h2, h3, p, li) {
    color: inherit;
  }

  .home-section--intro .home-copy,
  .home-section--intro .home-proof-item p,
  .home-section--intro .home-evidence-list {
    color: var(--ink-secondary);
  }

  .home-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.32fr) minmax(20rem, 0.88fr);
    gap: clamp(2rem, 3vw, 3.5rem);
    align-items: start;
  }

  .home-intro__panel {
    padding: clamp(1.75rem, 2.3vw, 2.4rem);
    border: 1px solid var(--ink-border);
    background: linear-gradient(180deg, rgba(17, 23, 22, 0.98), rgba(17, 23, 22, 0.92));
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.08);
  }

  .home-intro__panel .home-proof-item__label,
  .home-intro__panel .home-panel-label {
    color: rgba(255, 255, 255, 0.82);
  }

  .home-intro__panel .home-proof-item p {
    color: rgba(255, 255, 255, 0.72);
  }

  .home-proof-stack,
  .home-evidence-grid,
  .home-evidence-list {
    display: grid;
    gap: var(--space-4);
  }

  .home-proof-item {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .home-proof-item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .home-proof-item__label {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .home-evidence-grid {
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
    align-items: stretch;
    gap: var(--space-6);
  }

  .home-evidence-card {
    min-width: 0;
    padding: clamp(1.55rem, 2.2vw, 2.2rem);
    border: 1px solid var(--ink-border);
    background: var(--surface-paper-panel);
  }

  .home-evidence-card--light {
    background: var(--surface-paper-strong);
    box-shadow: 0 18px 40px rgba(17, 23, 22, 0.06);
  }

  .home-evidence-card--light .home-evidence-list {
    display: grid;
    gap: var(--space-4);
    padding-left: 0;
  }

  .home-evidence-card--light .home-evidence-list li {
    list-style: none;
  }

  .home-evidence-list {
    padding-left: 1rem;
    color: var(--ink-secondary);
  }

  @media (max-width: 960px) {
    .home-intro,
    .home-evidence-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
