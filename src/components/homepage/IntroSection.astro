---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: readonly string[]
    panelLabel: string
    panelItems: readonly { label: string; body: string }[]
    evidenceCards: readonly { title: string; items: readonly string[] }[]
  }
}

const { content } = Astro.props
---

<section class="home-section home-section--intro">
  <div class="container">
    <div class="home-intro">
      <div class="home-intro__lead">
        <span class="pe-meta-label">{content.label}</span>
        <h2 class="pe-heading-l">{content.title}</h2>
        {
          content.paragraphs.map((paragraph, index) => (
            <p
              class:list={[
                'home-copy',
                index === 0 ? 'home-copy--first' : 'home-copy--subsequent',
              ]}
            >
              {paragraph}
            </p>
          ))
        }
      </div>

      <div class="home-intro__panel glass-panel">
        <span class="pe-meta-label">{content.panelLabel}</span>
        <div class="home-proof-stack">
          {
            content.panelItems.map((item) => (
              <div class="home-proof-item">
                <span class="home-proof-item__label">{item.label}</span>
                <p>{item.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="home-evidence-grid home-evidence-grid--spaced">
      {
        content.evidenceCards.map((card, index) => (
          <article
            class:list={[
              'home-evidence-card',
              'glass-panel',
              index === 0 && 'home-evidence-card--light',
            ]}
          >
            <span class="pe-meta-label">{card.title}</span>
            <ul class="home-evidence-list">
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background: var(--bg-primary);
    color: var(--text-primary);
    padding: var(--section-padding-y) 0;
    position: relative;
    overflow: hidden;
  }

  /* Grid overlay for terminal feel */
  .home-section--intro::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--grid-pattern);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at 50% 0%, black, transparent 70%);
    pointer-events: none;
    opacity: 0.12;
  }

  .home-copy {
    max-width: 32rem;
    font-size: 1rem;
    line-height: 1.7;
    margin-left: auto;
    margin-right: auto;
    opacity: 0.85;
  }

  .home-copy--first {
    margin-top: var(--spacing-6);
  }

  .home-copy--subsequent {
    margin-top: var(--spacing-4);
  }

  .home-intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(3rem, 5vw, 4.5rem);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .home-intro__lead {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
  }

  .home-intro__panel {
    position: relative;
    padding: var(--spacing-6);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  /* Structural top line */
  .home-intro__panel::after {
    content: '';
    position: absolute;
    top: -1px;
    left: var(--spacing-6);
    right: var(--spacing-6);
    height: 1px;
    background: linear-gradient(90deg, var(--accent-primary), transparent);
    opacity: 0.5;
  }

  .home-proof-stack {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-4);
    margin-top: var(--spacing-6);
  }

  .home-proof-item {
    padding: var(--spacing-4);
    border: 1px solid var(--divider-subtle);
    background: var(--bg-ghost);
    border-radius: 2px;
  }

  .home-proof-item__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-2);
  }

  .home-proof-item p {
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.7;
    margin: 0;
  }

  .home-evidence-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-6);
    margin-top: clamp(4rem, 8vw, 6rem);
    position: relative;
    z-index: 1;
  }

  .home-evidence-card {
    padding: var(--spacing-8);
    transition: transform var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }

  .home-evidence-card:hover {
    border-color: rgba(var(--accent-primary-rgb), 0.3);
    transform: translateY(-2px);
  }

  .home-evidence-card--light {
    background: rgba(var(--accent-primary-rgb), 0.03);
    border-color: rgba(var(--accent-primary-rgb), 0.15);
  }

  .home-evidence-list {
    margin: var(--spacing-6) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--spacing-3);
  }

  .home-evidence-list li {
    font-size: 0.95rem;
    padding-left: var(--spacing-5);
    position: relative;
    opacity: 0.8;
  }

  .home-evidence-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-weight: bold;
    opacity: 0.7;
  }

  @media (max-width: 880px) {
    .home-proof-stack {
      grid-template-columns: 1fr;
    }
    
    .home-evidence-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
