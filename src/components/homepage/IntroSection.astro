---
export interface Props {
  content: {
    label: string
    title: string
    paragraphs: readonly string[]
    panelLabel: string
    panelItems: readonly { label: string; body: string }[]
    evidenceCards: readonly { title: string; items: readonly string[] }[]
  }
}

const { content } = Astro.props
---

<section class="pe-home-section home-section--intro">
  <div class="pe-home-shell">
    <div class="home-intro">
      <div class="home-intro__lead">
        <span class="pe-meta-label">{content.label}</span>
        <h2 class="pe-heading-l">{content.title}</h2>
        <div class="home-intro__prose">
          {
            content.paragraphs.map((paragraph) => (
              <p class="pe-home-copy">{paragraph}</p>
            ))
          }
        </div>
      </div>

      <div class="home-intro__body">
        <section class="home-intro__diagnostic">
          <span class="pe-page-panel-label">{content.panelLabel}</span>
          <div class="home-intro__issue-grid">
            {
              content.panelItems.map((item) => (
                <article class="home-intro__issue">
                  <span class="home-intro__issue-label">{item.label}</span>
                  <p>{item.body}</p>
                </article>
              ))
            }
          </div>
        </section>

        <div class="home-intro__evidence-board">
          {
            content.evidenceCards.map((card) => (
              <section class="home-intro__evidence-column">
                <h3 class="pe-heading-s">{card.title}</h3>
                <ul class="home-intro__evidence-list">
                  {card.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home-section--intro {
    background: transparent;
    color: var(--text-primary);
  }

  .home-intro {
    display: grid;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .home-intro__lead {
    display: grid;
    gap: 1.05rem;
    max-width: 34rem;
    margin: 0 auto;
  }

  .home-intro__prose {
    display: grid;
    gap: 1rem;
  }

  .home-intro__body {
    display: grid;
    gap: 1.5rem;
  }

  .home-intro__diagnostic {
    display: grid;
    gap: 1rem;
    padding-top: 0.35rem;
  }

  .home-intro__issue-grid {
    display: grid;
    gap: 0.85rem;
  }

  .home-intro__issue {
    display: grid;
    gap: 0.55rem;
    padding: 1rem 1rem 1.05rem;
    border-top: 1px dotted rgba(253, 252, 252, 0.1);
  }

  .home-intro__issue-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .home-intro__issue p,
  .home-intro__evidence-list li {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.94rem;
    line-height: 1.74;
    color: rgba(253, 252, 252, 0.8);
  }

  .home-intro__evidence-board {
    display: grid;
    gap: 1rem;
  }

  .home-intro__evidence-column {
    display: grid;
    gap: 0.85rem;
    padding: 1.1rem 0 0;
    border-top: 1px dotted rgba(253, 252, 252, 0.1);
  }

  .home-intro__evidence-list {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .home-intro__evidence-list li {
    position: relative;
    padding-left: 0;
    text-align: center;
  }

  .home-intro__evidence-list li::before {
    content: '';
    position: static;
    display: block;
    width: 0.38rem;
    height: 0.38rem;
    margin: 0 auto 0.65rem;
    border-radius: 999px;
    background: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(var(--accent-primary-rgb), 0.12);
  }

  @media (min-width: 980px) {
    .home-intro {
      grid-template-columns: minmax(22rem, 0.82fr) minmax(0, 1.18fr);
      gap: clamp(3rem, 5vw, 5.5rem);
      align-items: start;
      text-align: center;
    }

    .home-intro__lead {
      position: sticky;
      top: 7rem;
      max-width: 31rem;
      margin: 0 auto;
      text-align: center;
      justify-items: center;
    }

    .home-intro__lead .pe-heading-l {
      max-width: 12ch;
    }

    .home-intro__lead .pe-home-copy {
      margin: 0 auto;
      text-align: center;
    }

    .home-intro__issue-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .home-intro__diagnostic,
    .home-intro__issue,
    .home-intro__evidence-column {
      text-align: center;
      justify-items: center;
    }

    .home-intro__issue,
    .home-intro__evidence-column {
      padding: 1.15rem;
      border: 1px solid rgba(253, 252, 252, 0.1);
      border-radius: 4px;
      background: rgba(253, 252, 252, 0.016);
    }

    .home-intro__issue p {
      max-width: 32rem;
      margin-inline: auto;
    }

    .home-intro__evidence-list li {
      max-width: 32rem;
      margin-inline: auto;
    }

    .home-intro__evidence-board {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (max-width: 720px) {
    .home-intro,
    .home-intro__lead,
    .home-intro__body,
    .home-intro__diagnostic,
    .home-intro__issue,
    .home-intro__evidence-column {
      text-align: center;
      justify-items: center;
    }

    .home-intro__evidence-list {
      justify-items: center;
      text-align: center;
    }

    .home-intro__issue,
    .home-intro__evidence-column {
      padding: 1rem;
      border: 1px solid rgba(253, 252, 252, 0.14);
      border-radius: 4px;
      background: rgba(253, 252, 252, 0.018);
    }
  }
</style>
