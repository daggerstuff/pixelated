---
import DataPoint from '@/components/homepage/DataPoint.astro'

export interface Props {
  artifact: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const { artifact } = Astro.props
---

<aside class="hero-artifact" aria-label="Session review artifact">
  <div class="hero-artifact__body">
    <div class="hero-artifact__header">
      <div class="hero-artifact__heading">
        <span class="hero-artifact__eyebrow">{artifact.eyebrow}</span>
        <h2 class="hero-artifact__title">{artifact.status}</h2>
      </div>

      <div class="hero-artifact__header-meta">
        <span class="hero-artifact__chip">{artifact.chip}</span>
        <span class="hero-artifact__mode">{artifact.mode}</span>
      </div>
    </div>

    {
      artifact.image ? (
        <figure class="hero-artifact__figure">
          <img
            src={artifact.image}
            alt={artifact.imageAlt || artifact.status}
            class="hero-artifact__image"
            loading="eager"
            decoding="async"
            width="1440"
            height="1200"
            srcset="/images/homepage/training-session-proof-640.png 640w, /images/homepage/training-session-proof-960.png 960w, /images/homepage/training-session-proof.png 1440w"
            sizes="(max-width: 768px) 92vw, (max-width: 1200px) 42vw, 560px"
          />
          <figcaption class="hero-artifact__figure-caption">
            Transcript, coaching lane, and decision notes stay attached to the same difficult session.
          </figcaption>
        </figure>
      ) : null
    }

    <div class="hero-artifact__readout">
      {
        artifact.readout.map((item) => (
          <div class="hero-artifact__metric">
            <DataPoint label={item.label} value={item.value} compact />
          </div>
        ))
      }
    </div>

    <section class="hero-artifact__story">
      <div class="hero-artifact__column">
        <span class="hero-artifact__label">Why teams can use it</span>
        <dl class="hero-artifact__facts pe-home-stack">
          {
            artifact.context.map((item) => (
              <div class="hero-artifact__fact">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="hero-artifact__column">
        <span class="hero-artifact__label">What the review leaves behind</span>
        <div class="hero-artifact__outputs pe-home-stack">
          {
            artifact.outputs.map((item) => (
              <div class="hero-artifact__output">
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</aside>

<style>
  .hero-artifact {
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: rgba(48, 44, 44, 0.6);
    overflow: hidden;
    backdrop-filter: blur(12px);
  }

  .hero-artifact__body {
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 2vw, 1.2rem);
  }

  .hero-artifact__header {
    display: grid;
    gap: 0.85rem;
  }

  .hero-artifact__heading {
    display: grid;
    gap: 0.45rem;
  }

  .hero-artifact__eyebrow,
  .hero-artifact__chip,
  .hero-artifact__label,
  .hero-artifact__fact dt,
  .hero-artifact__output span,
  .hero-artifact__mode {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-artifact__eyebrow,
  .hero-artifact__label,
  .hero-artifact__mode {
    color: var(--accent-primary);
  }

  .hero-artifact__title {
    margin: 0;
    max-width: 18ch;
    font-family: var(--font-mono);
    font-size: clamp(1.2rem, 1.04rem + 0.5vw, 1.7rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-artifact__header-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-artifact__chip,
  .hero-artifact__mode {
    display: inline-flex;
    align-items: center;
    padding: 0.34rem 0.54rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .hero-artifact__chip {
    border: 1px dotted rgba(253, 252, 252, 0.14);
    color: rgba(253, 252, 252, 0.7);
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-artifact__mode {
    border: 1px dotted rgba(var(--accent-primary-rgb), 0.34);
    background: rgba(var(--accent-primary-rgb), 0.08);
  }

  .hero-artifact__figure {
    margin: 0;
    display: grid;
    gap: 0;
    overflow: hidden;
    border: 1px dotted rgba(253, 252, 252, 0.14);
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.42);
  }

  .hero-artifact__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top;
  }

  .hero-artifact__figure-caption {
    margin: 0;
    padding: 0.8rem 0.9rem;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgba(253, 252, 252, 0.68);
  }

  .hero-artifact__readout {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .hero-artifact__metric {
    padding: 0.8rem;
    border: 1px dotted rgba(253, 252, 252, 0.12);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.02);
  }

  .hero-artifact__story {
    display: grid;
    gap: 1rem;
    padding-top: 0.1rem;
  }

  .hero-artifact__column {
    display: grid;
    gap: 0.75rem;
  }

  .hero-artifact__facts,
  .hero-artifact__outputs {
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .hero-artifact__fact,
  .hero-artifact__output {
    display: grid;
    gap: 0.45rem;
    padding: 0.8rem 0;
  }

  .hero-artifact__fact dt,
  .hero-artifact__output span {
    color: rgba(253, 252, 252, 0.5);
  }

  .hero-artifact__fact dd,
  .hero-artifact__output strong {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.62;
    color: rgba(253, 252, 252, 0.76);
  }

  @media (min-width: 900px) {
    .hero-artifact__story {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }
  }

  @media (max-width: 640px) {
    .hero-artifact__readout {
      grid-template-columns: 1fr;
    }
  }
</style>
