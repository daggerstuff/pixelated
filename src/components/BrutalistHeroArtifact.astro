---
export interface Props {
  artifact: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const { artifact } = Astro.props
const artifactHighlights = artifact.context.slice(0, 2)
---

<aside class="hero-artifact" aria-label="Session review artifact">
  <div class="hero-artifact__body">
    <div class="hero-artifact__header">
      <div class="hero-artifact__meta">
        <span class="hero-artifact__eyebrow">{artifact.eyebrow}</span>
        <span class="hero-artifact__mode">{artifact.mode}</span>
      </div>
      <h2 class="hero-artifact__title">{artifact.status}</h2>
      <p class="hero-artifact__summary">
        Transcript, coaching lane, and next-step evidence stay attached to one difficult session.
      </p>
    </div>

    {
      artifact.image ? (
        <figure class="hero-artifact__figure">
          <img
            src={artifact.image}
            alt={artifact.imageAlt || artifact.status}
            class="hero-artifact__image"
            loading="eager"
            decoding="async"
            width="1440"
            height="1200"
            srcset="/images/homepage/training-session-proof-640.png 640w, /images/homepage/training-session-proof-960.png 960w, /images/homepage/training-session-proof.png 1440w"
            sizes="(max-width: 768px) 92vw, (max-width: 1200px) 42vw, 560px"
          />
        </figure>
      ) : null
    }
    <div class="hero-artifact__highlights">
      {
        artifactHighlights.map((item) => (
          <div class="hero-artifact__highlight">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))
      }
    </div>
  </div>
</aside>

<style>
  .hero-artifact {
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: linear-gradient(180deg, rgba(48, 44, 44, 0.72), rgba(39, 35, 35, 0.56));
    overflow: hidden;
    backdrop-filter: blur(14px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .hero-artifact__body {
    display: grid;
    gap: 1.15rem;
    padding: clamp(1rem, 2vw, 1.25rem);
  }

  .hero-artifact__header {
    display: grid;
    gap: 0.65rem;
  }

  .hero-artifact__meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .hero-artifact__eyebrow,
  .hero-artifact__mode,
  .hero-artifact__highlight span {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-artifact__eyebrow {
    color: var(--accent-primary);
  }

  .hero-artifact__mode {
    color: rgba(253, 252, 252, 0.5);
  }

  .hero-artifact__title {
    margin: 0;
    max-width: 15ch;
    font-family: var(--font-mono);
    font-size: clamp(1.24rem, 1rem + 0.7vw, 1.95rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-artifact__summary {
    margin: 0;
    max-width: 34rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.72;
    color: rgba(253, 252, 252, 0.72);
  }

  .hero-artifact__figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.42);
  }

  .hero-artifact__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top;
  }


  .hero-artifact__highlights {
    display: grid;
    gap: 0;
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .hero-artifact__highlight {
    display: grid;
    gap: 0.45rem;
    padding: 0.85rem 0;
    border-bottom: 1px dotted rgba(253, 252, 252, 0.12);
  }

  .hero-artifact__highlight span {
    color: var(--accent-primary);
  }

  .hero-artifact__highlight strong {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.66;
    color: rgba(253, 252, 252, 0.78);
  }
</style>
