---
export interface Props {
  artifact: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const { artifact } = Astro.props
const artifactReadout = artifact.readout.slice(0, 3)
const artifactHighlights = artifact.context.slice(0, 2)
---

<aside class="hero-artifact" aria-label="Session review artifact">
  <div class="hero-artifact__body">
    <div class="hero-artifact__header">
      <div class="hero-artifact__meta">
        <span class="hero-artifact__eyebrow">{artifact.eyebrow}</span>
        <span class="hero-artifact__mode">{artifact.mode}</span>
      </div>
      <h2 class="hero-artifact__title">{artifact.status}</h2>
      {
        artifact.chip && (
          <span class="hero-artifact__chip">{artifact.chip}</span>
        )
      }
      <p class="hero-artifact__summary">
        The trainee attempt, scenario context, and supervisor notes stay
        connected in one reviewable record.
      </p>
    </div>

    {
      artifact.image ? (
        <figure class="hero-artifact__figure">
          <img
            src={artifact.image}
            alt={artifact.imageAlt || artifact.status}
            class="hero-artifact__image"
            loading="eager"
            decoding="async"
            width="1440"
            height="1200"
            srcset="/images/homepage/training-session-proof-640.png 640w, /images/homepage/training-session-proof-960.png 960w, /images/homepage/training-session-proof.png 1440w"
            sizes="(max-width: 768px) 92vw, (max-width: 1200px) 42vw, 560px"
          />
        </figure>
      ) : null
    }

    {
      artifactReadout.length > 0 && (
        <div class="hero-artifact__readout">
          {artifactReadout.map((item) => (
            <div class="hero-artifact__readout-item">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      )
    }
    {
      artifact.outputs.length > 0 && (
        <div class="hero-artifact__outputs" aria-label="Session output summary">
          {artifact.outputs.map((item) => (
            <article class="hero-artifact__output">
              <span>{item.label}</span>
              <p>{item.value}</p>
            </article>
          ))}
        </div>
      )
    }
    <div class="hero-artifact__highlights">
      {
        artifactHighlights.map((item) => (
          <div class="hero-artifact__highlight">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))
      }
    </div>
  </div>
</aside>

<style>
  .hero-artifact {
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(253, 252, 252, 0.1);
    border-radius: 20px;
    background:
      radial-gradient(
        circle at top right,
        rgba(var(--accent-primary-rgb), 0.1),
        transparent 34%
      ),
      linear-gradient(180deg, rgba(48, 44, 44, 0.84), rgba(35, 33, 33, 0.72));
    overflow: hidden;
    backdrop-filter: blur(16px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 24px 50px rgba(0, 0, 0, 0.2);
    text-align: center;
  }

  .hero-artifact__body {
    display: grid;
    gap: clamp(0.95rem, 1.5vw, 1.3rem);
    padding: clamp(1.35rem, 2.4vw, 2rem);
    justify-items: center;
    min-width: 0;
  }

  .hero-artifact__header {
    display: grid;
    gap: 0.75rem;
    justify-items: center;
  }

  .hero-artifact__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .hero-artifact__eyebrow,
  .hero-artifact__mode,
  .hero-artifact__highlight span {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .hero-artifact__eyebrow {
    color: var(--accent-primary, #ff6b00);
  }

  .hero-artifact__mode {
    color: rgba(253, 252, 252, 0.5);
  }

  .hero-artifact__title {
    margin: 0;
    max-width: 20ch;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1rem + 0.85vw, 2rem);
    line-height: 1.16;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-artifact__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--accent-primary-rgb), 0.26);
    background: rgba(var(--accent-primary-rgb), 0.08);
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(253, 252, 252, 0.88);
  }

  .hero-artifact__summary {
    margin: 0;
    max-width: 100%;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.72;
    color: rgba(253, 252, 252, 0.78);
  }

  .hero-artifact__readout {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    text-align: center;
    justify-items: center;
  }

  .hero-artifact__readout-item {
    display: grid;
    gap: 0.7rem;
    padding: clamp(0.85rem, 1.8vw, 1.1rem);
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.035);
    text-align: center;
    justify-items: center;
  }

  .hero-artifact__readout-item span {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: rgba(253, 252, 252, 0.5);
  }

  .hero-artifact__readout-item strong {
    font-family: var(--font-sans);
    font-size: 0.86rem;
    line-height: 1.45;
    color: var(--text-primary);
  }

  .hero-artifact__figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.42);
  }

  .hero-artifact__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
  }

  .hero-artifact__highlights {
    display: grid;
    gap: clamp(0.9rem, 1.6vw, 1.2rem);
    border-top: 1px dotted rgba(253, 252, 252, 0.12);
    padding-top: clamp(1rem, 1.8vw, 1.3rem);
    justify-items: center;
    text-align: center;
  }

  .hero-artifact__highlight {
    display: grid;
    gap: 0.75rem;
    padding: clamp(0.85rem, 1.4vw, 1.1rem) 0 0;
    text-align: center;
    justify-items: center;
  }

  .hero-artifact__highlight span {
    color: var(--accent-primary);
  }

  .hero-artifact__highlight strong {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.66;
    color: rgba(253, 252, 252, 0.8);
  }

  .hero-artifact__outputs {
    display: grid;
    gap: 0.85rem;
    width: 100%;
    padding-top: 0.1rem;
  }

  .hero-artifact__output {
    display: grid;
    gap: 0.5rem;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(253, 252, 252, 0.08);
    border-radius: 14px;
    background: rgba(253, 252, 252, 0.03);
    text-align: center;
    justify-items: center;
  }

  .hero-artifact__output span {
    font-family: var(--font-label);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-artifact__output p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.68;
    color: rgba(253, 252, 252, 0.82);
  }

  @media (min-width: 720px) {
    .hero-artifact__highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1040px) {
    .hero-artifact__body {
      gap: 0.8rem;
      padding: 1.15rem;
      align-items: start;
      justify-items: start;
    }

    .hero-artifact__header,
    .hero-artifact__meta,
    .hero-artifact__highlights,
    .hero-artifact__output {
      justify-items: start;
      text-align: left;
    }

    .hero-artifact__title {
      max-width: 18ch;
      margin: 0;
      font-size: clamp(1.2rem, 1.4vw, 1.65rem);
    }

    .hero-artifact__summary {
      margin: 0;
      font-size: 0.8rem;
      line-height: 1.55;
    }

    .hero-artifact__readout {
      justify-items: center;
    }

    .hero-artifact__readout-item {
      padding: 0.65rem;
      text-align: center;
      justify-items: center;
    }

    .hero-artifact__figure {
      max-height: 33rem;
    }

    .hero-artifact__image {
      max-height: 34rem;
      object-fit: cover;
    }

    .hero-artifact__highlights {
      justify-items: center;
      text-align: center;
    }

    .hero-artifact__highlight {
      padding-top: 0.55rem;
      text-align: center;
      justify-items: center;
    }

    .hero-artifact__highlight strong {
      font-size: 0.78rem;
      line-height: 1.55;
    }
  }

  @media (max-width: 720px) {
    .hero-artifact,
    .hero-artifact__header,
    .hero-artifact__meta {
      justify-content: center;
      text-align: center;
    }

    .hero-artifact__body,
    .hero-artifact__header,
    .hero-artifact__highlight,
    .hero-artifact__readout-item {
      justify-items: center;
    }

    .hero-artifact__readout {
      grid-template-columns: 1fr;
    }

    .hero-artifact__readout-item {
      text-align: center;
    }

    .hero-artifact__outputs {
      justify-items: stretch;
    }
  }
</style>
