---
import DataPoint from '@/components/homepage/DataPoint.astro'

export interface Props {
  artifact: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const { artifact } = Astro.props
---

<aside class="hero-artifact" aria-label="Session review artifact">
  <div class="hero-artifact__body">
    <div class="hero-artifact__header">
      <div class="hero-artifact__heading">
        <span class="hero-artifact__eyebrow">{artifact.eyebrow}</span>
        <h2 class="hero-artifact__title">{artifact.status}</h2>
      </div>
      <div class="hero-artifact__header-meta">
        <span class="hero-artifact__chip">{artifact.chip}</span>
        <span class="hero-artifact__mode">{artifact.mode}</span>
      </div>
    </div>

    {
      artifact.image ? (
        <figure class="hero-artifact__figure">
          <div class="hero-artifact__figure-bar">
            <span>Session evidence</span>
            <span>Review lane attached</span>
          </div>
          <img
            src={artifact.image}
            alt={artifact.imageAlt || artifact.status}
            class="hero-artifact__image"
            loading="eager"
            decoding="async"
            width="1440"
            height="1200"
            srcset="/images/homepage/training-session-proof-640.png 640w, /images/homepage/training-session-proof-960.png 960w, /images/homepage/training-session-proof.png 1440w"
            sizes="(max-width: 768px) 92vw, (max-width: 1200px) 42vw, 560px"
          />
        </figure>
      ) : null
    }

    <div class="hero-artifact__readout">
      {
        artifact.readout.map((item) => (
          <div class="hero-artifact__metric">
            <DataPoint label={item.label} value={item.value} compact />
          </div>
        ))
      }
    </div>

    <section class="hero-artifact__panel hero-artifact__panel--story">
      <span class="hero-artifact__label">Why teams can use it</span>
      <dl class="hero-artifact__facts">
        {
          artifact.context.map((item) => (
            <div class="hero-artifact__fact">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))
        }
      </dl>

      <div class="hero-artifact__outputs">
        {
          artifact.outputs.map((item) => (
            <div class="hero-artifact__output">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</aside>

<style>
  .hero-artifact {
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.07),
        rgba(255, 255, 255, 0.018)
      ),
      rgba(12, 18, 19, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 32px 76px rgba(0, 0, 0, 0.28);
    overflow: hidden;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out);
  }

  .hero-artifact:hover {
    border-color: rgba(143, 184, 162, 0.24);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 38px 90px rgba(0, 0, 0, 0.4),
      0 0 40px rgba(143, 184, 162, 0.08);
  }

  .hero-artifact__eyebrow,
  .hero-artifact__chip,
  .hero-artifact__label,
  .hero-artifact__fact dt,
  .hero-artifact__output span,
  .hero-artifact__figure-bar span,
  .hero-artifact__mode {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: none;
  }

  .hero-artifact__readout {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .hero-artifact__metric {
    padding: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.76rem;
    background: rgba(255, 255, 255, 0.035);
  }

  .hero-artifact__body {
    display: grid;
    gap: 1rem;
    padding: 1.15rem;
  }

  .hero-artifact__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.1rem;
  }

  .hero-artifact__heading {
    display: grid;
    gap: 0.45rem;
    max-width: 25rem;
  }

  .hero-artifact__eyebrow,
  .hero-artifact__chip,
  .hero-artifact__label,
  .hero-artifact__mode {
    color: var(--accent-primary);
  }

  .hero-artifact__header-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.45rem;
  }

  .hero-artifact__title {
    margin: 0;
    font-size: clamp(1.18rem, 1.02rem + 0.46vw, 1.62rem);
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: rgba(255, 255, 255, 0.94);
  }

  .hero-artifact__chip,
  .hero-artifact__mode {
    display: inline-flex;
    align-items: center;
    padding: 0.34rem 0.54rem;
    border-radius: 0.52rem;
    background: rgba(143, 184, 162, 0.08);
    white-space: nowrap;
  }

  .hero-artifact__chip {
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.74);
    background: rgba(255, 255, 255, 0.04);
  }

  .hero-artifact__mode {
    border: 1px solid rgba(143, 184, 162, 0.3);
    color: rgba(255, 255, 255, 0.82);
  }

  .hero-artifact__figure {
    margin: 0;
    display: grid;
    gap: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.86rem;
    background: rgba(6, 9, 11, 0.9);
    box-shadow: 0 26px 58px rgba(0, 0, 0, 0.3);
  }

  .hero-artifact__figure-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-artifact__figure-bar span {
    color: rgba(255, 255, 255, 0.54);
  }

  .hero-artifact__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 8.4;
    object-fit: cover;
    object-position: top;
  }

  .hero-artifact__panel {
    display: grid;
    gap: 0.8rem;
    padding: 0.9rem 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
  }

  .hero-artifact__panel--story {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: start;
  }

  .hero-artifact__facts,
  .hero-artifact__outputs {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .hero-artifact__fact,
  .hero-artifact__output {
    display: grid;
    gap: 0.3rem;
  }

  .hero-artifact__fact dt,
  .hero-artifact__output span {
    color: rgba(255, 255, 255, 0.44);
  }

  .hero-artifact__fact dd,
  .hero-artifact__output strong {
    margin: 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  @media (max-width: 1240px) {
    .hero-artifact__readout {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .hero-artifact__panel--story {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-artifact__body {
      padding: 0.9rem;
    }

    .hero-artifact__header,
    .hero-artifact__readout,
    .hero-artifact__header-meta {
      grid-template-columns: 1fr;
      display: grid;
    }

    .hero-artifact__header {
      gap: 0.75rem;
    }

    .hero-artifact__header-meta {
      justify-content: start;
    }

    .hero-artifact__metric:last-child {
      display: none;
    }
  }
</style>
