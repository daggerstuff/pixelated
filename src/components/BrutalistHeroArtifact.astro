---
export interface Props {
  artifact: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const { artifact } = Astro.props
---

<aside class="hero-artifact" aria-label="Session review artifact">
  <div class="hero-artifact__rail">
    <div class="hero-artifact__rail-label">
      <span>{artifact.eyebrow}</span>
      <strong>{artifact.mode}</strong>
    </div>

    <div class="hero-artifact__readout">
      {artifact.readout.map((item) => (
        <div class="hero-artifact__metric">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </div>
  </div>

  <div class="hero-artifact__body">
    <div class="hero-artifact__header">
      <div class="hero-artifact__heading">
        <span class="hero-artifact__eyebrow">{artifact.chip}</span>
        <h2 class="hero-artifact__title">{artifact.status}</h2>
      </div>
      <span class="hero-artifact__mode">{artifact.mode}</span>
    </div>

    {artifact.image ? (
      <figure class="hero-artifact__figure">
        <div class="hero-artifact__figure-bar">
          <span>Session evidence</span>
          <span>Review lane attached</span>
        </div>
        <img
          src={artifact.image}
          alt={artifact.imageAlt || artifact.status}
          class="hero-artifact__image"
          loading="eager"
          decoding="async"
          width="1440"
          height="1200"
          srcset="/images/homepage/training-session-proof-640.png 640w, /images/homepage/training-session-proof-960.png 960w, /images/homepage/training-session-proof.png 1440w"
          sizes="(max-width: 768px) 92vw, (max-width: 1200px) 42vw, 560px"
        />
      </figure>
    ) : null}

    <div class="hero-artifact__detail-grid">
      <section class="hero-artifact__panel">
        <span class="hero-artifact__label">Why supervision teams can use this</span>
        <dl class="hero-artifact__facts">
          {artifact.context.map((item) => (
            <div class="hero-artifact__fact">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="hero-artifact__panel">
        <span class="hero-artifact__label">What stays attached to the run</span>
        <div class="hero-artifact__outputs">
          {artifact.outputs.map((item) => (
            <div class="hero-artifact__output">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</aside>

<style>
  .hero-artifact {
    display: grid;
    grid-template-columns: minmax(7rem, 7.75rem) minmax(0, 1fr);
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
      rgba(11, 15, 17, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 32px 80px rgba(0, 0, 0, 0.34);
    overflow: hidden;
  }

  .hero-artifact__rail {
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: 1rem 0.9rem;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(125, 211, 168, 0.14), rgba(125, 211, 168, 0) 30%),
      rgba(255, 255, 255, 0.02);
  }

  .hero-artifact__rail-label,
  .hero-artifact__eyebrow,
  .hero-artifact__label,
  .hero-artifact__metric span,
  .hero-artifact__fact dt,
  .hero-artifact__output span,
  .hero-artifact__figure-bar span,
  .hero-artifact__mode {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-artifact__rail-label {
    display: grid;
    gap: 0.45rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-artifact__rail-label strong {
    color: var(--accent-primary);
  }

  .hero-artifact__readout {
    display: grid;
    gap: 0.7rem;
  }

  .hero-artifact__metric {
    display: grid;
    gap: 0.35rem;
    padding: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-artifact__metric span {
    color: rgba(255, 255, 255, 0.46);
  }

  .hero-artifact__metric strong {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.84rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-artifact__body {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .hero-artifact__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-artifact__heading {
    display: grid;
    gap: 0.45rem;
    max-width: 22rem;
  }

  .hero-artifact__eyebrow,
  .hero-artifact__label {
    color: var(--accent-primary);
  }

  .hero-artifact__title {
    margin: 0;
    font-size: clamp(1.4rem, 1.1rem + 0.75vw, 1.95rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.94);
  }

  .hero-artifact__mode {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.55rem;
    border: 1px solid rgba(125, 211, 168, 0.3);
    color: rgba(255, 255, 255, 0.78);
    background: rgba(125, 211, 168, 0.08);
    white-space: nowrap;
  }

  .hero-artifact__figure {
    margin: 0;
    display: grid;
    gap: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(6, 9, 11, 0.9);
  }

  .hero-artifact__figure-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-artifact__figure-bar span {
    color: rgba(255, 255, 255, 0.54);
  }

  .hero-artifact__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
  }

  .hero-artifact__detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .hero-artifact__panel {
    display: grid;
    gap: 0.7rem;
    padding: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-artifact__facts,
  .hero-artifact__outputs {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .hero-artifact__fact,
  .hero-artifact__output {
    display: grid;
    gap: 0.3rem;
  }

  .hero-artifact__fact dt,
  .hero-artifact__output span {
    color: rgba(255, 255, 255, 0.44);
  }

  .hero-artifact__fact dd,
  .hero-artifact__output strong {
    margin: 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  @media (max-width: 1080px) {
    .hero-artifact {
      grid-template-columns: 1fr;
    }

    .hero-artifact__rail {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-artifact__readout {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .hero-artifact__body,
    .hero-artifact__rail {
      padding: 0.9rem;
    }

    .hero-artifact__header,
    .hero-artifact__detail-grid,
    .hero-artifact__readout {
      grid-template-columns: 1fr;
      display: grid;
    }

    .hero-artifact__header {
      gap: 0.75rem;
    }

    .hero-artifact__mode {
      justify-self: start;
    }
  }
</style>
