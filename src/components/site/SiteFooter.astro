---
export interface Props {
  showTopCTA?: boolean
}

const currentYear = new Date().getFullYear()
const { showTopCTA = true } = Astro.props
---

<footer class="marketing-footer">
  <div class="marketing-shell">
    {
      showTopCTA && (
        <div class="site-footer__cta">
          <div>
            <p class="site-footer__eyebrow">Pilot protocol</p>
            <h2>Make the hard cases replayable.</h2>
          </div>
          <a class="site-footer__button" href="/contact">Book a pilot</a>
        </div>
      )
    }

    <div class="site-footer__main">
      <a href="/" class="site-footer__brand" aria-label="Pixelated Empathy home">
        <img class="site-footer__logo-img" src="/favicon.svg" alt="" width="36" height="36" />
        <span>
          <strong>Pixelated Empathy</strong>
          <small>Clinical simulation infrastructure.</small>
        </span>
      </a>

      <nav class="site-footer__links" aria-label="Footer navigation">
        <span class="site-footer__link-row">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/accessibility">Accessibility</a>
        </span>
        <span class="site-footer__link-row">
          <a href="/features">Features</a>
          <a href="/demo-hub">Demo</a>
          <a href="/trust">Trust</a>
          <a href="/contact">Contact</a>
        </span>
      </nav>

      <div class="site-footer__meta">
        <p>&copy; {currentYear} Pixelated Empathy.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .marketing-footer {
    font-family: var(--font-sans);
    width: 100%;
    padding: clamp(1.25rem, 3vw, 2rem) 0 1.25rem;
    border-top: 1px solid var(--divider-weak);
    background: linear-gradient(180deg, rgba(23, 25, 29, 0.92), var(--bg-primary));
  }

  .marketing-footer .marketing-shell {
    max-width: min(74rem, calc(100vw - clamp(2rem, 7vw, 6rem)));
    width: 100%;
  }

  .site-footer__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    margin-bottom: 1.25rem;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.035);
  }

  .site-footer__eyebrow {
    margin: 0 0 0.3rem;
    color: var(--accent-primary-hover);
    font-family: var(--font-label);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-footer__cta h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2.5rem);
    line-height: 1;
  }

  .site-footer__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0 1rem;
    border-radius: var(--radius-full);
    background: var(--accent-primary);
    color: var(--text-inverse);
    font-weight: 850;
    text-decoration: none;
    transition:
      transform var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .site-footer__button:hover {
    transform: translateY(-2px);
    background: var(--accent-primary-hover);
  }

  .site-footer__main {
    display: grid;
    width: 100%;
    grid-template-columns: minmax(20rem, 1fr) auto minmax(20rem, 1fr);
    align-items: center;
    column-gap: clamp(1.5rem, 5vw, 4rem);
    padding: 1rem clamp(1rem, 3vw, 2.5rem);
  }

  .site-footer__brand {
    display: inline-flex;
    grid-column: 1;
    grid-row: 1;
    align-items: center;
    justify-content: flex-start;
    justify-self: center;
    gap: 0.75rem;
    color: var(--text-primary);
    text-decoration: none;
  }

  .site-footer__logo-img {
    display: block;
    width: 2.25rem !important;
    height: 2.25rem !important;
    max-width: 2.25rem !important;
    object-fit: contain;
    flex: 0 0 auto;
  }

  .site-footer__brand strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--text-primary);
  }

  .site-footer__brand small {
    display: block;
    margin-top: 0.12rem;
    color: var(--text-muted);
    font-size: 0.78rem;
  }

  .site-footer__links {
    display: flex;
    flex-direction: column;
    grid-column: 3;
    grid-row: 1;
    justify-content: center;
    justify-self: center;
    gap: 0.45rem;
    text-align: center;
  }

  .site-footer__link-row {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    white-space: nowrap;
  }

  .site-footer__links a {
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-footer__links a:hover {
    color: var(--text-primary);
  }

  .site-footer__meta {
    grid-column: 2;
    grid-row: 1;
    justify-self: center;
    color: var(--text-muted);
    text-align: center;
  }

  .site-footer__meta p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  @media (max-width: 960px) {
    .site-footer__main {
      grid-template-columns: 1fr;
      justify-items: center;
      row-gap: 0.9rem;
    }

    .site-footer__brand {
      grid-column: auto;
      grid-row: auto;
      justify-self: center;
    }

    .site-footer__links {
      grid-column: auto;
      grid-row: auto;
      justify-content: center;
      justify-self: center;
      max-width: 18rem;
      text-align: center;
    }

    .site-footer__meta {
      grid-column: auto;
      grid-row: auto;
    }

    .site-footer__cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 720px) {
    .marketing-footer {
      padding: 1.25rem 0;
    }
  }
</style>
