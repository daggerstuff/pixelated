---
const currentPath = Astro.url.pathname

const links = [
  { text: 'Features', href: '/features' },
  { text: 'Trust', href: '/trust' },
  { text: 'Company', href: '/company' },
  { text: 'Contact', href: '/contact' },
]
---

<header class="site-nav">
  <div class="site-nav__shell">
    <a href="/" class="site-nav__brand" aria-label="Pixelated Empathy home">
      <span class="site-nav__mark" aria-hidden="true">
        <img src="/favicon.svg" alt="" />
      </span>
      <span class="site-nav__brand-text">
        <span class="site-nav__name">Pixelated Empathy</span>
        <span class="site-nav__tag">AI practice clients</span>
      </span>
    </a>

    <nav class="site-nav__links" aria-label="Main navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'site-nav__link',
              currentPath === link.href && 'site-nav__link--active',
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.text}
          </a>
        ))
      }
    </nav>

    <div class="site-nav__actions">
      <a href="/demo-hub" class="site-nav__ghost">Watch demo</a>
      <a href="/contact" class="site-nav__cta">Book a pilot</a>
    </div>

    <button
      id="mobile-menu-button"
      class="site-nav__toggle"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div id="mobile-menu" class="site-nav__mobile hidden">
      <nav class="site-nav__mobile-content" aria-label="Mobile navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                'site-nav__mobile-link',
                currentPath === link.href && 'site-nav__mobile-link--active',
              ]}
            >
              {link.text}
            </a>
          ))
        }
        <a href="/demo-hub" class="site-nav__mobile-link">Watch demo</a>
        <a href="/contact" class="site-nav__mobile-cta">Book a pilot</a>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    inset: 1rem 1rem auto;
    z-index: 50;
    font-family: var(--font-sans);
  }

  .site-nav__shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(1rem, 2vw, 2rem);
    width: min(78rem, 100%);
    min-height: 4.25rem;
    margin-inline: auto;
    padding: 0.55rem 0.65rem 0.55rem 1rem;
    border: 1px solid var(--border-primary);
    border-radius: 1.1rem;
    background:
      linear-gradient(135deg, rgba(240, 163, 90, 0.12), rgba(246, 241, 232, 0.04)),
      rgba(23, 25, 29, 0.9);
    box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(22px);
  }

  .site-nav__brand,
  .site-nav__links,
  .site-nav__actions {
    min-width: 0;
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--text-primary);
    text-decoration: none;
  }

  .site-nav__mark {
    display: inline-flex;
    width: 2.25rem;
    height: 2.25rem;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .site-nav__mark img {
    display: block;
    width: 2.25rem;
    height: 2.25rem;
  }

  .site-nav__brand-text {
    display: grid;
    gap: 0.1rem;
    line-height: 1;
  }

  .site-nav__name {
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  .site-nav__tag {
    font-family: var(--font-label);
    color: var(--text-muted);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .site-nav__links {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.28rem;
    border: 1px solid var(--divider-weak);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.035);
  }

  .site-nav__link,
  .site-nav__ghost,
  .site-nav__cta,
  .site-nav__mobile-link,
  .site-nav__mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    border-radius: 0.7rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .site-nav__link {
    padding: 0 0.95rem;
    color: var(--text-secondary);
  }

  .site-nav__link:hover,
  .site-nav__link--active {
    color: var(--text-primary);
    background: var(--accent-primary-subtle);
  }

  .site-nav__actions {
    display: inline-flex;
    justify-content: flex-end;
    gap: 0.55rem;
  }

  .site-nav__ghost,
  .site-nav__cta {
    padding: 0 1rem;
  }

  .site-nav__ghost {
    border: 1px solid var(--border-primary);
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.035);
  }

  .site-nav__ghost:hover {
    transform: translateY(-1px);
    border-color: var(--border-strong);
    background: var(--accent-primary-subtle);
  }

  .site-nav__cta,
  .site-nav__mobile-cta {
    border: 1px solid rgba(240, 163, 90, 0.8);
    color: #111216;
    background: #f0a35a;
    box-shadow: 0 0 34px rgba(240, 163, 90, 0.24);
  }

  .site-nav__cta:hover,
  .site-nav__mobile-cta:hover {
    transform: translateY(-1px);
    background: #f6bd7c;
  }

  .site-nav__toggle {
    display: none;
    width: 2.85rem;
    height: 2.85rem;
    place-items: center;
    border: 1px solid var(--border-primary);
    border-radius: 0.8rem;
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
    cursor: pointer;
  }

  .site-nav__toggle span {
    grid-area: 1 / 1;
    width: 1rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  .site-nav__toggle span:nth-child(1) {
    transform: translateY(-5px);
  }

  .site-nav__toggle span:nth-child(3) {
    transform: translateY(5px);
  }

  .site-nav__mobile {
    grid-column: 1 / -1;
    padding-top: 0.65rem;
  }

  .site-nav__mobile-content {
    display: grid;
    gap: 0.45rem;
    padding: 0.75rem;
    border-top: 1px solid var(--divider-weak);
  }

  .site-nav__mobile-link,
  .site-nav__mobile-cta {
    width: 100%;
    padding: 0 1rem;
  }

  .site-nav__mobile-link {
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.035);
  }

  .site-nav__mobile-link:hover,
  .site-nav__mobile-link--active {
    color: var(--text-primary);
    background: var(--accent-primary-subtle);
  }

  @media (max-width: 980px) {
    .site-nav__shell {
      grid-template-columns: minmax(0, 1fr) auto;
      border-radius: var(--radius-xl);
    }

    .site-nav__links,
    .site-nav__actions {
      display: none;
    }

    .site-nav__toggle {
      display: grid;
    }
  }

  @media (max-width: 560px) {
    .site-nav {
      inset: 0.65rem 0.65rem auto;
    }

    .site-nav__shell {
      min-height: 3.75rem;
      padding: 0.48rem;
    }

    .site-nav__mark {
      width: 2rem;
      height: 2rem;
    }

    .site-nav__mark img {
      width: 2rem;
      height: 2rem;
    }

    .site-nav__tag {
      display: none;
    }

    .site-nav__name {
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button')
  const mobileMenu = document.getElementById('mobile-menu')

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      const isExpanded =
        mobileMenuButton.getAttribute('aria-expanded') === 'true'
      mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded))
      mobileMenu.classList.toggle('hidden')
    })
  }
</script>
