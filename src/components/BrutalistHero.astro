---
/**
 * Brutalist Hero Component
 * Balanced product-first homepage entry for the supervision workflow.
 */
import BrutalistHeroArtifact from '@/components/BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import HeroStage from '@/components/homepage/HeroStage.astro'
import HeroStatsBand from '@/components/homepage/HeroStatsBand.astro'
import { heroContent } from '@/lib/content/hero'

export interface Props {
  title?: string
  subtitle?: string
  proofPoints?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  stats?: readonly { value: string; label: string }[]
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const {
  title = heroContent.title,
  subtitle = heroContent.subtitle,
  proofPoints = heroContent.proofPoints,
  primaryCTA = heroContent.primaryCTA,
  secondaryCTA = heroContent.secondaryCTA,
  stats = heroContent.stats,
  artifact,
} = Astro.props

const artifactData = artifact ?? heroContent.artifact
const kicker = heroContent.kicker
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <div class="hero-backdrop"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="pe-page-shell hero-shell">
    <HeroStage>
      <div class="hero-layout">
        <div class="hero-copy">
          <div class="hero-prelude">
            <div class="hero-kicker-pill">
              <span class="hero-kicker-dot"></span>
              <span class="hero-kicker">{kicker}</span>
            </div>
            <span class="hero-case-index">Casefile 01</span>
          </div>

          <h1 class="hero-title">{title}</h1>

          <p class="hero-subtitle">{subtitle}</p>

          <ul class="hero-proof-grid" aria-label="Core proof" role="list">
            {proofPoints.map((item, index) => (
              <li class="hero-proof-card">
                <span class="hero-proof-card__index">{String(index + 1).padStart(2, '0')}</span>
                <p class="hero-proof-card__copy">{item}</p>
              </li>
            ))}
          </ul>

          <div class="hero-actions">
            <a href={primaryCTA.href} class="btn-premium">
              <span class="btn-premium__text">{primaryCTA.text}</span>
              <div class="btn-premium__fill"></div>
            </a>

            <a href={secondaryCTA.href} class="hero-secondary-link">
              <span class="hero-secondary-link__text">{secondaryCTA.text}</span>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="hero-secondary-link__icon"
                aria-hidden="true"
              >
                <path
                  d="M5 12H19M19 12L13 6M19 12L13 18"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"
                />
              </svg>
            </a>
          </div>

          <div class="hero-operator-note">
            <span class="hero-operator-note__label">Operating model</span>
            <p class="hero-operator-note__copy">
              Practice the difficult conversation, keep the transcript and notes in one evidence
              trail, then coach the retry from the exact turn that mattered.
            </p>
          </div>
        </div>

        <div class="hero-artifact-shell">
          <BrutalistHeroArtifact artifact={artifactData} />
        </div>
      </div>

      {
        stats && stats.length > 0 && (
          <HeroStatsBand stats={stats} />
        )
      }
    </HeroStage>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    min-height: clamp(24rem, 54vh, 34rem);
    padding: clamp(3.3rem, 5vh, 4.8rem) 0 clamp(2.2rem, 4vh, 3.4rem);
    background: var(--bg-void);
  }

  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.02),
        transparent 18%,
        transparent 84%,
        rgba(255, 255, 255, 0.02)
      ),
      radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.12) 100%);
    opacity: 0.22;
    pointer-events: none;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-void);
  }

  .hero-shell {
    max-width: 80rem;
    position: relative;
    z-index: 1;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(22rem, 1.06fr);
    gap: clamp(1.25rem, 2.5vw, 2.4rem);
    align-items: stretch;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 42rem;
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: 0.95rem;
    padding: clamp(0.8rem, 1.1vw, 1.1rem) 0;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(125, 211, 168, 0.24);
    background: rgba(125, 211, 168, 0.08);
  }

  .hero-kicker-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-kicker,
  .hero-secondary-link,
  .hero-proof-card__index,
  .hero-operator-note__label {
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .hero-kicker {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-case-index {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  .hero-title {
    max-width: 12ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 2rem + 1.2vw, 3.75rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.045em;
    color: var(--text-primary);
  }

  .hero-subtitle {
    max-width: 34rem;
    margin: 0;
    font-size: clamp(1rem, 0.96rem + 0.22vw, 1.12rem);
    line-height: 1.62;
    color: #E2E8F0;
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-proof-card {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
    padding: 0.82rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(125, 211, 168, 0.08), rgba(125, 211, 168, 0)),
      rgba(255, 255, 255, 0.035);
  }

  .hero-proof-card:last-child {
    grid-column: 1 / -1;
  }

  .hero-proof-card__index,
  .hero-operator-note__label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-proof-card__index {
    color: var(--accent-primary);
  }

  .hero-proof-card__copy {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.4;
    color: #F1F5F9;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 0.2rem;
  }

  .btn-premium {
    position: relative;
    padding: 0.88rem 1.45rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .btn-premium:hover {
    color: black;
  }

  .btn-premium__text {
    position: relative;
    z-index: 1;
  }

  .btn-premium__fill {
    position: absolute;
    inset: 0;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .btn-premium:hover .btn-premium__fill {
    transform: scaleX(1);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-secondary-link__text {
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link__icon {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover .hero-secondary-link__text {
    opacity: 1;
  }

  .hero-secondary-link:hover .hero-secondary-link__icon {
    transform: translateX(0.5rem);
  }

  .hero-operator-note {
    display: grid;
    gap: 0.45rem;
    max-width: 34rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-operator-note__label {
    color: rgba(255, 255, 255, 0.52);
  }

  .hero-operator-note__copy {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: #CBD5E1;
  }

  .hero-artifact-shell {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 8rem;
    background: linear-gradient(to top, var(--bg-void), transparent);
  }

  @media (max-width: 1080px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }

    .hero-copy,
    .hero-title,
    .hero-subtitle {
      max-width: none;
    }

    .hero-proof-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-proof-card:last-child {
      grid-column: auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 4.5rem;
      padding-bottom: 3rem;
    }

    .hero-shell,
    .hero-copy {
      max-width: 100%;
    }

    .hero-copy {
      gap: 1rem;
      padding: 0.6rem 0 0.7rem;
    }

    .hero-title {
      font-size: clamp(2.45rem, 8vw, 3.2rem);
    }

    .hero-subtitle {
      font-size: clamp(0.94rem, 3vw, 1rem);
    }

    .hero-proof-grid {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .hero-proof-card:last-child {
      grid-column: auto;
    }

    .btn-premium {
      padding: 0.75rem 1.5rem;
      font-size: 0.8rem;
    }

    .hero-secondary-link {
      font-size: 0.72rem;
    }

    .hero-operator-note {
      padding-top: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 4rem;
      padding-bottom: 2.5rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 10vw, 2.7rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-prelude {
      align-items: flex-start;
    }

    .btn-premium {
      width: 100%;
      text-align: center;
    }

    .hero-actions > a {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>
