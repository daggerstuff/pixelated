---
/**
 * Brutalist Hero Component
 * Balanced product-first homepage entry for the supervision workflow.
 */
import BrutalistHeroArtifact from '@/components/BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import HeroContent from '@/components/homepage/HeroContent.astro'
import HeroStage from '@/components/homepage/HeroStage.astro'
export interface Props {
  kicker?: string
  title?: string
  subtitle?: string
  proofPoints?: readonly { label: string; text: string }[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const {
  kicker,
  title,
  subtitle,
  proofPoints = [],
  primaryCTA,
  secondaryCTA,
  artifact,
} = Astro.props
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <div class="hero-backdrop"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="pe-page-shell hero-shell">
    <HeroStage>
      <div class="hero-layout">
        <HeroContent
          kicker={kicker}
          title={title}
          subtitle={subtitle}
          proofPoints={proofPoints}
          primaryCTA={primaryCTA}
          secondaryCTA={secondaryCTA}
        />

        {artifact && (
          <div class="hero-artifact-shell">
            <BrutalistHeroArtifact artifact={artifact} />
          </div>
        )}
      </div>
    </HeroStage>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    min-height: 100dvh;
    padding: clamp(6.2rem, 9vh, 8.6rem) 0 clamp(4.75rem, 7vh, 6.25rem);
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(143, 184, 162, 0.1),
        transparent 42%
      ),
      radial-gradient(
        circle at 50% 18%,
        rgba(255, 255, 255, 0.04),
        transparent 36%
      ),
      linear-gradient(
        180deg,
        rgba(8, 12, 13, 1) 0%,
        rgba(11, 16, 17, 0.98) 100%
      );
  }

  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacty='0.05'/%3E%3C/svg%3E");
    opacity: 0.04;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-void);
  }

  .hero-shell {
    max-width: 88rem;
    position: relative;
    z-index: 1;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.9rem, 3vw, 3rem);
    align-items: start;
    justify-items: center;
    position: relative;
    z-index: 1;
  }



  .hero-artifact-shell {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-width: 0;
    isolation: isolate;
    margin-top: 0;
    transform: none;
    width: 100%;
    max-width: 64rem;
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 7rem;
    background: linear-gradient(to top, var(--bg-primary), transparent);
  }

  @media (max-width: 1180px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .hero-artifact-shell {
      margin-top: 0;
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 5rem;
      padding-bottom: 4rem;
    }

    .hero-shell {
      max-width: 100%;
    }

    .hero-artifact-shell {
      margin-top: 0.2rem;
      max-height: none;
      overflow: visible;
    }

    .hero-artifact {
      max-height: none;
      overflow: visible;
    }

    .hero-artifact__image {
      max-height: 20rem;
      object-fit: contain;
    }

    .hero-background {
      opacity: 0.78;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 4.2rem;
      padding-bottom: 2.8rem;
    }
  }
</style>
