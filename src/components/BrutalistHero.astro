---
/**
 * Brutalist Hero Component
 * High-impact mission statement
 */
import BrutalistHeroArtifact from '@/components/BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import HeroStage from '@/components/homepage/HeroStage.astro'
import HeroStatsBand from '@/components/homepage/HeroStatsBand.astro'
import { heroContent } from '@/lib/content/hero'

export interface Props {
  title?: string
  subtitle?: string
  proofPoints?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  stats?: readonly { value: string; label: string }[]
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const {
  title = heroContent.title,
  subtitle = heroContent.subtitle,
  proofPoints = heroContent.proofPoints,
  primaryCTA = heroContent.primaryCTA,
  secondaryCTA = heroContent.secondaryCTA,
  stats = heroContent.stats,
  artifact,
} = Astro.props

const primaryAction = primaryCTA
const secondaryAction = secondaryCTA
const artifactData = artifact ?? heroContent.artifact
const kicker = heroContent.kicker
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <div class="hero-backdrop"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="pe-page-shell hero-shell">
    <HeroStage>
      <div class="hero-layout">
        <div class="hero-copy">
          <div class="hero-prelude">
            <div class="hero-kicker-pill">
              <span class="hero-kicker-dot"></span>
              <span class="hero-kicker">{kicker}</span>
            </div>
            <span class="hero-case-index">Casefile 01</span>
          </div>

          <h1 class="hero-title">
            {title}
          </h1>

          <p class="hero-subtitle">
            {subtitle}
          </p>

          <div class="hero-evidence-strip" aria-label="Core proof">
            {proofPoints.map((item) => (
              <span class="hero-evidence-pill">{item}</span>
            ))}
          </div>

          <div class="hero-actions">
            <a href={primaryAction.href} class="btn-premium">
              <span class="btn-premium__text">{primaryAction.text}</span>
              <div class="btn-premium__fill"></div>
            </a>

            <a
              href={secondaryAction.href}
              class="hero-secondary-link"
            >
              <span class="hero-secondary-link__text">{secondaryAction.text}</span>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="hero-secondary-link__icon"
              >
                <path
                  d="M5 12H19M19 12L13 6M19 12L13 18"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="hero-artifact-shell">
          <BrutalistHeroArtifact artifact={artifactData} />
        </div>
      </div>

      {
        stats && stats.length > 0 && (
          <HeroStatsBand stats={stats} />
        )
      }
    </HeroStage>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    min-height: clamp(24rem, 54vh, 34rem);
    padding: clamp(3.3rem, 5vh, 4.8rem) 0 clamp(2.2rem, 4vh, 3.4rem);
    background:
      radial-gradient(circle at top, rgba(125, 211, 168, 0.08), transparent 34%),
      linear-gradient(
        180deg,
        rgba(8, 12, 13, 0.92) 0%,
        rgba(8, 12, 13, 0.98) 100%
      );
  }

  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 18%, transparent 84%, rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.12) 100%);
    opacity: 0.22;
    pointer-events: none;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-void);
  }

  .btn-premium {
    position: relative;
    padding: 0.88rem 1.45rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .btn-premium:hover {
    color: black;
  }

  .btn-premium__text {
    position: relative;
    z-index: 1;
  }

  .btn-premium__fill {
    position: absolute;
    inset: 0;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .btn-premium:hover .btn-premium__fill {
    transform: scaleX(1);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 0.1rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    margin-bottom: 1rem;
    border: 1px solid rgba(125, 211, 168, 0.24);
    background: rgba(125, 211, 168, 0.08);
  }

  .hero-kicker-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-shell {
    max-width: 80rem;
    position: relative;
    z-index: 1;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 24rem);
    gap: clamp(1rem, 2.2vw, 2rem);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 39rem;
    position: relative;
    z-index: 1;
    padding:
      clamp(1rem, 1.4vw, 1.25rem)
      0
      clamp(1rem, 1.6vw, 1.25rem);
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .hero-case-index {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  .hero-title {
    max-width: 9ch;
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2.1rem + 2.2vw, 4.9rem);
    font-weight: 600;
    line-height: 0.94;
    letter-spacing: -0.06em;
    color: var(--text-primary);
  }

  .hero-subtitle {
    max-width: 28rem;
    margin: 0;
    font-size: clamp(0.98rem, 0.93rem + 0.18vw, 1.08rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.8);
  }

  .hero-evidence-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1rem 0 1rem;
  }

  .hero-evidence-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.45rem 0.68rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.74rem;
    line-height: 1.2;
  }

  .hero-kicker,
  .hero-secondary-link {
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .hero-kicker {
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-secondary-link__text {
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link__icon {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover .hero-secondary-link__text {
    opacity: 1;
  }

  .hero-secondary-link:hover .hero-secondary-link__icon {
    transform: translateX(0.5rem);
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 8rem;
    background: linear-gradient(to top, var(--bg-void), transparent);
  }
  .hero-artifact-shell {
    position: relative;
    z-index: 2;
    margin-right: 0;
    margin-bottom: 0;
  }

  @media (max-width: 1080px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }

    .hero-copy,
    .hero-title,
    .hero-subtitle {
      max-width: none;
    }

    .hero-artifact-shell {
      margin-right: 0;
      margin-bottom: 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 4.5rem;
      padding-bottom: 3rem;
    }

    .hero-shell,
    .hero-copy {
      max-width: 100%;
    }

    .hero-copy {
      padding: 0.6rem 0 0.7rem;
    }

    .hero-title {
      font-size: clamp(2.6rem, 9vw, 3.25rem);
    }

    .hero-subtitle {
      font-size: clamp(0.94rem, 3vw, 1rem);
    }

    .hero-evidence-strip {
      gap: 0.55rem;
      margin: 1.2rem 0 1.1rem;
    }

    .hero-evidence-pill {
      min-height: 2rem;
      padding: 0.45rem 0.7rem;
      font-size: 0.74rem;
    }

    .btn-premium {
      padding: 0.75rem 1.5rem;
      font-size: 0.8rem;
    }

    .hero-kicker-pill {
      margin-bottom: 1rem;
    }

    .hero-secondary-link {
      font-size: 0.72rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 4rem;
      padding-bottom: 2.5rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 10vw, 2.7rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-prelude {
      align-items: flex-start;
    }

    .btn-premium {
      width: 100%;
      text-align: center;
    }

    .hero-actions > a {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>
