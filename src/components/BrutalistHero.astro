---
/**
 * Brutalist Hero Component
 * High-impact mission statement
 */
import BrutalistHeroArtifact from './BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import { heroContent } from '@/lib/content/hero'

export interface Props {
  title?: string
  subtitle?: string
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  stats?: Array<{ value: string; label: string }>
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: Array<{ label: string; value: string }>
    outputs: Array<{ label: string; value: string }>
    readout: Array<{ label: string; value: string }>
  }
}

const {
  title = 'AI Roleplay Training for Therapists',
  subtitle = 'Practice difficult clinical conversations with realistic AI patients, structured feedback, and repeatable supervision workflows.',
  primaryCTA,
  secondaryCTA,
  stats,
  artifact,
} = Astro.props

const primaryAction = primaryCTA || { text: 'Start Practice', href: '/signup' }
const secondaryAction = secondaryCTA || { text: 'Watch Demo', href: '/demo-hub' }
const artifactData = artifact ?? heroContent.artifact
const kicker = heroContent.kicker
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <div class="hero-backdrop"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="pe-page-shell hero-shell">
    <div class="hero-layout">
      <div class="hero-copy">
        <div class="hero-kicker-pill">
          <span class="hero-kicker-dot"></span>
          <span class="hero-kicker">{kicker}</span>
        </div>

        <h1 class="hero-title">
          {title}
        </h1>

        <p class="hero-subtitle">
          {subtitle}
        </p>

        <div class="hero-actions">
          <a href={primaryAction.href} class="btn-premium">
            <span class="btn-premium__text">{primaryAction.text}</span>
            <div class="btn-premium__fill"></div>
          </a>

          <a
            href={secondaryAction.href}
            class="hero-secondary-link"
          >
            <span class="hero-secondary-link__text">{secondaryAction.text}</span>
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              class="hero-secondary-link__icon"
            >
              <path
                d="M5 12H19M19 12L13 6M19 12L13 18"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="square"></path>
            </svg>
          </a>
        </div>

        {
          stats && stats.length > 0 && (
          <div class="hero-stats">
              <div class="hero-stats-grid" aria-label="Proof points">
                {stats.map((stat) => (
                  <div class="stat-item">
                    <span class="stat-value">{stat.value}</span>
                    <span class="stat-label">{stat.label}</span>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <BrutalistHeroArtifact artifact={artifactData} />
    </div>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    min-height: clamp(40rem, 82vh, 52rem);
    padding: clamp(7rem, 10vh, 9rem) 0 clamp(4.5rem, 8vh, 6.5rem);
    background:
      radial-gradient(circle at top, rgba(125, 211, 168, 0.08), transparent 34%),
      linear-gradient(
        180deg,
        rgba(8, 12, 13, 0.92) 0%,
        rgba(8, 12, 13, 0.98) 100%
      );
  }

  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 18%, transparent 84%, rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.12) 100%);
    opacity: 0.22;
    pointer-events: none;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-void);
  }

  .btn-premium {
    position: relative;
    padding: 1rem 2rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .btn-premium:hover {
    color: black;
  }

  .btn-premium__text {
    position: relative;
    z-index: 1;
  }

  .btn-premium__fill {
    position: absolute;
    inset: 0;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .btn-premium:hover .btn-premium__fill {
    transform: scaleX(1);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.75rem;
    border: 1px solid rgba(125, 211, 168, 0.24);
    background: rgba(125, 211, 168, 0.08);
  }

  .hero-kicker-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-shell {
    max-width: 80rem;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.38fr) minmax(23rem, 27.5rem);
    gap: clamp(2rem, 4.2vw, 5rem);
    align-items: start;
  }

  .hero-copy {
    max-width: 50rem;
    padding-top: 0.5rem;
  }

  .hero-title {
    max-width: 14.5ch;
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 2.2rem + 1.8vw, 4.45rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: var(--text-primary);
  }

  .hero-subtitle {
    max-width: 42rem;
    margin: 0 0 2.25rem;
    font-size: clamp(1.06rem, 0.98rem + 0.3vw, 1.2rem);
    line-height: 1.68;
    color: var(--text-secondary);
  }

  .hero-kicker,
  .hero-secondary-link,
  .stat-label {
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .hero-kicker {
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-secondary-link__text {
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link__icon {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover .hero-secondary-link__text {
    opacity: 1;
  }

  .hero-secondary-link:hover .hero-secondary-link__icon {
    transform: translateX(0.5rem);
  }

  .hero-stats {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 8rem;
    background: linear-gradient(to top, var(--bg-void), transparent);
  }
  .hero-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: var(--space-8);
  }

  .stat-item {
    min-width: 0;
    display: grid;
    gap: 0.55rem;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.18rem, 1.06rem + 0.32vw, 1.42rem);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .stat-label {
    display: block;
    font-size: 0.82rem;
    line-height: 1.5;
    text-transform: none;
    letter-spacing: 0.01em;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 6rem;
      padding-bottom: 4rem;
    }

    .hero-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    .hero-shell,
    .hero-copy {
      max-width: 100%;
    }

    .hero-title {
      max-width: 11ch;
      font-size: clamp(2.2rem, 1.9rem + 1.6vw, 2.9rem);
    }

    .hero-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
