---
/**
 * Brutalist Hero Component
 * High-impact mission statement
 */
import BrutalistHeroArtifact from './BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import { heroContent } from '@/lib/content/hero'

export interface Props {
  title?: string
  subtitle?: string
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  stats?: Array<{ value: string; label: string }>
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    context: Array<{ label: string; value: string }>
    outputs: Array<{ label: string; value: string }>
    readout: Array<{ label: string; value: string }>
  }
}

const {
  title = 'AI Roleplay Training for Therapists',
  subtitle = 'Practice difficult clinical conversations with realistic AI patients, structured feedback, and repeatable supervision workflows.',
  primaryCTA,
  secondaryCTA,
  stats,
  artifact,
} = Astro.props

const primaryAction = primaryCTA || { text: 'Start Practice', href: '/signup' }
const secondaryAction = secondaryCTA || { text: 'Watch Demo', href: '/demo-hub' }
const reviewArtifact = artifact || heroContent.artifact
---

<section
  class="hero relative flex items-center overflow-hidden"
  data-component="brutalist-hero"
>
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-void"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="container relative z-10 hero-shell">
    <div class="hero-layout">
      <div class="hero-copy">
        <div
          class="hero-kicker-pill inline-flex items-center gap-2 px-3 py-1 rounded-full mb-7"
        >
          <span class="w-2 h-2 rounded-full bg-accent-primary"></span>
          <span class="hero-kicker">Clinical rehearsal for difficult therapeutic conversations</span>
        </div>

        <h1 class="hero-title">
          {title}
        </h1>

        <p class="hero-subtitle">
          {subtitle}
        </p>

        <div class="flex flex-wrap gap-6 items-center">
          <a href={primaryAction.href} class="btn-premium group">
            <span class="relative z-10">{primaryAction.text}</span>
            <div
              class="absolute inset-0 bg-accent-primary transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-normal"
            >
            </div>
          </a>

          <a
            href={secondaryAction.href}
            class="group hero-secondary-link flex items-center gap-2 text-white text-sm uppercase tracking-widest no-underline"
          >
            <span class="opacity-60 group-hover:opacity-100 transition-opacity">{secondaryAction.text}</span>
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              class="transform group-hover:translate-x-2 transition-transform"
            >
              <path
                d="M5 12H19M19 12L13 6M19 12L13 18"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="square"></path>
            </svg>
          </a>
        </div>

        {
          stats && stats.length > 0 && (
          <div
            class="stats-grid mt-16 pt-8"
            style="border-top: 1px solid rgba(255, 255, 255, 0.12);"
          >
              <div class="hero-stats-grid" aria-label="Proof points">
                {stats.map((stat) => (
                  <div class="stat-item">
                    <span class="stat-value">{stat.value}</span>
                    <span class="stat-label">{stat.label}</span>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <BrutalistHeroArtifact artifact={reviewArtifact} />
    </div>
  </div>

  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent"
  >
  </div>
</section>

<style>
  .hero {
    min-height: clamp(40rem, 82vh, 52rem);
    padding: clamp(7rem, 10vh, 9rem) 0 clamp(4.5rem, 8vh, 6.5rem);
    background:
      radial-gradient(circle at top, rgba(125, 211, 168, 0.08), transparent 34%),
      linear-gradient(
        180deg,
        rgba(8, 12, 13, 0.92) 0%,
        rgba(8, 12, 13, 0.98) 100%
      );
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 18%, transparent 84%, rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.12) 100%);
    opacity: 0.22;
    pointer-events: none;
  }

  .btn-premium {
    position: relative;
    padding: 1rem 2rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .btn-premium:hover {
    color: black;
  }

  .hero-kicker-pill {
    border: 1px solid rgba(125, 211, 168, 0.24);
    background: rgba(125, 211, 168, 0.08);
  }

  .hero-shell {
    max-width: 74rem;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.34fr) minmax(19rem, 23.5rem);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: start;
  }

  .hero-copy {
    max-width: 39rem;
    padding-top: 0.5rem;
  }

  .hero-title {
    max-width: 9.8ch;
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 2.1rem + 1.8vw, 4.1rem);
    font-weight: 600;
    line-height: 0.94;
    letter-spacing: -0.045em;
    color: var(--text-primary);
  }

  .hero-subtitle {
    max-width: 38rem;
    margin: 0 0 2.25rem;
    font-size: clamp(1.03rem, 0.96rem + 0.28vw, 1.18rem);
    line-height: 1.62;
    color: var(--text-secondary);
  }

  .hero-kicker,
  .hero-secondary-link,
  .stat-label {
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .hero-kicker {
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-secondary-link {
    font-size: 0.78rem;
  }

  .hero-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .stat-item {
    min-width: 0;
    display: grid;
    gap: 0.55rem;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.18rem, 1.06rem + 0.32vw, 1.42rem);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .stat-label {
    display: block;
    font-size: 0.72rem;
    line-height: 1.55;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 6rem;
      padding-bottom: 4rem;
    }

    .hero-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    .hero-shell,
    .hero-copy {
      max-width: 100%;
    }

    .hero-title {
      max-width: 11ch;
      font-size: clamp(2.2rem, 1.9rem + 1.6vw, 2.9rem);
    }

    .hero-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
