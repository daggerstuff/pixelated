---
/**
 * Brutalist Hero Component
 * High-impact mission statement
 */
export interface Props {
  title?: string;
  subtitle?: string;
  primaryCTA?: { text: string; href: string };
  secondaryCTA?: { text: string; href: string };
  ctaPrimary?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
  stats?: Array<{ value: string; label: string }>;
}

const {
  title = "Where Emotional Intelligence Meets Artificial Precision",
  subtitle = "Master complex therapeutic dialogues in high-fidelity, risk-free simulations. Transform difficult conversations into clinical mastery with the Empathy Gym™.",
  primaryCTA,
  secondaryCTA,
  ctaPrimary,
  ctaSecondary,
  stats,
} = Astro.props;

// Support both prop naming conventions
const primaryAction = primaryCTA || ctaPrimary || { text: "Enter the Gym", href: "/training" };
const secondaryAction = secondaryCTA || ctaSecondary || { text: "Explore Intelligence", href: "/ai-engine" };
---

<section class="hero relative min-h-screen flex items-center pt-20 overflow-hidden" data-component="brutalist-hero">
  <!-- Background Layer -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-void"></div>
    <div class="absolute inset-0 opacity-40 mix-blend-screen grayscale hover:grayscale-0 transition-all duration-ultra brightness-50">
      <img src="/assets/hero-bg.png" alt="Empathy Gym Background" class="w-full h-full object-cover" />
    </div>
<!-- Grain/Noise Overlay -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.1) 100%);"></div>
    <!-- Radial Focal Glow -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(0,255,136,0.05)_0%,transparent_70%)]"></div>
  </div>

  <div class="container relative z-10">
    <div class="max-w-4xl">
      <!-- Tag/Status -->
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-accent-primary-glow border border-accent-primary-dim rounded-full mb-8 animate-pulse-soft">
        <span class="w-2 h-2 rounded-full bg-accent-primary"></span>
        <span class="text-[10px] font-mono uppercase tracking-widest text-accent-primary">Intelligence Engine Active // v2.4.0</span>
      </div>

      <h1 class="font-display font-black text-6xl md:text-8xl leading-tight mb-8 tracking-tighter text-white">
        Architecting <span class="text-accent-primary">Empathy</span><br />
        in the <span class="stark-outline">Code.</span>
      </h1>

      <p class="text-xl md:text-2xl text-secondary max-w-2xl mb-12 leading-relaxed font-light">
        {subtitle}
      </p>

      <div class="flex flex-wrap gap-6 items-center">
        <a href={primaryAction.href} class="btn-premium group">
          <span class="relative z-10">{primaryAction.text}</span>
          <div class="absolute inset-0 bg-accent-primary transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-normal"></div>
        </a>

        <a href={secondaryAction.href} class="group flex items-center gap-2 text-white font-mono text-sm uppercase tracking-widest no-underline">
          <span class="opacity-60 group-hover:opacity-100 transition-opacity">{secondaryAction.text}</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="transform group-hover:translate-x-2 transition-transform">
            <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </a>
      </div>

      <!-- Stats Section -->
      {stats && stats.length > 0 && (
        <div class="stats-grid mt-16 pt-8" style="border-top: var(--border-primary);">
          <div class="grid grid-cols-3 gap-8">
            {stats.map((stat) => (
              <div class="stat-item text-center md:text-left">
                <span class="stat-value font-display font-black text-4xl md:text-5xl text-accent-primary block">{stat.value}</span>
                <span class="stat-label mt-2 font-mono text-xs uppercase tracking-widest text-secondary block">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Perspective Grid Footer -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent"></div>
</section>

<style>
  .stark-outline {
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
    color: transparent;
  }
  
  .btn-premium {
    position: relative;
    padding: 1.25rem 2.5rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }
  
  .btn-premium:hover {
    color: black;
  }
</style>

