---
/**
 * Brutalist Hero Component
 * High-impact mission statement
 */
export interface Props {
  title?: string
  subtitle?: string
  ctaPrimary?: { text: string; href: string }
  ctaSecondary?: { text: string; href: string }
  stats?: Array<{ value: string; label: string }>
}

const {
  title = 'AI Roleplay Training for Therapists',
  subtitle = 'Practice difficult clinical conversations with realistic AI patients, structured feedback, and repeatable supervision workflows.',
  ctaPrimary = { text: 'Enter the Gym', href: '/training' },
  ctaSecondary = { text: 'Explore Intelligence', href: '/ai-engine' },
  stats,
} = Astro.props

const primaryAction = ctaPrimary
const secondaryAction = ctaSecondary
---

<section
  class="hero relative flex items-center overflow-hidden"
  data-component="brutalist-hero"
>
  <!-- Background Layer -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-void"></div>
    <div class="hero-atmosphere absolute inset-0 opacity-80">
      <div class="hero-atmosphere__glow hero-atmosphere__glow--left"></div>
      <div class="hero-atmosphere__glow hero-atmosphere__glow--right"></div>
      <div class="hero-atmosphere__grid"></div>
      <div class="hero-atmosphere__scanline"></div>
    </div>
    <!-- Grain/Noise Overlay -->
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style="background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.1) 100%);"
    >
    </div>
    <!-- Radial Focal Glow -->
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(0,255,136,0.05)_0%,transparent_70%)]"
    >
    </div>
  </div>

  <div class="container relative z-10 hero-shell">
    <div class="hero-copy">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 bg-accent-primary-glow border border-accent-primary-dim rounded-full mb-8"
      >
        <span class="w-2 h-2 rounded-full bg-accent-primary"></span>
        <span
          class="text-[10px] font-mono uppercase tracking-widest text-accent-primary"
          >Clinical Simulation System // Pixelated Empathy</span
        >
      </div>

      <h1 class="hero-title">{title}</h1>

      <p class="hero-subtitle">{subtitle}</p>

      <div class="hero-actions">
        <a href={primaryAction.href} class="btn-premium group">
          <span class="relative z-10">{primaryAction.text}</span>
          <div
            class="absolute inset-0 bg-accent-primary transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-normal"
          >
          </div>
        </a>

        <a href={secondaryAction.href} class="hero-link group">
          <span class="hero-link__label">{secondaryAction.text}</span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            class="transform group-hover:translate-x-2 transition-transform"
          >
            <path
              d="M5 12H19M19 12L13 6M19 12L13 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="square"></path>
          </svg>
        </a>
      </div>

      {
        stats && stats.length > 0 && (
          <div class="stats-grid">
            {stats.map((stat) => (
              <div class="stat-item">
                <span class="stat-value">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        )
      }
    </div>

    <aside class="hero-visual-panel" aria-label="Platform preview">
      <div class="hero-visual-panel__frame">
        <div class="hero-visual-panel__header">
          <span class="hero-visual-panel__eyebrow">Live Simulation</span>
          <span class="hero-visual-panel__status">Risk cues active</span>
        </div>

        <div class="hero-transcript">
          <div class="hero-bubble hero-bubble--patient">
            "I keep telling everyone I'm fine because I do not want them to make
            this bigger than it already is."
          </div>
          <div class="hero-bubble hero-bubble--clinician">
            "You do not have to minimize this with me. I want to understand how
            unsafe it feels right now."
          </div>
          <div class="hero-bubble hero-bubble--system">
            Feedback: reflected avoidance, named risk gently, kept the pace
            contained.
          </div>
        </div>

        <div class="hero-metrics">
          <div class="hero-metric">
            <span class="hero-metric__label">Empathy</span>
            <strong>91</strong>
          </div>
          <div class="hero-metric">
            <span class="hero-metric__label">Pacing</span>
            <strong>88</strong>
          </div>
          <div class="hero-metric">
            <span class="hero-metric__label">Risk detection</span>
            <strong>94</strong>
          </div>
        </div>
      </div>
    </aside>
  </div>
  </div>

  <!-- Perspective Grid Footer -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent"
  >
  </div>
</section>

<style>
  .hero {
    min-height: clamp(42rem, 82svh, 54rem);
    padding: clamp(6rem, 10vw, 8rem) 0 clamp(3.5rem, 6vw, 5rem);
    background:
      radial-gradient(circle at top, rgba(34, 197, 94, 0.08), transparent 36%),
      linear-gradient(
        180deg,
        rgba(2, 6, 23, 0.88) 0%,
        rgba(2, 6, 23, 0.97) 100%
      );
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
  }

  .hero-copy {
    max-width: 42rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 7vw, 6.75rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.06em;
    margin: 0 0 1.5rem;
    max-width: 11ch;
    text-wrap: balance;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 1rem + 0.5vw, 1.45rem);
    color: var(--text-secondary);
    max-width: 38rem;
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
    margin-bottom: 2.5rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: white;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-link__label {
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .hero-link:hover .hero-link__label {
    opacity: 1;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: var(--border-primary);
  }

  .stat-item {
    min-width: 0;
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2vw, 2.4rem);
    font-weight: 700;
    color: var(--accent-primary);
    letter-spacing: -0.05em;
  }

  .stat-label {
    display: block;
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
  }

  .hero-visual-panel {
    position: relative;
  }

  .hero-visual-panel__frame {
    position: relative;
    padding: 1.35rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(5, 10, 15, 0.88);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .hero-visual-panel__frame::before {
    content: '';
    position: absolute;
    inset: -1px;
    border: 1px solid rgba(0, 255, 136, 0.16);
    pointer-events: none;
    transform: translate(0.65rem, 0.65rem);
    opacity: 0.6;
  }

  .hero-visual-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .hero-visual-panel__eyebrow {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.72rem;
  }

  .hero-visual-panel__status {
    color: var(--accent-primary);
    font-size: 0.68rem;
  }

  .hero-transcript {
    display: grid;
    gap: 0.85rem;
  }

  .hero-bubble {
    padding: 0.95rem 1rem;
    font-size: 0.96rem;
    line-height: 1.55;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-bubble--patient {
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.88);
    margin-right: 2rem;
  }

  .hero-bubble--clinician {
    background: rgba(0, 255, 136, 0.08);
    color: white;
    margin-left: 1.4rem;
  }

  .hero-bubble--system {
    background: rgba(56, 189, 248, 0.08);
    color: rgba(255, 255, 255, 0.82);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .hero-metric {
    padding-top: 0.9rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-metric strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    letter-spacing: -0.05em;
    color: white;
  }

  .hero-metric__label {
    display: block;
    margin-bottom: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.55);
  }

  .hero-atmosphere {
    overflow: hidden;
  }

  .hero-atmosphere__glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(90px);
    opacity: 0.55;
    transform: translateZ(0);
  }

  .hero-atmosphere__glow--left {
    top: 8%;
    left: -8%;
    width: min(44rem, 60vw);
    height: min(44rem, 60vw);
    background: radial-gradient(
      circle,
      rgba(16, 185, 129, 0.24) 0%,
      rgba(16, 185, 129, 0.08) 42%,
      transparent 72%
    );
  }

  .hero-atmosphere__glow--right {
    right: -6%;
    bottom: 4%;
    width: min(40rem, 52vw);
    height: min(40rem, 52vw);
    background: radial-gradient(
      circle,
      rgba(56, 189, 248, 0.18) 0%,
      rgba(14, 165, 233, 0.08) 45%,
      transparent 74%
    );
  }

  .hero-atmosphere__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.1) 1px, transparent 1px);
    background-position: center center;
    background-size: 72px 72px;
    mask-image: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 0.9),
      transparent 82%
    );
    opacity: 0.16;
  }

  .hero-atmosphere__scanline {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.05),
        transparent 22%,
        transparent 78%,
        rgba(255, 255, 255, 0.03)
      ),
      repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.035) 0,
        rgba(255, 255, 255, 0.035) 1px,
        transparent 1px,
        transparent 4px
      );
    opacity: 0.08;
    mix-blend-mode: soft-light;
  }

  .stark-outline {
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
    color: transparent;
  }

  .btn-premium {
    position: relative;
    padding: 1.25rem 2.5rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .btn-premium:hover {
    color: black;
  }

  @media (max-width: 960px) {
    .hero-shell {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: none;
    }

    .hero-title {
      max-width: none;
    }

    .hero-visual-panel {
      max-width: 38rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .hero-atmosphere__grid {
      background-size: 44px 44px;
      opacity: 0.11;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-link {
      justify-content: space-between;
    }

    .stats-grid,
    .hero-metrics {
      grid-template-columns: 1fr;
    }

    .hero-bubble--patient,
    .hero-bubble--clinician {
      margin-left: 0;
      margin-right: 0;
    }

    .hero-visual-panel__frame::before {
      transform: translate(0.35rem, 0.35rem);
    }
  }
</style>
