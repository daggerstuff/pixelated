---
/**
 * Brutalist Hero Component
 * Balanced product-first homepage entry for the supervision workflow.
 */
import BrutalistHeroArtifact from '@/components/BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import HeroStage from '@/components/homepage/HeroStage.astro'
import { heroContent } from '@/lib/content/hero'

export interface Props {
  title?: string
  subtitle?: string
  proofPoints?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const {
  title = heroContent.title,
  subtitle = heroContent.subtitle,
  proofPoints = heroContent.proofPoints,
  primaryCTA = heroContent.primaryCTA,
  secondaryCTA = heroContent.secondaryCTA,
  artifact,
} = Astro.props

const artifactData = artifact ?? heroContent.artifact
const kicker = heroContent.kicker
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <div class="hero-backdrop"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="pe-page-shell hero-shell">
    <HeroStage>
      <div class="hero-layout">
        <div class="hero-copy">
          <div class="hero-prelude">
            <div class="hero-kicker-pill">
              <span class="hero-kicker-dot"></span>
              <span class="hero-kicker">{kicker}</span>
            </div>
          </div>

          <h1 class="hero-title">{title}</h1>

          <p class="hero-subtitle">{subtitle}</p>

          <ul class="hero-proof-grid" aria-label="Core proof" role="list">
            {
              proofPoints.map((item, index) => (
                <li class="hero-proof-card" tabindex="0">
                  <span class="hero-proof-card__index">
                    {index === 0 ? 'Who it serves' : 'What changes'}
                  </span>
                  <p class="hero-proof-card__copy">{item}</p>
                </li>
              ))
            }
          </ul>

          <div class="hero-actions">
            <a href={primaryCTA.href} class="btn-premium" role="button">
              <span class="btn-premium__text">{primaryCTA.text}</span>
              <div class="btn-premium__fill"></div>
            </a>

            <a href={secondaryCTA.href} class="hero-secondary-link">
              <span class="hero-secondary-link__text">{secondaryCTA.text}</span>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="hero-secondary-link__icon"
                aria-hidden="true"
              >
                <path
                  d="M5 12H19M19 12L13 6M19 12L13 18"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="hero-artifact-shell">
          <BrutalistHeroArtifact artifact={artifactData} />
        </div>
      </div>
    </HeroStage>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    min-height: clamp(40rem, 92dvh, 53rem);
    padding: clamp(5.2rem, 10vh, 7.6rem) 0 clamp(4rem, 7vh, 5.8rem);
    background:
      radial-gradient(circle at 12% 16%, rgba(143, 184, 162, 0.13), transparent 28%),
      radial-gradient(circle at 88% 18%, rgba(240, 236, 226, 0.05), transparent 22%),
      linear-gradient(
        180deg,
        rgba(7, 17, 18, 1) 0%,
        rgba(10, 19, 20, 0.985) 54%,
        rgba(9, 17, 18, 1) 100%
      );
  }

  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.02),
        transparent 18%,
        transparent 84%,
        rgba(255, 255, 255, 0.02)
      ),
      radial-gradient(
        circle at center,
        transparent 0%,
        rgba(0, 0, 0, 0.12) 100%
      );
    opacity: 0.22;
    pointer-events: none;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-void);
  }

  .hero-shell {
    max-width: 86rem;
    position: relative;
    z-index: 1;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(28rem, 1.1fr);
    gap: clamp(3rem, 5vw, 6rem);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 38rem;
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: 1.8rem;
    padding: clamp(1.8rem, 3.2vw, 3rem) 0 0;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(143, 184, 162, 0.22);
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.14),
        rgba(143, 184, 162, 0.05)
      ),
      rgba(255, 255, 255, 0.02);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 18px 38px rgba(4, 11, 12, 0.18);
  }

  .hero-kicker-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-kicker,
  .hero-secondary-link,
  .hero-proof-card__index,
  .hero-operator-note__label {
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: none;
    color: var(--accent-primary);
    opacity: 0.88;
  }

  .hero-title {
    max-width: 10ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2.25rem + 2.3vw, 4.9rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.065em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .hero-subtitle {
    max-width: 34rem;
    margin: 0;
    font-size: clamp(1.04rem, 0.98rem + 0.24vw, 1.18rem);
    line-height: 1.78;
    color: var(--text-secondary);
    text-wrap: pretty;
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
    max-width: 37rem;
  }

  .hero-proof-card {
    display: grid;
    gap: 0.6rem;
    min-width: 0;
    padding: 1.2rem 1.2rem 1.25rem;
    border-radius: 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.13),
        rgba(143, 184, 162, 0.04)
      ),
      rgba(255, 255, 255, 0.03);
    box-shadow: var(--shadow-panel);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .hero-proof-card:hover {
    border-color: rgba(143, 184, 162, 0.32);
    background:
      linear-gradient(
        180deg,
        rgba(143, 184, 162, 0.16),
        rgba(143, 184, 162, 0.05)
      ),
      rgba(255, 255, 255, 0.05);
    transform: translateY(-4px);
    box-shadow: 0 28px 62px rgba(2, 8, 9, 0.42);
  }

  .hero-proof-card:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  .hero-proof-card__index,
  .hero-operator-note__label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: none;
  }

  .hero-proof-card__index {
    color: var(--accent-primary);
  }

  .hero-proof-card__copy {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.62;
    color: var(--text-primary);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.2rem;
    align-items: center;
    margin-top: 0.35rem;
  }

  .btn-premium {
    position: relative;
    padding: 1rem 1.55rem;
    background: rgba(12, 18, 17, 0.58);
    border: 1px solid var(--accent-primary);
    border-radius: 1.05rem;
    color: #09110e;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.01em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    box-shadow: 0 18px 42px rgba(143, 184, 162, 0.2);
    transition:
      color 0.3s ease,
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .btn-premium:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
  }

  .btn-premium:hover {
    color: #09110e;
    transform: translateY(-2px);
    box-shadow: 0 24px 52px rgba(143, 184, 162, 0.24);
  }

  .btn-premium:active {
    transform: translateY(1px) scale(0.99);
  }

  .btn-premium__text {
    position: relative;
    z-index: 1;
  }

  .btn-premium__fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      var(--accent-secondary),
      var(--accent-primary) 42%,
      var(--accent-primary-dim)
    );
    transform: scaleX(1);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    padding-bottom: 0.15rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .hero-secondary-link:hover {
    text-decoration: none;
    border-bottom-color: rgba(143, 184, 162, 0.4);
    color: var(--text-primary);
  }

  .hero-secondary-link:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .hero-secondary-link__text {
    opacity: 0.85;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link__icon {
    width: 1rem;
    height: 1rem;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover .hero-secondary-link__text {
    opacity: 1;
  }

  .hero-secondary-link:hover .hero-secondary-link__icon {
    transform: translateX(0.5rem);
  }

  .hero-artifact-shell {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    min-width: 0;
    isolation: isolate;
    margin-top: clamp(2rem, 4vw, 4rem);
    transform: translateY(clamp(0.4rem, 1vw, 1rem));
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 7rem;
    background: linear-gradient(to top, var(--bg-primary), transparent);
  }

  @media (max-width: 1180px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .hero-copy,
    .hero-title,
    .hero-subtitle {
      max-width: none;
    }

    .hero-proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-artifact-shell {
      margin-top: 0;
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 4.8rem;
      padding-bottom: 3.1rem;
    }

    .hero-shell,
    .hero-copy {
      max-width: 100%;
    }

    .hero-copy {
      gap: 1.15rem;
      padding: 0.35rem 0 0.7rem;
    }

    .hero-title {
      font-size: clamp(2.55rem, 8vw, 3.35rem);
    }

    .hero-subtitle {
      font-size: clamp(1rem, 3vw, 1.08rem);
    }

    .hero-proof-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .hero-artifact-shell {
      margin-top: 0.2rem;
      max-height: 60vh;
      overflow: hidden;
    }

    .hero-artifact {
      max-height: 60vh;
      overflow: auto;
    }

    .hero-artifact__image {
      max-height: 20rem;
      object-fit: contain;
    }

    .btn-premium {
      padding: 0.9rem 1.35rem;
      font-size: 0.84rem;
    }

    .hero-secondary-link {
      font-size: 0.82rem;
    }

    .hero-background {
      opacity: 0.78;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 4.2rem;
      padding-bottom: 2.8rem;
    }

    .hero-title {
      font-size: clamp(2.25rem, 12vw, 2.85rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-prelude {
      align-items: flex-start;
      justify-content: flex-start;
    }

    .hero-title {
      max-width: 18ch;
    }

    .btn-premium {
      width: 100%;
      text-align: center;
    }

    .hero-actions > a {
      width: 100%;
      justify-content: flex-start;
      text-align: left;
    }

    .btn-premium {
      text-align: center;
    }

    .hero-secondary-link {
      justify-content: center;
      text-align: center;
    }
  }
</style>
