---
/**
 * Brutalist Hero Component
 * Balanced product-first homepage entry for the supervision workflow.
 */
import BrutalistHeroArtifact from '@/components/BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import HeroContent from '@/components/homepage/HeroContent.astro'
import HeroStage from '@/components/homepage/HeroStage.astro'
export interface Props {
  kicker?: string
  title?: string
  subtitle?: string
  helperText?: string
  proofPoints?: readonly { label: string; text: string }[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const {
  kicker,
  title,
  subtitle,
  helperText,
  proofPoints = [],
  primaryCTA,
  secondaryCTA,
  artifact,
} = Astro.props
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <HeroAtmosphere />
  </div>


  <div class="container hero-shell">

    <HeroStage>
      <div class="hero-layout">
        <HeroContent
          kicker={kicker}
          title={title}
          subtitle={subtitle}
          helperText={helperText}
          proofPoints={proofPoints}
          primaryCTA={primaryCTA}
          secondaryCTA={secondaryCTA}
        />

        {artifact && (
          <div class="hero-artifact-shell">
            <BrutalistHeroArtifact artifact={artifact} />
          </div>
        )}
      </div>
    </HeroStage>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    min-height: 80dvh;
    padding: clamp(6.2rem, 9vh, 8.6rem) 0 clamp(4.75rem, 7vh, 6.25rem);
    background: var(--bg-primary);
  }


  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }






  .hero-shell {
    position: relative;
    z-index: 1;
  }


  .hero-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.9rem, 3vw, 3rem);
    align-items: start;
    justify-items: center;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1181px) {
    .hero-layout {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
      align-items: center;
      justify-items: stretch;
    }
  }



  .hero-artifact-shell {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-width: 0;
    isolation: isolate;
    margin-top: 0;
    transform: none;
    width: 100%;
    max-width: 64rem;
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 7rem;
    background: linear-gradient(to top, var(--bg-primary), transparent);
  }

  @media (max-width: 1180px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .hero-artifact-shell {
      margin-top: 0;
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 5rem;
      padding-bottom: 4rem;
    }

    .hero-shell {
      max-width: 100%;
    }

    .hero-artifact-shell {
      margin-top: 0.2rem;
      max-height: none;
      overflow: visible;
    }

    .hero-artifact {
      max-height: none;
      overflow: visible;
    }

    .hero-artifact__image {
      max-height: 20rem;
      object-fit: contain;
    }

    .hero-background {
      opacity: 0.78;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 4.2rem;
      padding-bottom: 2.8rem;
    }
  }
</style>
