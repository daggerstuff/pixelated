---
/**
 * Brutalist Hero Component
 * Balanced product-first homepage entry for the supervision workflow.
 */
import BrutalistHeroArtifact from '@/components/BrutalistHeroArtifact.astro'
import HeroAtmosphere from '@/components/homepage/HeroAtmosphere.astro'
import HeroStage from '@/components/homepage/HeroStage.astro'
import { heroContent } from '@/lib/content/hero'

export interface Props {
  title?: string
  subtitle?: string
  proofPoints?: readonly string[]
  primaryCTA?: { text: string; href: string }
  secondaryCTA?: { text: string; href: string }
  artifact?: {
    eyebrow: string
    status: string
    chip: string
    mode: string
    image?: string
    imageAlt?: string
    context: readonly { label: string; value: string }[]
    outputs: readonly { label: string; value: string }[]
    readout: readonly { label: string; value: string }[]
  }
}

const {
  title = heroContent.title,
  subtitle = heroContent.subtitle,
  proofPoints = heroContent.proofPoints,
  primaryCTA = heroContent.primaryCTA,
  secondaryCTA = heroContent.secondaryCTA,
  artifact,
} = Astro.props

const artifactData = artifact ?? heroContent.artifact
const kicker = heroContent.kicker
---

<section class="hero hero-section" data-component="brutalist-hero">
  <div class="hero-background">
    <div class="hero-backdrop"></div>
    <HeroAtmosphere />
    <div class="hero-surface-noise"></div>
  </div>

  <div class="pe-page-shell hero-shell">
    <HeroStage>
      <div class="hero-layout">
        <div class="hero-copy">
          <div class="hero-prelude">
            <div class="hero-kicker-pill">
              <span class="hero-kicker-dot"></span>
              <span class="hero-kicker">{kicker}</span>
            </div>
          </div>

          <h1 class="hero-title">{title}</h1>

          <p class="hero-subtitle">{subtitle}</p>

          <ul class="hero-proof-grid" aria-label="Core proof" role="list">
            {
              proofPoints.map((item, index) => (
                <li class="hero-proof-card" tabindex="0">
                  <span class="hero-proof-card__index">
                    {index === 0 ? 'For' : 'Outcome'}
                  </span>
                  <p class="hero-proof-card__copy">{item}</p>
                </li>
              ))
            }
          </ul>

          <div class="hero-actions">
            <a href={primaryCTA.href} class="btn-premium" role="button">
              <span class="btn-premium__text">{primaryCTA.text}</span>
              <div class="btn-premium__fill"></div>
            </a>

            <a href={secondaryCTA.href} class="hero-secondary-link">
              <span class="hero-secondary-link__text">{secondaryCTA.text}</span>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="hero-secondary-link__icon"
                aria-hidden="true"
              >
                <path
                  d="M5 12H19M19 12L13 6M19 12L13 18"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="hero-artifact-shell">
          <BrutalistHeroArtifact artifact={artifactData} />
        </div>
      </div>
    </HeroStage>
  </div>

  <div class="hero-fadeout"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    min-height: clamp(25rem, 58vh, 37rem);
    padding: clamp(3.8rem, 6.4vh, 5.4rem) 0 clamp(2rem, 4vh, 2.8rem);
    background: var(--bg-void);
  }

  .hero-section {
    border-top: 0;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-surface-noise {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.02),
        transparent 18%,
        transparent 84%,
        rgba(255, 255, 255, 0.02)
      ),
      radial-gradient(
        circle at center,
        transparent 0%,
        rgba(0, 0, 0, 0.12) 100%
      );
    opacity: 0.22;
    pointer-events: none;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-void);
  }

  .hero-shell {
    max-width: 80rem;
    position: relative;
    z-index: 1;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(24rem, 1.1fr);
    gap: clamp(2rem, 4vw, 4.6rem);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 34rem;
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: 1.25rem;
    padding: clamp(1rem, 1.8vw, 1.5rem) 0;
  }

  .hero-prelude {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-kicker-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(125, 211, 168, 0.24);
    background: rgba(125, 211, 168, 0.08);
  }

  .hero-kicker-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent-primary);
  }

  .hero-kicker,
  .hero-secondary-link,
  .hero-proof-card__index,
  .hero-operator-note__label {
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .hero-kicker {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .hero-title {
    max-width: 18ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.7rem, 2.1rem + 2vw, 4.5rem);
    font-weight: 600;
    line-height: 0.94;
    letter-spacing: -0.05em;
    color: var(--text-primary);
  }

  .hero-subtitle {
    max-width: 26rem;
    margin: 0;
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.16rem);
    line-height: 1.72;
    color: #e2e8f0;
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-proof-card {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
    padding: 0.9rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(
        180deg,
        rgba(125, 211, 168, 0.12),
        rgba(125, 211, 168, 0.02)
      ),
      rgba(255, 255, 255, 0.025);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .hero-proof-card:hover {
    border-color: rgba(125, 211, 168, 0.25);
    background:
      linear-gradient(
        180deg,
        rgba(125, 211, 168, 0.18),
        rgba(125, 211, 168, 0.04)
      ),
      rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  .hero-proof-card:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  .hero-proof-card__index,
  .hero-operator-note__label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-proof-card__index {
    color: var(--accent-primary);
  }

  .hero-proof-card__copy {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.44;
    color: #f1f5f9;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
    margin-top: 0.35rem;
  }

  .btn-premium {
    position: relative;
    padding: 0.88rem 1.45rem;
    background: transparent;
    border: 1px solid var(--accent-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .btn-premium:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
  }

  .btn-premium:hover {
    color: black;
  }

  .btn-premium__text {
    position: relative;
    z-index: 1;
  }

  .btn-premium__fill {
    position: absolute;
    inset: 0;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .btn-premium:hover .btn-premium__fill {
    transform: scaleX(1);
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-secondary-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(125, 211, 168, 0.4);
  }

  .hero-secondary-link:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .hero-secondary-link__text {
    opacity: 0.85;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link__icon {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .hero-secondary-link:hover .hero-secondary-link__text {
    opacity: 1;
  }

  .hero-secondary-link:hover .hero-secondary-link__icon {
    transform: translateX(0.5rem);
  }

  .hero-artifact-shell {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    min-width: 0;
    isolation: isolate;
  }

  .hero-fadeout {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 5rem;
    background: linear-gradient(to top, var(--bg-void), transparent);
  }

  @media (max-width: 1180px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.35rem;
    }

    .hero-copy,
    .hero-title,
    .hero-subtitle {
      max-width: none;
    }

    .hero-proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 4.4rem;
      padding-bottom: 2.6rem;
    }

    .hero-shell,
    .hero-copy {
      max-width: 100%;
    }

    .hero-copy {
      gap: 1rem;
      padding: 0.2rem 0 0.55rem;
    }

    .hero-title {
      font-size: clamp(2.5rem, 8vw, 3.3rem);
    }

    .hero-subtitle {
      font-size: clamp(1rem, 3vw, 1.04rem);
    }

    .hero-proof-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .hero-artifact-shell {
      margin-top: 0.2rem;
      max-height: 60vh;
      overflow: hidden;
    }

    .hero-artifact {
      max-height: 60vh;
      overflow: auto;
    }

    .hero-artifact__image {
      max-height: 20rem;
      object-fit: contain;
    }

    .btn-premium {
      padding: 0.75rem 1.5rem;
      font-size: 0.8rem;
    }

    .hero-secondary-link {
      font-size: 0.72rem;
    }

    .hero-background {
      opacity: 0.78;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 4rem;
      padding-bottom: 2.5rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 10vw, 2.7rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-prelude {
      align-items: flex-start;
      justify-content: flex-start;
    }

    .hero-title {
      max-width: 18ch;
    }

    .btn-premium {
      width: 100%;
      text-align: center;
    }

    .hero-actions > a {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>
