---
/**
 * Brutalist Footer Component
 * Minimal, grid-exposed structure
 */
import { footerContent } from '@/lib/content/footer'

const currentYear = new Date().getFullYear()

export interface Props {
  tagline?: string
  foundation?: string
  manifesto?: string
  proofTitle?: string
  reviewStandards?: string[]
  proofCTA?: { text: string; href: string }
}

const links = {
  product: [
    { href: '/training', label: 'Training' },
    { href: '/features', label: 'Features' },
    { href: '/trust', label: 'Trust' },
    { href: '/demo-hub', label: 'Demos' },
  ],
  company: [
    { href: '/about', label: 'About' },
    { href: '/company', label: 'Company' },
    { href: '/team', label: 'Team' },
    { href: '/contact', label: 'Contact' },
  ],
  legal: [
    { href: '/privacy', label: 'Privacy' },
    { href: '/terms', label: 'Terms' },
    { href: '/cookie-policy', label: 'Cookies' },
  ],
}

const social = [
  {
    href: 'https://github.com/nochadisfaction/pixelated',
    label: 'GitHub',
    icon: 'github',
  },
  {
    href: 'https://x.com/pixelatedempathy',
    label: 'X',
    icon: 'x',
  },
]

const {
  tagline = footerContent.tagline,
  foundation = footerContent.foundation,
  manifesto = footerContent.manifesto,
  proofTitle = footerContent.proofTitle,
  reviewStandards = footerContent.reviewStandards,
  proofCTA = footerContent.proofCTA,
} = Astro.props
---

<footer class="footer" data-component="brutalist-footer">
  <!-- Top Accent Line -->
  <div class="footer-accent" aria-hidden="true"></div>

  <div class="footer-container">
    <!-- Main Grid -->
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-brand-lockup">
            <img
              src="/favicon.svg"
              alt="Pixelated Empathy"
              class="footer-logo-mark"
              width="36"
              height="36"
              loading="lazy"
              decoding="async"
            />
            <span class="footer-logo-text">
              Pixelated <span class="footer-logo-text-accent">Empathy</span>
            </span>
          </span>
        </a>
        <p class="footer-tagline">
          {tagline}
        </p>
        <p class="footer-foundation">
          {foundation}
        </p>
        <p class="footer-manifesto">
          {manifesto}
        </p>

        <!-- Social Links -->
        <div class="footer-social">
          {
            social.map((item) => (
              <a
                href={item.href}
                class="footer-social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.label}
              >
                {item.icon === 'github' && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="18"
                    height="18"
                  >
                    <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.09.682-.22.682-.48 0-.24-.009-.87-.013-1.71-2.782.6-3.369-1.34-3.369-1.34-.454-1.16-1.11-1.47-1.11-1.47-.908-.62.069-.61.069-.61 1.003.07 1.531 1.03 1.531 1.03.892 1.53 2.341 1.09 2.91.83.092-.65.35-1.09.636-1.34-2.22-.25-4.555-1.11-4.555-4.94 0-1.09.39-1.98 1.029-2.68-.103-.25-.446-1.27.098-2.64 0 0 .84-.27 2.75 1.02A9.578 9.578 0 0112 6.84c.85 0 1.7.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.546 1.37.202 2.39.1 2.64.64.7 1.028 1.59 1.028 2.68 0 3.84-2.339 4.68-4.566 4.94.359.31.678.92.678 1.85 0 1.34-.012 2.42-.012 2.75 0 .27.18.58.688.48A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z" />
                  </svg>
                )}
                {item.icon === 'x' && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="18"
                    height="18"
                  >
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <div class="footer-link-groups">
        <div class="footer-links">
          <span class="footer-links-label">Product</span>
          <ul class="footer-links-list">
            {
              links.product.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-links">
          <span class="footer-links-label">Company</span>
          <ul class="footer-links-list">
            {
              links.company.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-links">
          <span class="footer-links-label">Policies</span>
          <ul class="footer-links-list">
            {
              links.legal.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <aside class="footer-proof">
        <span class="footer-links-label">Decision standard</span>
        <h3 class="footer-proof-title">
          {proofTitle}
        </h3>
        <ul class="footer-proof-list">
          {
            reviewStandards.map((item) => (
              <li class="footer-proof-item">{item}</li>
            ))
          }
        </ul>
        <a href={proofCTA.href} class="footer-proof-link">{proofCTA.text}</a>
      </aside>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {currentYear} Pixelated Empathy // All rights reserved.
      </p>
      <p class="footer-built">
        <span class="footer-built-dot"></span>
        Therapy simulation platform // Public site
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--bg-void);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-accent {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--accent-primary) 50%,
      transparent 100%
    );
    opacity: 0.2;
  }

  .footer-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--spacing-12) var(--spacing-6);
  }

  /* Grid Layout */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-6);
    margin-bottom: var(--spacing-8);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: var(--spacing-8);
    }
  }

  @media (min-width: 960px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--spacing-10);
    }
  }

  .footer-link-groups {
    display: grid;
    gap: var(--spacing-6);
  }

  @media (min-width: 640px) {
    .footer-link-groups {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-4);
    }
  }

  /* Brand */
  .footer-brand {
    max-width: 22rem;
  }

  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: var(--spacing-4);
  }

  .footer-logo:hover .footer-logo-mark {
    transform: translateY(-1px);
  }

  .footer-logo:hover .footer-logo-text-accent {
    color: #b5dec7;
  }

  .footer-brand-lockup {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-3);
  }

  .footer-logo-mark {
    width: 2.25rem;
    height: 2.25rem;
    object-fit: contain;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
  }

  .footer-logo-text-accent {
    color: var(--accent-primary);
    transition: color 0.2s ease;
  }

  .footer-foundation {
    margin-top: var(--spacing-2);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .footer-tagline {
    margin-top: var(--spacing-4);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-4);
  }

  .footer-manifesto {
    margin-top: var(--spacing-4);
    max-width: 15rem;
    font-family: var(--font-display);
    font-size: clamp(0.94rem, 0.9rem + 0.2vw, 1.08rem);
    line-height: 1.16;
    color: var(--text-primary);
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--spacing-4);
    margin-top: var(--spacing-4);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .footer-social-link:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  /* Links */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .footer-proof {
    display: grid;
    align-content: start;
    gap: var(--spacing-3);
    padding: 0;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
  }

  .footer-proof-title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.94rem + 0.28vw, 1.22rem);
    line-height: 1.12;
    color: var(--text-primary);
  }

  .footer-proof-list {
    display: grid;
    gap: var(--spacing-2);
    margin: 0;
    padding-left: 1rem;
    color: var(--text-secondary);
    line-height: 1.48;
    list-style: disc;
  }

  .footer-proof-item {
    list-style: disc;
  }

  .footer-proof-link {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    min-height: auto;
    padding: 0;
    border: 0;
    color: var(--accent-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background: transparent;
  }

  .footer-proof-link:hover {
    color: var(--text-primary);
  }

  .footer-links-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .footer-links-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  /* Bottom Bar */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    margin-top: var(--spacing-8);
    padding-top: var(--spacing-6);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-copyright,
  .footer-built {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .footer-built {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-built-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 999px;
    background: var(--accent-primary);
    box-shadow: 0 0 0 0 rgba(136, 201, 165, 0.12);
    animation: footer-pulse 1.8s ease-in-out infinite;
  }

  @keyframes footer-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(136, 201, 165, 0.08);
      opacity: 0.82;
    }

    50% {
      box-shadow: 0 0 0 0.3rem rgba(136, 201, 165, 0.02);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-built-dot {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .footer-brand {
      max-width: none;
    }

    .footer-proof-item:last-child {
      display: none;
    }
  }
</style>
