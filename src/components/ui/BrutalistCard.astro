---
/**
 * Brutalist Card Component
 * Uses new Pixelated Brutalism design tokens
 */
export interface Props {
  variant?: 'default' | 'accent' | 'lined' | 'outline' | 'metric'
  class?: string
}

const { variant = 'default', class: className = '' } = Astro.props

const baseClasses = 'card'
const variantClasses = {
  default: '',
  accent: 'card-accent',
  lined: 'card-lined',
  outline: 'card-outline',
  metric: 'card-metric',
}

const classes = [baseClasses, variantClasses[variant], className]
  .filter(Boolean)
  .join(' ')
---

<div class={classes}>
  <slot />
</div>
