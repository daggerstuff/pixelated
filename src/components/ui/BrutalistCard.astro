---
/**
 * Brutalist Card Component
 * Uses new Pixelated Brutalism design tokens
 */
export interface Props {
  variant?:
    | 'default'
    | 'accent'
    | 'lined'
    | 'outline'
    | 'metric'
    | 'elevated'
    | 'security'
  class?: string
  hover?: boolean
}

const {
  variant = 'default',
  class: className = '',
  hover = false,
} = Astro.props

const baseClasses = 'card'
const variantClasses = {
  default: '',
  accent: 'card-accent',
  lined: 'card-lined',
  outline: 'card-outline',
  metric: 'card-metric',
  elevated: 'card-elevated',
  security: 'card-security',
}

const classes = [
  baseClasses,
  variantClasses[variant],
  hover ? 'card-hover' : '',
  className,
]
  .filter(Boolean)
  .join(' ')
---

<div class={classes}>
  <slot />
</div>
