---
/**
 * Brutalist Header Component
 * Minimal navigation with terminal-like precision
 */
export interface Props {
  logo?: string
  title?: string
}

const { logo = "/logo.svg", title = "Pixelated Empathy" } = Astro.props

const navItems = [
  { href: "/", label: "Home" },
  { href: "/training", label: "Training" },
  { href: "/features", label: "Features" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
]
---

<header class="header" data-component="brutalist-header">
  <div class="header-container">
    <!-- Logo Section -->
    <a href="/" class="header-logo">
      {logo && (
        <img src={logo} alt={title} class="header-logo-img" width="32" height="32" />
      )}
      <span class="header-logo-text">{title}</span>
    </a>
    
    <!-- Navigation -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="header-nav-list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    
    <!-- Actions -->
    <div class="header-actions">
      <a href="/login" class="btn btn-ghost btn-sm">Sign In</a>
      <a href="/signup" class="btn btn-primary btn-sm">Start</a>
    </div>
    
    <!-- Mobile Menu Toggle -->
    <button class="header-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="menu-icon">
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
  
  <!-- Mobile Navigation -->
  <nav class="header-mobile-nav" aria-label="Mobile navigation">
    <ul class="header-mobile-list">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="nav-link">{item.label}</a>
        </li>
      ))}
      <li class="header-mobile-actions">
        <a href="/login" class="btn btn-outline">Sign In</a>
        <a href="/signup" class="btn btn-primary">Start Training</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background: rgba(0, 0, 0, 0.9);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: transform 0.3s var(--ease-out);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: var(--space-4) var(--space-6);
    gap: var(--space-8);
  }
  
  /* Logo */
  .header-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--text-primary);
  }
  
  .header-logo-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }
  
  .header-logo-text {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
  }
  
  /* Navigation */
  .header-nav {
    display: none;
  }
  
  @media (min-width: 768px) {
    .header-nav {
      display: block;
    }
  }
  
  .header-nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    padding: var(--space-2) 0;
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }
  
  .nav-link:hover {
    color: var(--text-primary);
  }
  
  .nav-link[aria-current="page"] {
    color: var(--accent-primary);
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-fast) var(--ease-out);
  }
  
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    transform: scaleX(1);
  }
  
  /* Actions */
  .header-actions {
    display: none;
    align-items: center;
    gap: var(--space-3);
  }
  
  @media (min-width: 768px) {
    .header-actions {
      display: flex;
    }
  }
  
  /* Mobile Menu Toggle */
  .header-menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-out);
  }
  
  .header-menu-toggle:hover {
    border-color: var(--accent-primary);
  }
  
  @media (min-width: 768px) {
    .header-menu-toggle {
      display: none;
    }
  }
  
  .menu-icon {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 18px;
  }
  
  .menu-icon span {
    display: block;
    height: 1px;
    background: var(--text-primary);
    transition: all var(--duration-fast) var(--ease-out);
  }
  
  .header-menu-toggle[aria-expanded="true"] .menu-icon span:first-child {
    transform: rotate(45deg) translateY(5px);
  }
  
  .header-menu-toggle[aria-expanded="true"] .menu-icon span:last-child {
    transform: rotate(-45deg) translateY(-5px);
  }
  
  /* Mobile Navigation */
  .header-mobile-nav {
    display: none;
    background: var(--bg-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: var(--space-4) var(--space-6);
  }
  
  .header-mobile-nav[aria-hidden="false"] {
    display: block;
  }
  
  .header-mobile-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .header-mobile-list .nav-link {
    display: block;
    padding: var(--space-3) 0;
    font-size: var(--text-sm);
  }
  
  .header-mobile-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .header-mobile-actions .btn {
    width: 100%;
    justify-content: center;
  }
</style>

<script>
  const toggle = document.querySelector('.header-menu-toggle');
  const mobileNav = document.querySelector('.header-mobile-nav');
  
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobileNav?.setAttribute('aria-hidden', String(expanded));
  });
  
  // Scroll behavior
  let lastScroll = 0;
  const header = document.querySelector('.header');
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    
    if (currentScroll > lastScroll && currentScroll > 100) {
      header?.style.setProperty('transform', 'translateY(-100%)');
    } else {
      header?.style.setProperty('transform', 'translateY(0)');
    }
    
    lastScroll = currentScroll;
  }, { passive: true });
</script>
