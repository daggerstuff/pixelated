---
/**
 * Brutalist Header Component
 * Minimal navigation with terminal-like precision
 */
import { headerContent } from '@/lib/content/header'

export interface Props {
  logo?: string
  title?: string
}

const { logo = '/favicon.svg', title = headerContent.title } = Astro.props
const [titlePrimary = 'Pixelated', ...titleRest] = title.trim().split(/\s+/)
const titleSecondary = titleRest.join(' ')

const currentPath = Astro.url.pathname
const isActivePath = (href: string) =>
  href === '/'
    ? currentPath === '/'
    : currentPath === href || currentPath.startsWith(`${href}/`)

const navItems = headerContent.navItems
const primaryAction = headerContent.actions.primary
const secondaryAction = headerContent.actions.secondary
---

<header class="header">
  <div class="header-container">
    <a href="/" class="header-brand-link">
      <div class="logo-container">
        <img
          src={logo}
          alt={title}
          class="logo-img"
          width="40"
          height="40"
          loading="eager"
          decoding="async"
        />
        <div class="logo-glow"></div>
      </div>
      <span class="brand-lockup">
        <span class="brand-mark">
          <span class="brand-mark__primary">{titlePrimary}</span>
          {titleSecondary ? (
            <span class="brand-mark__secondary">{titleSecondary}</span>
          ) : null}
        </span>
        <span class="brand-meta">{headerContent.brandMeta}</span>
      </span>
    </a>

    <div class="header-frame">
      <nav class="header-nav" aria-label="Main navigation">
        <ul class="header-nav-list">
          {
            navItems.map((item, index) => (
              <li>
                <a
                  href={item.href}
                  class="header-nav-link"
                  aria-current={isActivePath(item.href) ? 'page' : undefined}
                >
                  <span class="header-nav-link__index">{String(index + 1).padStart(2, '0')}</span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="header-actions">
        <a href={secondaryAction.href} class="header-action-link header-action-link--secondary">{secondaryAction.text}</a>
        <a href={primaryAction.href} class="header-action-link header-action-link--primary">{primaryAction.text}</a>
      </div>
    </div>

    <details class="header-mobile-shell">
      <summary class="header-menu-toggle" aria-label="Toggle menu">
        <span class="menu-icon">
          <span></span>
          <span></span>
        </span>
      </summary>

      <nav class="header-mobile-nav" aria-label="Mobile navigation">
        <ul class="header-mobile-list">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="header-nav-link"
                  aria-current={isActivePath(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li class="header-mobile-actions">
            <a href={secondaryAction.href} class="header-action-link header-action-link--secondary">{secondaryAction.text}</a>
            <a href={primaryAction.href} class="header-action-link header-action-link--primary">{primaryAction.text}</a>
          </li>
        </ul>
      </nav>
    </details>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(10, 13, 13, 0.86);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .header::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(125, 211, 168, 0.55), transparent);
  }

  .header-container {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    max-width: 80rem;
    margin: 0 auto;
    padding: 1rem var(--space-6);
    gap: clamp(1rem, 2vw, 2rem);
  }

  .header-brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    min-width: 0;
    padding-right: clamp(0.8rem, 1.8vw, 1.25rem);
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    white-space: nowrap;
    font-family: var(--font-display);
    letter-spacing: -0.03em;
  }

  .brand-lockup {
    display: grid;
    gap: 0.18rem;
  }

  .brand-mark__primary,
  .brand-mark__secondary {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.05rem + 0.45vw, 1.55rem);
    font-weight: 600;
    line-height: 1;
  }

  .header-brand-link:hover .brand-mark__primary,
  .header-brand-link:hover .brand-mark__secondary {
    color: var(--accent-primary);
  }

  .brand-mark__secondary {
    color: var(--accent-primary);
    font-weight: 600;
  }

  .brand-meta {
    display: inline-flex;
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: none;
    color: var(--text-tertiary);
  }

  .header-frame {
    display: none;
  }

  .header-action-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.6rem 1rem;
    border-radius: 0.35rem;
    border: 1px solid transparent;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .header-action-link--secondary {
    color: var(--text-secondary);
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
  }

  .header-action-link--secondary:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .header-action-link--primary {
    color: #09100e;
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .header-action-link--primary:hover {
    color: var(--accent-primary);
    background: transparent;
  }

  /* Navigation */
  @media (min-width: 768px) {
    .brand-meta {
      align-items: center;
      max-width: 15rem;
      line-height: 1.35;
    }

    .header-frame {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: var(--space-4);
      min-width: 0;
      padding: 0.65rem 0.65rem 0.65rem 1rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
        rgba(8, 12, 13, 0.45);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
      position: relative;
    }

    .header-frame::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 3px;
      background: linear-gradient(180deg, rgba(125, 211, 168, 0.85), rgba(125, 211, 168, 0.12));
    }

    .header-nav {
      display: block;
      min-width: 0;
    }
  }

  .header-nav-list {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 1.5vw, 1.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.35rem 0;
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .header-nav-link__index {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.35);
  }

  .header-nav-link:hover {
    color: var(--text-primary);
  }

  .header-nav-link[aria-current='page'] {
    color: var(--accent-primary);
  }

  .header-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .header-nav-link:hover::after,
  .header-nav-link[aria-current='page']::after {
    transform: scaleX(1);
  }

  .header-actions {
    align-items: center;
    gap: 0.55rem;
  }

  /* Mobile Menu Toggle */
  .header-mobile-shell {
    display: block;
    justify-self: end;
  }

  .header-mobile-shell summary {
    list-style: none;
  }

  .header-mobile-shell summary::-webkit-details-marker {
    display: none;
  }

  .header-menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .header-menu-toggle:hover {
    border-color: var(--accent-primary);
  }

  @media (min-width: 768px) {
    .header-mobile-shell {
      display: none;
    }
  }

  .menu-icon {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 18px;
  }

  .menu-icon span {
    display: block;
    height: 1px;
    background: var(--text-primary);
    transition: all var(--duration-fast) var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-icon span {
      transition: none;
    }

    .header-nav-link::after {
      transition: none;
    }

    .header-action-link {
      transition: none;
    }

    .logo-img {
      transition: none;
    }

    .logo-glow {
      transition: none;
    }
  }

  .header-mobile-shell[open] .menu-icon span:first-child {
    transform: rotate(45deg) translateY(5px);
  }

  .header-mobile-shell[open] .menu-icon span:last-child {
    transform: rotate(-45deg) translateY(-5px);
  }

  /* Mobile Navigation */
  .header-mobile-nav {
    display: none;
    background: rgba(10, 13, 13, 0.98);
    border-top: 1px solid var(--glass-border);
    padding: var(--space-4) var(--space-6);
    position: absolute;
    right: var(--space-4);
    top: calc(100% + 0.55rem);
    width: min(20rem, calc(100vw - 2rem));
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.28);
  }

  .header-mobile-shell[open] .header-mobile-nav {
    display: block;
  }

  .header-mobile-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-mobile-list .header-nav-link {
    display: block;
    padding: var(--space-3) 0;
    font-size: 0.92rem;
  }

  .header-mobile-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--glass-border);
  }

  .header-mobile-actions .header-action-link {
    width: 100%;
    justify-content: center;
  }

  /* Logo styles */
  .logo-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    height: 2.5rem;
    width: 2.5rem;
    object-fit: contain;
    transition: transform 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .logo-glow {
    position: absolute;
    inset: -0.25rem;
    background: var(--accent-primary);
    opacity: 0;
    filter: blur(0.875rem);
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .header-brand-link:hover .logo-glow {
    opacity: 0.2;
  }

  .header-brand-link:hover .logo-img {
    transform: scale(1.05);
  }

  @media (max-width: 767px) {
    .header-container {
      grid-template-columns: minmax(0, 1fr) auto;
      padding: 0.85rem var(--space-4);
    }

    .brand-mark {
      gap: 0.34rem;
    }

    .brand-mark__primary,
    .brand-mark__secondary {
      font-size: 1rem;
    }

    .logo-img {
      height: 2.2rem;
      width: 2.2rem;
    }

    .header-brand-link {
      padding-right: 0;
      border-right: 0;
    }

    .brand-meta {
      display: none;
    }
  }
</style>
