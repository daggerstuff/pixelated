  'shield':
    'M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L10 9.586 8.707 8.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z',
  'shield-check':
    'M10 1l6 3v5c0 3.866-2.239 7.39-6 9-3.761-1.61-6-5.134-6-9V4l6-3zm3.707 6.293a1 1 0 00-1.414-1.414L9 9.172 7.707 7.879a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z',
  'database':
    'M4 4c0-1.105 2.686-2 6-2s6 .895 6 2-2.686 2-6 2-6-.895-6-2zm0 4c0 1.105 2.686 2 6 2s6-.895 6-2M4 12c0 1.105 2.686 2 6 2s6-.895 6-2M4 4v12c0 1.105 2.686 2 6 2s6-.895 6-2V4',
