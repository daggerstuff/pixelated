---

<ul class:list={[isPortal ? 'space-y-2 font-medium' : 'space-y-1']}>
  {
    items.map((item) => {
      const isActive = activeItem === item.id
      return (
        <li>
          <a
            href={item.href}
            class:list={
              isPortal
                ? [
                    'flex items-center p-2 rounded-lg',
                    isActive
                      ? 'bg-gray-100 dark:bg-gray-700 text-blue-600 dark:text-blue-500'
                      : 'text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700',
                  ]
                : [
                    'nav-link-refined flex items-center px-6 py-3',
                    { 'nav-link-refined--active': isActive },
                  ]
            }
          >
            {
              showIcons && item.icon && iconPaths[item.icon] && (
                <span class={isPortal ? 'mr-3' : 'mr-3'}>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path d={iconPaths[item.icon]}></path>
                  </svg>
                </span>
              )
            }
            <span class={isPortal ? 'ms-3' : undefined}>{item.label}</span>
          </a>
        </li>
      )
    })
  }
</ul>
