---
import type { AdminNavItem } from './admin-nav'

interface Props {
  items: AdminNavItem[]
  activeItem?: string
  variant?: 'portal' | 'refined'
  showIcons?: boolean
}

const {
  items,
  activeItem = '',
  variant = 'portal',
  showIcons = false,
} = Astro.props

const isPortal = variant === 'portal'

const iconPaths: Record<string, string> = {
