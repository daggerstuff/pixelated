    'M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z',
  'document':
    'M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V8l-4-4H6zm6 1.5L14.5 6H12V3.5zM7 9h6v1.5H7V9zm0 3h6v1.5H7V12z',
