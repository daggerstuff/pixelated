{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "react", "react-dom", "vitest/globals"]
  },
  "include": [
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/*.spec.ts",
    "./src/**/*.spec.tsx",
    "./tests/**/*.ts",
    "./tests/**/*.tsx",
    "./tests/**/*.spec.ts",
    "./tests/**/*.test.ts",
    "./src/types/**/*.d.ts",
    "./src/types/**/*.ts",
    "./types/**/*.d.ts",
    "./types/**/*.ts"
  ]
}
