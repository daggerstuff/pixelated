{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ============================================================================
  // BLOCK ALL CLAUDE CODE IMPORTS
  // ============================================================================
  // Every flag defaults to true if the block is missing. All six MUST be false.
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": false,
    "agents": false,
    "hooks": false,
    "plugins": false
  },

  // ============================================================================
  // AGENT CONFIGURATIONS
  // ============================================================================
  "agents": {
    "sisyphus": {
      "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
      "variant": "max",
      "fallback_models": [
        { "model": "qwen/qwen3.5-397b-a17b", "variant": "high" },
        { "model": "deepseek-ai/deepseek-v3.2", "variant": "high" },
        { "model": "mistralai/mistral-large-3-675b-instruct-2512", "variant": "high" }
      ]
    },
    "hephaestus": {
      "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
      "variant": "high",
      "fallback_models": [
        { "model": "qwen/qwen3-coder-480b-a35b-instruct", "variant": "high" },
        { "model": "mistralai/devstral-2-123b-instruct-2512" },
        { "model": "qwen/qwen3.5-397b-a17b", "variant": "high" }
      ]
    },
    "oracle": {
      "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
      "variant": "high",
      "fallback_models": [
        { "model": "deepseek-ai/deepseek-v3.2", "variant": "high" },
        { "model": "qwen/qwen3.5-397b-a17b", "variant": "high" },
        { "model": "mistralai/mistral-large-3-675b-instruct-2512", "variant": "high" }
      ]
    },
    "explore": {
      "model": "nvidia/llama-3.3-nemotron-super-49b-v1.5",
      "variant": "medium",
      "fallback_models": [
        { "model": "nvidia/nemotron-3-nano-30b-a3b" },
        { "model": "mistralai/mistral-small-4-119b-2603" },
        { "model": "meta/llama-3.1-8b-instruct" }
      ]
    },
    "multimodal-looker": {
      "model": "google/gemma-4-31b-it",
      "variant": "medium",
      "fallback_models": [
        { "model": "microsoft/phi-4-multimodal-instruct" },
        { "model": "meta/llama-3.2-90b-vision-instruct" },
        { "model": "qwen/qwen3.5-397b-a17b" }
      ]
    },
    "prometheus": {
      "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
      "variant": "max",
      "fallback_models": [
        { "model": "qwen/qwen3.5-397b-a17b", "variant": "high" },
        { "model": "deepseek-ai/deepseek-v3.2", "variant": "high" },
        { "model": "mistralai/mistral-large-3-675b-instruct-2512", "variant": "high" }
      ]
    },
    "metis": {
      "model": "deepseek-ai/deepseek-v3.2",
      "variant": "high",
      "fallback_models": [
        { "model": "qwen/qwen3.5-397b-a17b", "variant": "high" },
        { "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1", "variant": "high" }
      ]
    },
    "momus": {
      "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
      "variant": "high",
      "fallback_models": [
        { "model": "deepseek-ai/deepseek-v3.2", "variant": "high" },
        { "model": "qwen/qwen3.5-397b-a17b", "variant": "high" },
        { "model": "mistralai/mistral-large-3-675b-instruct-2512", "variant": "high" }
      ]
    },
    "atlas": {
      "model": "nvidia/llama-3.3-nemotron-super-49b-v1.5",
      "variant": "medium",
      "fallback_models": [
        { "model": "moonshotai/kimi-k2.5" },
        { "model": "meta/llama-3.3-70b-instruct" },
        { "model": "nvidia/nemotron-3-super-120b-a12b" }
      ]
    },
    "sisyphus-junior": {
      "model": "nvidia/llama-3.1-nemotron-nano-8b-v1",
      "fallback_models": [
        { "model": "microsoft/phi-4-mini-instruct" },
        { "model": "meta/llama-3.2-3b-instruct" },
        { "model": "nvidia/nemotron-3-nano-30b-a3b" }
      ]
    },
    "librarian": {
      "model": "moonshotai/kimi-k2.5",
      "variant": "medium",
      "fallback_models": [
        { "model": "qwen/qwen3-coder-480b-a35b-instruct" },
        { "model": "nvidia/llama-3.3-nemotron-super-49b-v1.5" },
        { "model": "mistralai/mistral-small-4-119b-2603" }
