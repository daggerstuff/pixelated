{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  // ============================================================================
  // DCP — Dynamic Context Pruning
  // ============================================================================
  // Installed via: opencode plugin @tarquinen/opencode-dcp@latest --global
  // Config search order (last match wins):
  //   1. ~/.config/opencode/dcp.jsonc
  //   2. $OPENCODE_CONFIG_DIR/dcp.jsonc
  //   3. .opencode/dcp.jsonc  ← this file (project-level, highest priority)

  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "toast",

  "commands": {
    "enabled": true,
    "protectedTools": ["compress", "batch"],
  },

  "manualMode": {
    "enabled": false,
    "automaticStrategies": true,
  },

  "turnProtection": {
    "enabled": true,
    "turns": 2,
  },

  "experimental": {
    "allowSubAgents": true,
    "customPrompts": false,
  },

  // Protect important files from being pruned during compression
  "protectedFilePatterns": [
    ".env",
    ".env.*",
    "*.key",
    "*.pem",
    "package-lock.json",
    "pnpm-lock.yaml",
  ],

  // ============================================================================
  // COMPRESSION SETTINGS
  // ============================================================================
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "protectUserMessages": true,

    // Aggressive thresholds to preemptively compress BEFORE context rot degrades model quality
    // Even on 128K+ models, recall accuracy drops as the window fills — compress early
    "maxContextLimit": "70%",
    "minContextLimit": "20%",
    "nudgeFrequency": 3,
    "iterationNudgeThreshold": 10,
    "nudgeForce": "strong",

    "protectedTools": [
      "task",
      "skill",
      "todowrite",
      "todoread",
      "compress",
      "batch",
    ],

    // ============================================================================
    // MODEL-SPECIFIC CONTEXT LIMITS
    // ============================================================================
    // Format: absolute token count OR "X%" of model's context window
    // Higher maxLimits → more aggressive pruning at lower thresholds
    // Higher minLimits → earlier compression triggers

    // GLM-5 (128K context) — lower thresholds to reduce tool-call JSON errors
    // Prone to malformed output under context pressure; compress earlier
    "modelMaxLimits": {
      "z-ai/glm5": 90000,
      "z-ai/glm4.7": 100000,

      // Qwen 3.5 122B (131K context) — strict system message ordering
      // Compress earlier to reduce message count and system prompt collisions
      "qwen/qwen3.5-122b-a10b": 100000,

      // Qwen 3.5 397B (262K context) — larger window but same system message rules
      "qwen/qwen3.5-397b-a17b": 200000,

      // Qwen 3 Coder 480B (131K context)
      "qwen/qwen3-coder-480b-a35b-instruct": 100000,

      // Qwen 3 Next 80B (131K context)
      "qwen/qwen3-next-80b-a3b-instruct": 100000,
      "qwen/qwen3-next-80b-a3b-thinking": 100000,

      // Nemotron Ultra 253B (128K context) — best tool use, can handle more context
      "nvidia/llama-3.1-nemotron-ultra-253b-v1": 100000,

      // Nemotron Super 49B (128K context)
      "nvidia/llama-3.3-nemotron-super-49b-v1.5": 95000,

      // Nemotron 3 Super 120B (128K context)
      "nvidia/nemotron-3-super-120b-a12b": 95000,

      // Nemotron Nano 8B (128K context) — smaller model, compress more aggressively
      "nvidia/llama-3.1-nemotron-nano-8b-v1": 80000,
      "nvidia/nemotron-3-nano-30b-a3b": 85000,

      // DeepSeek V3.2 (128K context)
      "deepseek-ai/deepseek-v3.2": 100000,
      "deepseek-ai/deepseek-v3.1": 95000,

      // Mistral Large 3 675B (128K context)
      "mistralai/mistral-large-3-675b-instruct-2512": 100000,

      // Mistral Small 4 119B (128K context)
      "mistralai/mistral-small-4-119b-2603": 95000,

      // Devstral 2 123B (128K context)
      "mistralai/devstral-2-123b-instruct-2512": 95000,

      // Kimi K2.5 (256K context) — very long context, generous limits
      "moonshotai/kimi-k2.5": 200000,
      "moonshotai/kimi-k2-instruct": 200000,
      "moonshotai/kimi-k2-thinking": 200000,

      // Gemma 4 31B (128K context)
      "google/gemma-4-31b-it": 95000,

      // Llama 3.3 70B (128K context)
      "meta/llama-3.3-70b-instruct": 95000,

      // Default fallback for any unlisted model
      "default": 90000,
    },

    "modelMinLimits": {
      "z-ai/glm5": 40000,
      "z-ai/glm4.7": 45000,
      "qwen/qwen3.5-122b-a10b": 50000,
      "qwen/qwen3.5-397b-a17b": 80000,
      "qwen/qwen3-coder-480b-a35b-instruct": 50000,
      "qwen/qwen3-next-80b-a3b-instruct": 50000,
      "qwen/qwen3-next-80b-a3b-thinking": 50000,
      "nvidia/llama-3.1-nemotron-ultra-253b-v1": 50000,
      "nvidia/llama-3.3-nemotron-super-49b-v1.5": 45000,
      "nvidia/nemotron-3-super-120b-a12b": 45000,
      "nvidia/llama-3.1-nemotron-nano-8b-v1": 35000,
      "nvidia/nemotron-3-nano-30b-a3b": 40000,
      "deepseek-ai/deepseek-v3.2": 50000,
      "deepseek-ai/deepseek-v3.1": 45000,
      "mistralai/mistral-large-3-675b-instruct-2512": 50000,
      "mistralai/mistral-small-4-119b-2603": 45000,
      "mistralai/devstral-2-123b-instruct-2512": 45000,
      "moonshotai/kimi-k2.5": 100000,
      "moonshotai/kimi-k2-instruct": 100000,
      "moonshotai/kimi-k2-thinking": 100000,
      "google/gemma-4-31b-it": 45000,
      "meta/llama-3.3-70b-instruct": 45000,
      "default": 40000,
    },
  },

  // ============================================================================
  // STRATEGIES
  // ============================================================================
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": ["edit", "write"],
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": ["edit", "write"],
    },
  },
}
