# Production Dockerfile for Business Strategy CMS
# Base stage for shared environment (no build tools)
ARG NODE_IMAGE=node:24.12.0-bookworm-slim
FROM ${NODE_IMAGE} AS base
WORKDIR /app
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN npm install -g pnpm@11.0.8
RUN npm install -g npm@11.12.1

# Build dependencies stage (has build tools)
FROM ${NODE_IMAGE} AS build-base
WORKDIR /app
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV PRISMA_SKIP_POSTINSTALL_GENERATE=1
RUN npm install -g pnpm@11.0.8
RUN npm install -g npm@11.12.1
RUN set -eux; \
    echo 'Acquire::Retries "5";' > /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::http::Timeout "20";' >> /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::https::Timeout "20";' >> /etc/apt/apt.conf.d/80-retries && \
    apt-get update && \
    if ! apt-get install --no-install-recommends --no-install-suggests -y \
      python3 \
      make \
      g++ \
      libvips-dev \
      curl \
      git; then \
      echo "Retrying after apt index sync issue..." && \
      rm -rf /var/lib/apt/lists/* && \
      apt-get update && \
      apt-get install --no-install-recommends --no-install-suggests -y \
        python3 \
        make \
        g++ \
        libvips-dev \
        curl \
        git; \
    fi && \
    rm -rf /var/lib/apt/lists/*

# Runtime base stage (no build toolchain)
FROM ${NODE_IMAGE} AS runtime
WORKDIR /app
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN set -eux; \
    echo 'Acquire::Retries "5";' > /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::http::Timeout "20";' >> /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::https::Timeout "20";' >> /etc/apt/apt.conf.d/80-retries && \
    apt-get update && \
    if ! apt-get install --no-install-recommends --no-install-suggests -y curl; then \
      echo "Retrying after apt index sync issue..." && \
      rm -rf /var/lib/apt/lists/* && \
      apt-get update && \
      apt-get install --no-install-recommends --no-install-suggests -y curl; \
    fi && \
    rm -rf /var/lib/apt/lists/*

# Production dependencies stage
FROM build-base AS prod-deps
COPY package.json pnpm-lock.yaml ./
COPY scripts/devops/install-git-hooks.sh ./scripts/devops/install-git-hooks.sh
RUN pnpm install --frozen-lockfile

# Build stage
FROM prod-deps AS build
COPY . .
RUN pnpm run build

# Final runner stage
FROM runtime AS runner
WORKDIR /app

# The final runtime image only needs `node`; remove package-manager tooling
# so Trivy does not flag bundled npm/pnpm libraries we never use in prod.
RUN rm -rf /usr/local/lib/node_modules/npm /usr/local/lib/node_modules/corepack \
  && rm -f /usr/local/bin/npm /usr/local/bin/npx /usr/local/bin/corepack \
  && rm -rf /usr/local/lib/node_modules/pnpm \
  && rm -f /usr/local/bin/pnpm /usr/local/bin/pnpx

# Create user
RUN groupadd -g 1001 nodejs && useradd -u 1001 -g nodejs -s /bin/sh -m pixelated

# Copy necessary files from previous stages.
# Use the full dependency graph from the production dependency stage to avoid runtime failures from
# production pruning of packages that still resolve at runtime in SSR output.
COPY --from=prod-deps --chown=pixelated:nodejs /app/node_modules ./node_modules
COPY --from=build --chown=pixelated:nodejs /app/dist ./dist
COPY --chown=pixelated:nodejs package.json ./
COPY --chown=pixelated:nodejs scripts/ci/docker-entrypoint.js ./docker-entrypoint.js

# Create SSL directory
RUN mkdir -p /app/ssl && chown pixelated:nodejs /app/ssl

# Switch user
USER pixelated

# Environment variables
ENV HOST=0.0.0.0
ENV PORT=4321
ENV NODE_ENV=production

# Expose port
EXPOSE 4321

# Start application
CMD ["node", "./docker-entrypoint.js", "node", "./dist/server/entry.mjs"]
