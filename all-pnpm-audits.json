      "severity": "moderate",
      "module_name": "ip-address",
      "vulnerable_versions": "<=10.1.0",
      "github_advisory_id": "GHSA-v2v4-37r5-5v8g",
      "recommendation": "Upgrade to version 10.1.1 or later",
      "patched_versions": ">=10.1.1",
      "updated": "2026-05-05T21:51:01.000Z",
      "cvss": {
