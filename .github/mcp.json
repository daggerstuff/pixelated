{
  "mcpServers": {
    "context7": {
      "command": "pnpm",
      "args": ["dlx", "@upstash/context7-mcp"],
      "timeout": 30000
    },
    "rube": {
      "type": "http",
      "url": "https://rube.app/mcp",
      "headers": {
        "Authorization": "Bearer ${RUBE_API_KEY}"
      },
      "tools": ["*"],
      "timeout": 60000
    },
    "linear": {
      "command": "pnpm",
      "args": ["dlx", "@mseep/linear-mcp"],
      "timeout": 30000
    },
    "hindsight": {
      "command": "pnpm",
      "args": ["dlx", "hindsight-mcp"],
      "env": {
        "HINDSIGHT_DB_PATH": ".copilot/hindsight.db"
      },
      "timeout": 30000
    },
    "brave-search": {
      "command": "pnpm",
      "args": ["dlx", "@brave/brave-search-mcp-server"],
      "env": { "BRAVE_API_KEY": "${BRAVE_API_KEY}" },
      "timeout": 30000
    },
    "firecrawl": {
      "command": "pnpm",
      "args": ["dlx", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}" },
      "timeout": 60000
    },
    "sequential-thinking": {
      "command": "pnpm",
      "args": ["dlx", "@gotza02/seq-thinking"],
      "timeout": 30000
    },
    "playwright": {
      "command": "pnpm",
      "args": ["dlx", "@playwright/mcp"],
      "timeout": 60000
    },
    "sentry": {
      "command": "pnpm",
      "args": ["dlx", "@sentry/mcp-server"],
      "env": { "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}" },
      "timeout": 30000
    }
  }
}
