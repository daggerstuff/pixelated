{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true,
    "vitest": true
  },
  "globals": {
    "expect": "readonly",
    "it": "readonly",
    "describe": "readonly",
    "vi": "readonly",
    "beforeEach": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "afterAll": "readonly",
    "test": "readonly"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": ["import", "typescript", "react", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "settings": {
    "react": {
      "version": "19.0.0"
    }
  },
  "rules": {
    "no-unused-vars": "off",
    "no-shadow": "off",
    "no-useless-constructor": "off",
    "no-new": "off",
    "no-unused-expressions": "off",
    "no-extend-native": "off",
    "no-unneeded-ternary": "off",
    "block-scoped-var": "off",
    "import/no-cycle": "off",
    "import/default": "off",
    "import/no-named-as-default": "off",
    "import/no-named-as-default-member": "off",
    "import/no-duplicates": "off",
    "import/no-unassigned-import": "off",
    "import/no-empty-named-blocks": "off",
    "import/no-self-import": "off",
    "import/no-absolute-path": "off",
    "react/self-closing-comp": "off",
    "react/display-name": "off",
    "react/react-in-jsx-scope": "off",
    "react/no-this-in-sfc": "off",
    "react-hooks/exhaustive-deps": "off",
    "vitest/expect-expect": "off",
    "vitest/no-conditional-expect": "off",
    "vitest/require-mock-type-parameters": "off",
    "vitest/require-to-throw-message": "off",
    "vitest/hoisted-apis-on-top": "off",
    "jest/require-to-throw-message": "off",
    "jest/no-commented-out-tests": "off",
    "jest/valid-describe-callback": "off",
    "jest/no-export": "off",
    "jest/no-disabled-tests": "off",
    "jest/no-standalone-expect": "off",
    "preserve-caught-error": "off",
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-extraneous-class": "off",
    "@typescript-eslint/restrict-template-expressions": "warn",
    "@typescript-eslint/no-base-to-string": "warn",
    "@typescript-eslint/no-floating-promises": "error",
    "@typescript-eslint/no-redundant-type-constituents": "warn",
    "@typescript-eslint/unbound-method": "warn",
    "@typescript-eslint/no-misused-spread": "warn",
    "@typescript-eslint/require-array-sort-compare": "warn",
    "@typescript-eslint/await-thenable": "error",
    "typescript/no-explicit-any": "off",
    "typescript/no-extraneous-class": "off",
    "typescript/restrict-template-expressions": "warn",
    "typescript/no-base-to-string": "warn",
    "typescript/no-floating-promises": "error",
    "typescript/no-redundant-type-constituents": "warn",
    "typescript/unbound-method": "warn",
    "typescript/no-misused-spread": "warn",
    "typescript/require-array-sort-compare": "warn",
    "typescript/await-thenable": "error",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-unsafe-member-access": "warn",
    "typescript/no-unsafe-call": "warn",
    "typescript/no-unsafe-argument": "warn",
    "typescript/no-unsafe-return": "warn",
    "typescript/prefer-as-const": "warn",
    "typescript/prefer-enum-initializers": "warn",
    "typescript/prefer-for-of": "warn",
    "typescript/prefer-function-type": "warn",
    "typescript/prefer-includes": "warn",
    "typescript/prefer-nullish-coalescing": "warn",
    "typescript/prefer-optional-chain": "warn",
    "typescript/prefer-readonly": "warn",
    "typescript/prefer-reduce-type-parameter": "warn",
    "typescript/prefer-string-starts-ends-with": "warn",
    "typescript/promise-function-async": "warn",
    "typescript/restrict-plus-operands": "warn",
    "typescript/strict-boolean-expressions": "off",
    "typescript/switch-exhaustiveness-check": "error",
    "typescript/no-unnecessary-boolean-literal-compare": "warn",
    "typescript/no-unnecessary-condition": "warn",
    "typescript/no-unnecessary-qualifier": "warn",
    "typescript/no-unnecessary-type-arguments": "warn",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-unnecessary-type-constraint": "warn",
    "typescript/non-nullable-type-assertion-style": "warn",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-misused-spread": "warn"
  }
}
