{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "foresight": {
      "command": "uv",
      "args": ["run", "python", "-m", "ai.foresight.app"],
      "cwd": "/path/to/your/pixelated",
      "env": {
        "FORESIGHT_DB_PATH": "/home/your-user/.foresight/memory.db",
        "FORESIGHT_USER_ID": "your-username"
      }
    }
  }
}
