[Unit]
Description=Pixelated shared memory service
After=network.target

[Service]
Type=simple
User=__USER__
Group=__GROUP__
WorkingDirectory=__WORKDIR__
EnvironmentFile=-__ENV_FILE__
StateDirectory=pixelated-memory
ExecStart=__START_SCRIPT__
Restart=always
RestartSec=5
MemoryMax=__MEMORY_MAX__
MemoryHigh=__MEMORY_HIGH__
MemorySwapMax=__MEMORY_SWAP_MAX__
TasksMax=256

[Install]
WantedBy=multi-user.target
