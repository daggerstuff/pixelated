#!/usr/bin/env bash
set -euo pipefail

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🔍 [Hook] Running pre-commit checks...${NC}"

# A. Secret scanning (Catch potential leaks before they leave)
echo "🔒 Scanning for secrets..."
# Common sensitive filenames or patterns
EXPR="(\.env|config/secrets|\.pem|id_rsa|id_ed25519|.*\.key|.*\.p12|.*\.pfx)"

# Check for staged files matching sensitive patterns
if git diff --cached --name-only | grep -E "$EXPR" >/dev/null 2>&1; then
  SENSITIVE_FILES=$(git diff --cached --name-only | grep -E "$EXPR")
  echo -e "${RED}❌ ERROR: Potential sensitive file found in staged changes:${NC}"
  echo "$SENSITIVE_FILES"
  exit 1
fi

# Check for keywords like API_KEY, SECRET, PASSWORD in new code content
# Improved to evaluate line-by-line and handle safe pattern exclusion more accurately.
POTENTIAL_SECRETS=$(git diff --cached --unified=0 | grep -Ei "(api_key|secret|password|token|private_key|access_token|auth_token)\s*[=:]\s*['\"]?[a-zA-Z0-9+/=_\-]{12,}['\"]?" || true)

if [ -n "$POTENTIAL_SECRETS" ]; then
  FOUND_HARDCODED=false
  while read -r line; do
    [ -z "$line" ] && continue
    # Ignore known safe patterns like process.env or os.environ ONLY if they cover the whole line match
    if ! echo "$line" | grep -qiE "(process\.env|os\.environ|os\.getenv)"; then
      if [ "$FOUND_HARDCODED" = false ]; then
        echo -e "${RED}❌ ERROR: Potential hardcoded secret found in staged diff:${NC}"
      fi
      echo -e "${YELLOW}$line${NC}"
      FOUND_HARDCODED=true
    fi
  done <<< "$POTENTIAL_SECRETS"

  if [ "$FOUND_HARDCODED" = true ]; then
    echo -e "${YELLOW}Review your changes carefully. Use environment variables instead of hardcoding secrets.${NC}"
    exit 1
  fi
fi

# B. Check lockfile synchronization
if [ -f scripts/devops/check-lockfiles-pre-commit.sh ]; then
  echo "🔗 Checking lockfile synchronization..."
  bash scripts/devops/check-lockfiles-pre-commit.sh
fi

# C. Run linting via lint-staged (Fix Issue #2: performant linting only on staged files)
if command -v pnpm >/dev/null 2>&1 && [ -f .lintstagedrc.json ]; then
  echo -e "${GREEN}✨ Running linting via lint-staged (only on changed files)...${NC}"
  pnpm exec lint-staged --quiet
else
  echo -e "${YELLOW}✨ Running full project linting (consider setting up lint-staged)...${NC}"
  pnpm run lint
fi
