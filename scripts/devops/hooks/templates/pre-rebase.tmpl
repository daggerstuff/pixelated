#!/usr/bin/env bash
set -euo pipefail

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Hook arguments:
# $1: The upstream branch where we are rebasing ONTO.
# $2: The branch being rebased (optional; if omitted, current HEAD is rebased).

# UPSTREAM is the target branch ($1), and TARGET_BRANCH is the branch being rewritten ($2 or HEAD)
UPSTREAM="$1"
TARGET_BRANCH="${2:-$(git symbolic-ref -q --short HEAD || echo "detached")}"

# Normalize branch names to avoid path issues
TARGET_BRANCH=$(git rev-parse --abbrev-ref "$TARGET_BRANCH" 2>/dev/null || echo "$TARGET_BRANCH")

# Fetch protected branches from git config, falling back to defaults if not set.
# This prevents the hook from being 'frozen' at installation time.
PROTECTED_BRANCHES=$(git config --get pixelated.protectedBranches || echo "main master production staging")

for BRANCH in $PROTECTED_BRANCHES; do
  # Block only if we are specifically rewriting a protected branch's history.
  if [ "$TARGET_BRANCH" = "$BRANCH" ]; then
    echo -e "${RED}❌ ERROR: You are attempting to rewrite history of a protected branch ($BRANCH).${NC}"
    echo -e "${YELLOW}Rebasing protected branches is forbidden to maintain history integrity.${NC}"
    exit 1
  fi
done
