#!/usr/bin/env bash
set -euo pipefail

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Auto-sync lockfiles on checkout/merge
PREV_REF=""
if git rev-parse --verify HEAD@{1} >/dev/null 2>&1; then
  PREV_REF="HEAD@{1}"
elif git rev-parse --verify ORIG_HEAD >/dev/null 2>&1; then
  PREV_REF="ORIG_HEAD"
fi

if [ -n "$PREV_REF" ]; then
  # check for lockfile changes
  if git diff-tree -r --name-only "$PREV_REF" HEAD | grep -q 'pnpm-lock.yaml'; then
    if command -v pnpm >/dev/null 2>&1; then
      echo -e "${BLUE}📦 [Hook] pnpm-lock.yaml changed. Running pnpm install...${NC}"
      pnpm install
    else
      echo -e "${YELLOW}⚠️ [Hook] pnpm-lock.yaml changed but pnpm is not installed. Skipping install.${NC}"
    fi
  fi
  # check for python lockfile changes
  if git diff-tree -r --name-only "$PREV_REF" HEAD | grep -q 'uv.lock'; then
    if command -v uv >/dev/null 2>&1; then
      echo -e "${BLUE}📦 [Hook] uv.lock changed. Running uv sync --frozen...${NC}"
      uv sync --frozen
    else
      echo -e "${YELLOW}⚠️ [Hook] uv.lock changed but uv is not installed. Skipping sync.${NC}"
    fi
  fi
fi
